# Tina Quant System - 環境變數範例
# 複製此檔案為 .env 並填入實際值
# .env 不會被提交到 Git（已加入 .gitignore）

# === Telegram 通知 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === LINE Notify ===
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# === 資料庫路徑 ===
DB_PATH=./data/tina_master.db

# === FinMind API (需付費才能用法人的) ===
FINMIND_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiSm9qbzg4OCIsImVtYWlsIjoiYnJpYW4wMjYwQGdtYWlsLmNvbSJ9.oCdQO1qNRUCYxHZSVuRQCqlF7X2DbQ77wury5ARCKzM

# === API 健康檢查 ===
# 自動檢查頻率: 每日 09:00, 13:00, 17:00
# 報告位置: ./logs/api_health_check.json


# === 交易設定 ===
INITIAL_CAPITAL=3000000
MAX_POSITION_SIZE=30
STOP_LOSS_PCT=5
TAKE_PROFIT_PCT=10

# === 日誌設定 ===
LOG_LEVEL=INFO
LOG_DIR=./logs
