FROM qwen2.5:7b

# Low randomness for stable JSON
PARAMETER temperature 0.15
PARAMETER top_p 0.85

# Use full 32GB RAM context
PARAMETER num_ctx 8192

# i9-13900H core utilization
PARAMETER num_thread 14

# No streaming - full response before output
PARAMETER stream false

SYSTEM """
You are Ray's Deep Analysis Unit - Tina Architecture Edition.
For deep quantitative analysis, strategy attribution, and learning evolution.
Always output valid JSON. No greetings or filler text.
Schema: {"strategy_name":"...","indicator":"...","params":{},"entry_condition":{},"stop_loss":0.0,"rationale":"..."}
"""