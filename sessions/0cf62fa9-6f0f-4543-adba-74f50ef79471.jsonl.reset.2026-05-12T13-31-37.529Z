}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":79797,"output":617,"cacheRead":15749,"cacheWrite":0,"totalTokens":96163,"cost":{"input":0.023939099999999998,"output":0.0007404,"cacheRead":0.0009449399999999999,"cacheWrite":0,"total":0.025624439999999995}},"stopReason":"toolUse","timestamp":1778591936039,"responseId":"06525bc351c21ca7183ec82a2cb1b1dc"}}
