{"type":"message","id":"163650f2","parentId":"6c2b6c37","timestamp":"2026-05-12T12:00:03.066Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update LOCAL_CONFIG.md to document the routing rules clearly.\n","thinkingSignature":"63c62ad9bc6dfd7d6b20011e555864ce0e0370e141a5c04c54d8ca9284aa4262"},{"type":"toolCall","id":"call_function_dpa11ok53rtd_1","name":"write","arguments":{"content":"# Ray LLM Router Config\n# LLM 路由分層原則\n\nmode: auto  # auto | local_only | minimax_only\n\n# ══════════════════════════════════════════════════════════════\n# LLM 路由分層（Layer 0-3）\n# ══════════════════════════════════════════════════════════════\n# Layer 0: 純本地計算 → 不走 LLM\n#   us_momentum.py, us_scan_live.py, ray_engine.py\n#   技術指標、Sharpe/MDD 計算、SQLite 持久化\n#\n# Layer 1: 快速策略（< 3 秒）→ ray-v1（本地 Ollama）\n#   daily_scan, quick_signal, position_check, signal_parse\n#\n# Layer 2: 深度推理（3-15 秒）→ MiniMax Remnant（雲端）\n#   backtest_summary, deep_analysis, attribution, macro_outlook, json_validate\n#\n# Layer 3: 連網學習 → MiniMax（帶 web fetch）\n#   web_learn, news_summary, sentiment, macro_news, earnings_summary\n#\n# 數據獲取（永遠不走 LLM）：yfinance, finmind, twstock\n# ══════════════════════════════════════════════════════════════\n\nrules:\n  local_when:\n    - context: \"技術指標\" or \"backtest\" or \"SQLite查詢\" → 本地 Python 計算\n    - complexity: \"JSON<200字節\" → ray-v1（1.5B，< 3秒）\n    - task: \"us_momentum scan\" or \"live scan\" → ray-v1\n    - task: \"深度歸因\" or \"宏觀分析\" → MiniMax Layer 2\n    - task: \"連網學習\" or \"新聞摘要\" → MiniMax Layer 3\n\n  minimax_when:\n    - context: \"複雜推理\" or \"策略進化\" → MiniMax\n    - complexity: \"高複雜度\" → MiniMax\n    - task: \"general analysis\" without signal data → MiniMax\n\n# ══════════════════════════════════════════════════════════════\n# 模型映射\n# ══════════════════════════════════════════════════════════════\nollama:\n  base_url: \"http://localhost:11434/api/chat\"\n  layer1: \"ray-v1\"       # Qwen 1.5B - 快速任務（< 3s）\n  layer1_deep: \"ray-deep-v1\"  # Qwen 7B - 備用深度（少用）\n  layer1_v3: \"qwen3.5:4b\"    # Qwen 3.5 4B - 緊急快速\n\nminimax:\n  model: \"minimax/MiniMax-M2.7\"  # Remnant\n  layer2: \"deep_analysis, backtest_summary, attribution\"\n  layer3: \"web_learn, news_summary, sentiment\"\n\n# ══════════════════════════════════════════════════════════════\n# Token 節約策略（econ_learner 遺留）\n# ══════════════════════════════════════════════════════════════\ntoken_save:\n  batch_size: 10  # 10 篇文章批量一次 LLM\n  max_input_tokens: 3000\n  max_output_tokens: 1000\n\nfallback:\n  action: \"local_only\"  # local_only | minimax_only | error\n  error_note: \"Router 降級順序：MiniMax → ray-deep-v1 → ray-v1\"","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\LOCAL_CONFIG.md"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":189,"output":816,"cacheRead":79232,"cacheWrite":0,"totalTokens":80237,"cost":{"input":0.000056699999999999996,"output":0.0009792,"cacheRead":0.004753919999999999,"cacheWrite":0,"total":0.005789819999999999}},"stopReason":"toolUse","timestamp":1778587190647,"responseId":"065249399204fd9ab51420f533e5dacf"}}
