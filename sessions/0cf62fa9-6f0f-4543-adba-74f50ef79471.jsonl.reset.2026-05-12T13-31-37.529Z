rt requests\n            resp = requests.post(OLLAMA_URL, json={\n                \"model\": model,\n                \"messages\": [{\"role\": \"user\", \"content\": prompt}],\n                \"stream\": False\n            }, timeout=60)\n            return resp.json().get(\"message\", {}).get(\"content\", \"\")\n        except Exception as e:\n            return f\"LLM Error: {str(e)}\"\n\n    def propose_signal(self, symbol, indicators, strategies, corrections, layer=2):\n        \"\"\"\n        提出交易信號（預設走 Router Layer 2 → MiniMax）\n        layer=1: 快速但淺（ray-v1）\n        layer=2: 深度（MiniMax）\n        layer=3: 連網（MiniMax + web）\n        \"\"\"","oldText":"class LLMAdvisor:\n    \"\"\"整合 LLM 給出建議\"\"\"\n\n    def __init__(self):\n        self.model = \"ray-v1\"  # 1.5B 快速建議\n\n    def ask(self, prompt, model=\"ray-v1\"):\n        \"\"\"詢問 LLM\"\"\"\n        try:\n            import requests\n            resp = requests.post(OLLAMA_URL, json={\n                \"model\": model,\n                \"messages\": [{\"role\": \"user\", \"content\": prompt}],\n                \"stream\": False\n            }, timeout=60)\n            return resp.json().get(\"message\", {}).get(\"content\", \"\")\n        except Exception as e:\n            return f\"LLM Error: {str(e)}\"\n\n    def propose_signal(self, symbol, indicators, strategies, corrections):"}],"path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_integrated_brain.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":785,"output":964,"cacheRead":71744,"cacheWrite":0,"totalTokens":73493,"cost":{"input":0.00023549999999999998,"output":0.0011568,"cacheRead":0.004304639999999999,"cacheWrite":0,"total":0.005696939999999999}},"stopReason":"toolUse","timestamp":1778587135913,"responseId":"065249019c27e559cb9590a290109a53"}}
