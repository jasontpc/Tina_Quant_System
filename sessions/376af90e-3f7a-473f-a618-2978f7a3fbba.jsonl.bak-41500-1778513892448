 self.engine = RayEngine(market_type=\"US\", db_path=db_path)\n        self.validator = NL2CodeValidator()\n        self.learned_count   = 0\n        self.rejected_count  = 0\n\n    # ── 核心：自動學習循環（單檔）──────────────────────────────────\n    def autonomous_learning_cycle(self, symbol: str,\n                                   lookback_days: int = 730,\n                                   min_shappe: float = 1.5,\n                                   max_mdd: float = 0.15) -> Dict:\n        \"\"\"\n        對單一標的執行完整的自主學習循環\n\n        步驟：\n        1. 抓取歷史數據\n        2. 嘗試多個候選策略（網格搜索）\n        3. 每個策略經過 NL2Code + 回測把關\n        4. 最好且通過的把關策略寫入 DB\n\n        返回：{status, best_strategy, sharpe, mdd, ...}\n        \"\"\"\n        print(f\"[RayEvolution] Learning cycle for {symbol}...\")\n\n        # ── 抓數據 ───────────────────────────────────────────────\n        try:\n            df = yf.Ticker(symbol).history(period=f\"{lookback_days}d\",\n                                           interval=\"1d\", auto_adjust=True)\n            if df is None or len(df) < 200:\n                return {\"status\": \"error\", \"reason\": \"insufficient data\"}\n        except Exception as e:\n            return {\"status\": \"error\", \"reason\": str(e)}\n\n        # ── 網格候選參數（Ray 擅長的策略）──────────────────────────\n        candidates = []\n\n        # Vegas Tunnel\n        for ema_fast in [144, 169]:\n            for ema_slow in [576, 676]:\n                if ema_fast >= ema_slow: continue\n                candidates.append({\n                    \"strategy_name\": f\"VEGAS_TUNNEL_{ema_fast}_{ema_slow}\",\n                    \"indicator\": \"VEGAS_TUNNEL\",\n                    \"params\": {\"fast\": ema_fast, \"slow\": ema_slow},\n                    \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n                    \"stop_loss\": 0.08,\n                    \"max_hold_days\": 10,\n                })\n\n        # EMA Cross\n        for fast, slow in [(9, 21), (12, 26), (20, 60), (50, 200)]:\n            candidates.append({\n                \"strategy_name\": f\"EMA_CROSS_{fast}_{slow}\",\n                \"indicator\": \"EMA_CROSS\",\n                \"params\": {\"fast\": fast, \"slow\": slow},\n                \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n                \"stop_loss\": 0.08,\n                \"max_hold_days\": 15,\n            })\n\n        # Momentum\n        for window in [5, 10, 20, 60]:\n            candidates.append({\n                \"strategy_name\": f\"MOMENTUM_{window}\",\n                \"indicator\": \"MOMENTUM\",\n                \"params\": {\"window\": window},\n                \"entry_condition\": {\"operator\": \">\", \"threshold\": 0.02},\n                \"stop_loss\": 0.10,\n                \"max_hold_days\": 20,\n            })\n\n        # ── NL2Code 驗證 + 回測把關 ─────────────────────────────────\n        passed_strategies = []\n        for axiom in candidates:\n            # NL2Code 驗證\n            is_valid, parsed, errors = self.validator.validate(axiom)\n            if not is_valid:\n                continue  # 格式不合，自動跳過\n\n            # 回測把關\n            report = self.engine.run_backtest(df, axiom)\n            if report[\"passed\"]:\n                passed_strategies.append({**report, \"axiom\": axiom})\n                backtest_id = self.db.log_backtest(\n                    strategy_name = axiom[\"strategy_name\"],\n                    symbol        = symbol,\n                    indicator     = axiom[\"indicator\"],\n                    params        = axiom[\"params\"],\n                    sharpe        = report[\"sharpe\"],\n                    mdd           = report[\"mdd\"],\n                    total_ret     = report[\"total_ret\"],\n                    win_rate      = report[\"win_rate\"],\n                    avg_return    = report[\"avg_return\"],\n                    num_trades    = report[\"num_trades\"],\n                    note          = f\"auto_learned | cost={report.get('cost_pct',0.15)}%\",\n                )\n                self.db.log_wisdom(\n                    axiom_json = json.dumps(axiom),\n                    reflection = f\"SHARP={report['sharpe']:.2f} MDD={report['mdd']:.2%} WIN={report['win_rate']:.1%}\",\n                    backtest_id = backtest_id,\n                )\n\n        # ── 選最佳策略 ─────────────────────────────────────────────\n        if passed_strategies:\n            best = sorted(passed_strategies, key=lambda x: -x[\"sharpe\"])[0]\n            self.learned_count += 1\n            print(f\"[RayEvolution] ✅ {symbol}: {len(passed_strategies)} passed, best Sharpe={best['sharpe']:.2f}\")\n            return {\n                \"status\":         \"success\",\n                \"symbol\":         symbol,\n                \"best_strategy\":  best[\"axiom\"][\"strategy_name\"],\n                \"indicator\":       best[\"axiom\"][\"indicator\"],\n                \"sharpe\":         best[\"sharpe\"],\n                \"mdd\":            best[\"mdd\"],\n                \"total_ret\":      best[\"total_ret\"],\n                \"win_rate\":       best[\"win_rate\"],\n                \"num_trades\":     best[\"num_trades\"],\n                \"passed_count\":   len(passed_strategies),\n            }\n        else:\n            self.rejected_count += 1\n            # 記錄失敗\n            self.db.log_wisdom(\n                axiom_json = json.dumps({\"symbol\": symbol, \"attempted\": len(candidates)}),\n                reflection = f\"No strategy passed (tried {len(candidates)})\",\n            )\n            print(f\"[RayEvolution] ❌ {symbol}: all {len(candidates)} strategies rejected\")\n            return {\n                \"status\":   \"rejected\",\n                \"symbol\":   symbol,\n                \"attempted\": len(candidates),\n            }\n\n    # ── 批量學習（多檔）────────────────────────────────────────────\n    def batch_learning(self, symbols: List[str], lookback_days: int = 730