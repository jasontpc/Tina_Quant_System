{"type":"message","id":"c7d333a4","parentId":"aaf63285","timestamp":"2026-05-11T11:48:06.340Z","message":{"role":"toolResult","toolCallId":"call_function_qwcggzgfum1j_2","toolName":"read","content":[{"type":"text","text":"# -*- coding: utf-8 -*-\r\n\"\"\"\r\nVegas V1 Alpha Pro - Core System\r\nMulti-timeframe mean-reversion momentum system for US stocks\r\n\r\nCore components:\r\n- EMA 144/169 tunnel (hourly trigger + daily environment filter)\r\n- KDJ J-cross momentum trigger\r\n- ATR 2x dynamic stop-loss\r\n- Fib 618 structured pivot points (numpy-based local extrema)\r\n- 1000-point scoring engine\r\n\r\nNO external dependencies beyond: numpy, pandas, yfinance, ta\r\n\"\"\"\r\n\r\nimport sys\r\nimport os\r\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\r\nsys.stdout.reconfigure(encoding='utf-8')\r\n\r\nimport sqlite3\r\nimport json\r\nimport math\r\nimport warnings\r\nfrom datetime import datetime, timedelta\r\nfrom typing import Optional, Dict, List, Tuple\r\n\r\nimport numpy as np\r\nimport pandas as pd\r\nimport yfinance as yf\r\n\r\nwarnings.filterwarnings('ignore')\r\n\r\n# ===================== PATH CONFIG =====================\r\nSCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\r\n# tina_v3_core.py is at teams/vegas_v1_alpha/tina_v3_core.py\r\n# Navigate up: teams/vegas_v1_alpha -> teams -> <root>\r\nTEAM_DIR = os.path.join(SCRIPT_DIR)\r\nROOT_DIR = os.path.normpath(os.path.join(SCRIPT_DIR, '..', '..'))\r\nDB_PATH = os.path.join(ROOT_DIR, 'data', 'us_history.db')\r\nos.makedirs(TEAM_DIR, exist_ok=True)\r\n\r\n\r\n# ===================== UTILITY: numpy EMA =====================\r\ndef calc_ema(close: np.ndarray, period: int) -> np.ndarray:\r\n    \"\"\"Calculate EMA using numpy (no pandas_ta needed).\"\"\"\r\n    ema = np.zeros_like(close, dtype=float)\r\n    ema[0] = close[0]\r\n    alpha = 2.0 / (period + 1)\r\n    for i in range(1, len(close)):\r\n        ema[i] = close[i] * alpha + ema[i-1] * (1 - alpha)\r\n    return ema\r\n\r\n\r\ndef calc_rsi(close: np.ndarray, period: int = 14) -> np.ndarray:\r\n    \"\"\"Calculate RSI using ta library (already available).\"\"\"\r\n    try:\r\n        import ta\r\n        rsi = ta.momentum.RSIIndicator(close, window=period).rsi()\r\n        return rsi\r\n    except:\r\n        delta = np.diff(close, prepend=close[0])\r\n        gain = np.where(delta > 0, delta, 0.0)\r\n        loss = np.where(delta < 0, -delta, 0.0)\r\n        avg_gain = gain.copy()\r\n        avg_loss = loss.copy()\r\n        for i in range(1, len(avg_gain)):\r\n            avg_gain[i] = (avg_gain[i-1] * (period-1) + gain[i]) / period\r\n            avg_loss[i] = (avg_loss[i-1] * (period-1) + loss[i]) / period\r\n        rs = avg_gain / np.where(avg_loss == 0, 1e-10, avg_loss)\r\n        rsi = 100 - (100 / (1 + rs))\r\n        return rsi\r\n\r\n\r\ndef calc_atr(high: np.ndarray, low: np.ndarray, close: np.ndarray, period: int = 14) -> np.ndarray:\r\n    \"\"\"Calculate ATR using ta library.\"\"\"\r\n    try:\r\n        import ta\r\n        atr = ta.volatility.AverageTrueRange(high, low, close, window=period).average_true_range()\r\n        return atr\r\n    except:\r\n        tr = np.zeros(len(high), dtype=float)\r\n        prev_close = np.roll(close, 1)\r\n        prev_close[0] = close[0]\r\n        tr = np.maximum(high - low, np.maximum(np.abs(high - prev_close), np.abs(low - prev_close)))\r\n        atr = np.zeros(len(high), dtype=float)\r\n        atr[period-1] = np.mean(tr[:period])\r\n        for i in range(period, len(atr)):\r\n            atr[i] = (atr[i-1] * (period-1) + tr[i]) / period\r\n        return atr\r\n\r\n\r\ndef calc_kdj(high: np.ndarray, low: np.ndarray, close: np.ndarray,\r\n             n: int = 9, d_n: int = 3, m2: int = 3) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:\r\n    \"\"\"Calculate KDJ using ta library (StochasticOscillator).\r\n    Uses n=9 (fast K period), d_n=3 (slow D period, also J calculation param).\r\n    \"\"\"\r\n    try:\r\n        import ta\r\n        import pandas as pd\r\n        close_s = pd.Series(close)\r\n        high_s = pd.Series(high)\r\n        low_s = pd.Series(low)\r\n        kdj = ta.momentum.StochasticOscillator(high_s, low_s, close_s, n=n, d_n=d_n)\r\n        k = kdj.stoch().values\r\n        d = kdj.stoch_signal().values\r\n        j = 3 * k - 2 * d  # %J = 3*K - 2*D\r\n        return k, d, j\r\n    except Exception as e:\r\n        return np.zeros_like(close), np.zeros_like(close), np.zeros_like(close)\r\n\r\n\r\ndef find_local_extrema(close: np.ndarray, order: int = 5) -> Tuple[np.ndarray, np.ndarray]:\r\n    \"\"\"\r\n    Find local maxima and minima using numpy (scipy-free equivalent of scipy.signal.argrelextrema).\r\n    Returns boolean arrays of same length as close.\r\n    \"\"\"\r\n    close = np.asarray(close, dtype=float)\r\n    n = len(close)\r\n    maxima = np.zeros(n, dtype=bool)\r\n    minima = np.zeros(n, dtype=bool)\r\n    \r\n    for i in range(order, n - order):\r\n        window = close[i-order:i+order+1]\r\n        if close[i] == np.max(window):\r\n            maxima[i] = True\r\n        if close[i] == np.min(window):\r\n            minima[i] = True\r\n    \r\n    return maxima, minima\r\n\r\n\r\ndef find_fib618_pivots(close: np.ndarray, order: int = 5) -> Tuple[Optional[float], Optional[float]]:\r\n    \"\"\"\r\n    Find Fib 618 pivot points from weekly data.\r\n    Returns (support_price, resistance_price) based on recent swing low/high near 61.8% retracement.\r\n    \"\"\"\r\n    maxima, minima = find_local_extrema(close, order=order)\r\n    if not np.any(maxima) or not np.any(minima):\r\n        return None, None\r\n    \r\n    highs_idx = np.where(maxima)[0]\r\n    lows_idx = np.where(minima)[0]\r\n    if len(highs_idx) < 2 or len(lows_idx) < 2:\r\n        return None, None\r\n    \r\n    recent_highs = close[highs_idx[-5:]] if len(highs_idx) >= 5 else close[highs_idx]\r\n    recent_lows = close[lows_idx[-5:]] if len(lows_idx) >= 5 else close[lows_idx]\r\n    \r\n    swing_high = np.max(recent_highs)\r\n    swing_low = np.min(recent_lows)\r\n    \r\n    # Fib 618 retracement levels\r\n    range_val = swing_high - swing_low\r\n    fib618_support = swing_high - range_val * 0.618\r\n    fib618_resistance = swing_low + range_val * 0.618\r\n    \r\n    return float(fib618_support), float(fib618_resistance)\r\n\r\n\r\n# ===================== DATA FETCH =====================\r\ndef fetch_weekly_data(symbol: str, period: str = '6mo') -> pd.DataFrame:\r\n    \"\"\"Fetch weekly OHLCV for structure analysis.\"\"\"\r\n    try:\r\n        ticker = yf.Ticker(symbol)\r\n        df = ticker.history(period=period, interval='1wk', auto_adjust=True)\r\n        if df is None or len(df) < 20:\r\n            return pd.DataFrame()\r\n        df.columns = [c.title() for c in df.columns]\r\n        return df\r\n    except:\r\n        return pd.DataFrame()\r\n\r\n\r\ndef fetch_daily_data(symbol: str, period: str = '3mo') -> pd.DataFrame:\r\n    \"\"\"Fetch daily OHLCV for environment filter.\"\"\"\r\n    try:\r\n        ticker = yf.Ticker(symbol)\r\n        df = ticker.history(period=period, interval='1d', auto_adjust=True)\r\n        if df is None or len(df) < 30:\r\n            return pd.DataFrame()\r\n        df.columns = [c.title() for c in df.columns]\r\n        return df\r\n    except:\r\n        return pd.DataFrame()\r\n\r\n\r\ndef fetch_hourly_data(symbol: str, period: str = '5d') -> pd.DataFrame:\r\n    \"\"\"Fetch hourly OHLCV for trigger layer.\"\"\"\r\n    try:\r\n        ticker = yf.Ticker(symbol)\r\n        df = ticker.history(period=period, interval='1h', auto_adjust=True)\r\n        if df is None or len(df) < 20:\r\n            return pd.DataFrame()\r\n        df.columns = [c.title() for c in df.columns]\r\n        return df\r\n    except:\r\n        return pd.DataFrame()\r\n\r\n\r\ndef load_symbols_from_db() -> List[str]:\r\n    \"\"\"Load all US stock symbols from local DB.\"\"\"\r\n    conn = sqlite3.connect(DB_PATH)\r\n    cur = conn.cursor()\r\n    cur.execute('SELECT DISTINCT symbol FROM daily_ohlcv ORDER BY symbol')\r\n    symbols = [r[0] for r in cur.fetchall()]\r\n    conn.close()\r\n    return symbols\r\n\r\n\r\n# ===================== INDICATORS =====================\r\ndef calculate_daily_indicators(df: pd.DataFrame) -> Dict:\r\n    \"\"\"Calculate daily indicators: EMA144, EMA169, RSI, ATR.\"\"\"\r\n    if len(df) < 170:\r\n        return {}\r\n    close = df['Close'].values.astype(float)\r\n    high = df['High'].values.astype(float)\r\n    low = df['Low'].values.astype(float)\r\n    \r\n    ema144 = calc_ema(close, 144)\r\n    ema169 = calc_ema(close, 169)\r\n    rsi = calc_rsi(close, 14)\r\n    atr = calc_atr(high, low, close, 14)\r\n    atr_pct = atr / close * 100\r\n    \r\n    return {\r\n        'close': close,\r\n        'high': high,\r\n        'low': low,\r\n        'ema144': ema144,\r\n        'ema169': ema169,\r\n        'rsi': rsi,\r\n        'atr': atr,\r\n        'atr_pct': atr_pct,\r\n        'dates': df.index.tolist()\r\n    }\r\n\r\n\r\ndef calculate_hourly_indicators(df: pd.DataFrame) -> Dict:\r\n    \"\"\"Calculate hourly indicators: EMA144, EMA169, KDJ J-cross.\"\"\"\r\n    if len(df) < 170:\r\n        return {}\r\n    close = df['Close'].values.astype(float)\r\n    high = df['High'].values.astype(float)\r\n    low = df['Low'].values.astype(float)\r\n    \r\n    ema144 = calc_ema(close, 144)\r\n    ema169 = calc_ema(close, 169)\r\n    k, d, j = calc_kdj(high, low, close, 9, 3, 3)\r\n    \r\n    return {\r\n        'close': close,\r\n        'high': high,\r\n        'low': low,\r\n        'ema144': ema144,\r\n        'ema169': ema169,\r\n        'k': k,\r\n        'd': d,\r\n        'j': j,\r\n        'dates': df.index.tolist()\r\n    }\r\n\r\n\r\ndef calculate_weekly_structure(df: pd.DataFrame) -> Dict:\r\n    \"\"\"Calculate weekly Fib 618 structure.\"\"\"\r\n    if len(df) < 30:\r\n        return {}\r\n    close = df['Close'].values.astype(float)\r\n    support, resistance = find_fib618_pivots(close, order=5)\r\n    return {\r\n        'close': close,\r\n        'fib618_support': support,\r\n        'fib618_resistance': resistance,\r\n        'dates': df.index.tolist()\r\n    }\r\n\r\n\r\n# ===================== SIGNAL GENERATION =====================\r\ndef generate_entry_signal(symbol: str, verbose: bool = False) -> Optional[Dict]:\r\n    \"\"\"\r\n    Generate entry signal for a symbol using multi-timeframe analysis.\r\n    Returns signal dict or None if no signal.\r\n    \"\"\"\r\n    daily = fetch_daily_data(symbol, '3mo')\r\n    hourly = fetch_hourly_data(symbol, '5d')\r\n    weekly = fetch_weekly_data(symbol, '6mo')\r\n    \r\n    if daily.empty or hourly.empty:\r\n        return None\r\n    \r\n    d_ind = calculate_daily_indicators(daily)\r\n    h_ind = calculate_hourly_indicators(hourly)\r\n    w_str = calculate_weekly_structure(weekly)\r\n    \r\n    if not d_ind or not h_ind:\r\n        return None\r\n    \r\n    # === DAILY ENVIRONMENT FILTER ===\r\n    d_close = d_ind['close']\r\n    d_ema144 = d_ind['ema144']\r\n    d_ema169 = d_ind['ema169']\r\n    d_rsi = d_ind['rsi']\r\n    d_atr_pct = d_ind['atr_pct']\r\n    \r\n    n = len(d_close)\r\n    d_env_ok = (d_ema144[n-1] > d_ema169[n-1]) and (d_close[n-1] > d_ema144[n-1])\r\n    \r\n    # === HOURLY TRIGGER ===\r\n    h_close = h_ind['close']\r\n    h_ema144 = h_ind['ema144']\r\n    h_ema169 = h_ind['ema169']\r\n    h_j = h_ind['j']\r\n    h_k = h_ind['k']\r\n    h_d = h_ind['d']\r\n    \r\n    h_n = len(h_close)\r\n    \r\n    # Check EMA144 cross above EMA169 in last 4 bars\r\n    ema_cross_bull = False\r\n    for i in range(max(0, h_n-5), h_n):\r\n        if i >= 1:\r\n            if h_ema144[i] > h_ema169[i] and h_ema144[i-1] <= h_ema169[i-1]:\r\n                ema_cross_bull = True\r\n                break\r\n    \r\n    # Check KDJ J-cross above K and D\r\n    kdj_bull = False\r\n    for i in range(max(0, h_n-4), h_n):\r\n        if i >= 1:\r\n            if h_j[i] > h_k[i] and h_j[i] > h_d[i] and h_j[i-1] <= h_k[i-1]:\r\n                kdj_bull = True\r\n                break\r\n    \r\n    # === FIB 618 STRUCTURE ===\r\n    fib_ok = False\r\n    current_price = d_close[n-1]\r\n    if w_str.get('fib618_support'):\r\n        support = w_str['fib618_support']\r\n        if support and abs(current_price - support) / support < 0.05:\r\n            fib_ok = True\r\n    \r\n    # === ENTRY CONDITIONS (all must be true) ===\r\n    if not (d_env_ok and ema_cross_bull and kdj_bull):\r\n        return None\r\n    \r\n    if d_rsi[n-1] > 70:\r\n        return None  # overbought\r\n    \r\n    # Calculate entry score\r\n    score = score_stock(symbol, d_ind, h_ind, w_str)\r\n    \r\n    entry = {\r\n        'symbol': symbol,\r\n        'entry_price': float(current_price),\r\n        'atr': float(d_ind['atr'][n-1]),\r\n        'atr_pct': float(d_atr_pct[n-1]),\r\n        'daily_rsi': float(d_rsi[n-1]),\r\n        'daily_ema144': float(d_ema144[n-1]),\r\n        'daily_ema169': float(d_ema169[n-1]),\r\n        'ema_cross': ema_cross_bull,\r\n        'kdj_cross': kdj_bull,\r\n        'fib618_ok': fib_ok,\r\n        'score': score,\r\n        'stop_loss': float(current_price - 3 * d_ind['atr'][n-1]),\r\n        'target': float(current_price + 2 * d_ind['atr'][n-1]),\r\n    }\r\n    \r\n    if verbose:\r\n        print(f\"  [{symbol}] Signal: price={current_price:.2f}, RSI={d_rsi[n-1]:.1f}, \"\r\n              f\"EMA_cross={ema_cross_bull}, KDJ_cross={kdj_bull}, score={score}\")\r\n    \r\n    return entry\r\n\r\n\r\n# ===================== SCORING ENGINE =====================\r\ndef score_stock(symbol: str, d_ind: Dict, h_ind: Dict, w_str: Dict) -> int:\r\n    \"\"\"\r\n    1000-point scoring system.\r\n    Returns score 0-1000.\r\n    \"\"\"\r\n    score = 0\r\n    n = len(d_ind['close'])\r\n    \r\n    # === MOMENTUM SCORE (0-300) ===\r\n    close = d_ind['close']\r\n    \r\n    # 1-month momentum (% change over 21 trading days)\r\n    lookback_1m = min(21, n-1)\r\n    momentum_1m = (close[n-1] / close[n-1-lookback_1m] - 1) * 100 if n > lookback_1m else 0\r\n    \r\n    # 1-week momentum (% change over 5 trading days)\r\n    lookback_1w = min(5, n-1)\r\n    momentum_1w = (close[n-1] / close[n-1-lookback_1w] - 1) * 100 if n > lookback_1w else 0\r\n    \r\n    # Volume ratio (current volume / 20-day average) - requires volume column\r\n    # Skipping volume scoring for simplicity (would need volume data)\r\n    \r\n    # Score: 1-month momentum\r\n    if momentum_1m >= 10: mom_1m_score = 120\r\n    elif momentum_1m >= 5: mom_1m_score = 90\r\n    elif momentum_1m >= 2: mom_1m_score = 60\r\n    elif momentum_1m >= 0: mom_1m_score = 30\r\n    else: mom_1m_score = 0\r\n    \r\n    # Score: 1-week momentum\r\n    if momentum_1w >= 5: mom_1w_score = 100\r\n    elif momentum_1w >= 2: mom_1w_score = 70\r\n    elif momentum_1w >= 0: mom_1w_score = 40\r\n    else: mom_1w_score = 10\r\n    \r\n    momentum_score = mom_1m_score + mom_1w_score  # max 220, but cap at 300\r\n    \r\n    # === TREND STRENGTH (0-200) ===\r\n    d_ema144 = d_ind['ema144']\r\n    d_ema169 = d_ind['ema169']\r\n    d_close = d_ind['close']\r\n    \r\n    # Daily EMA alignment (0-120)\r\n    if d_ema144[n-1] > d_ema169[n-1]:\r\n        ema_alignment_score = 60\r\n    else:\r\n        ema_alignment_score = 0\r\n    \r\n    # Price above EMA144 (0-60)\r\n    if d_close[n-1] > d_ema144[n-1]:\r\n        price_above_ema = 30\r\n    else:\r\n        price_above_ema = 0\r\n    \r\n    # === ATR VOLATILITY SCORE (0-200) ===\r\n    atr_pct = d_ind['atr_pct']\r\n    current_atr_pct = atr_pct[n-1] if not np.isnan(atr_pct[n-1]) else 1.0\r\n    \r\n    if 0.5 <= current_atr_pct <= 2.0:\r\n        atr_score = 200\r\n    elif 0.3 <= current_atr_pct < 0.5:\r\n        atr_score = 150\r\n    elif 2.0 < current_atr_pct <= 3.5:\r\n        atr_score = 120\r\n    elif current_atr_pct < 0.3:\r\n        atr_score = 80\r\n    else:\r\n        atr_score = 60\r\n    \r\n    # === INSTITUTIONAL FLOW (0-150) ===\r\n    # TODO: Integrate T86 data when available\r\n    inst_score_val = 75  # Neutral score when no data\r\n    \r\n    # === STRUCTURE SCORE (0-150) ===\r\n    current_price = d_close[n-1]\r\n    struct_score = 0\r\n    \r\n    if w_str.get('fib618_support'):\r\n        support = w_str['fib618_support']\r\n        if support:\r\n            # Within 3% of Fib 618 support\r\n            if abs(current_price - support) / support < 0.03:\r\n                struct_score += 80\r\n            elif abs(current_price - support) / support < 0.05:\r\n                struct_score += 40\r\n    \r\n    # Pivot quality (local extrema strength)\r\n    maxima, minima = find_local_extrema(d_close, order=5)\r\n    n_maxima = np.sum(maxima)\r\n    n_minima = np.sum(minima)\r\n    if n_maxima >= 3 and n_minima >= 3:\r\n        struct_score += 70\r\n    elif n_maxima >= 2 and n_minima >= 2:\r\n        struct_score += 35\r\n    \r\n    total = min(1000, momentum_score + ema_alignment_score + price_above_ema + atr_score + inst_score_val + struct_score)\r\n    \r\n    return int(total)\r\n\r\n\r\n# ===================== UNIVERSE SCAN =====================\r[... 14188 more characters truncated]"}],"isError":false,"timestamp":1778500086339}}
{"type":"message","id":"243a6616","parentId":"c7d333a4","timestamp":"2026-05-11T11:48:06.341Z","message":{"role":"toolResult","toolCallId":"call_function_qwcggzgfum1j_3","toolName":"read","content":[{"type":"text","text":"# -*- coding: utf-8 -*-\n\"\"\"\nTina V3 Alpha Pro - Scoring Engine\n1000-point multi-factor scoring system for US stocks\n\nComponent scores:\n- Momentum Score (0-300): 1-month momentum, 1-week momentum\n- Trend Strength (0-200): EMA alignment, price position\n- ATR Volatility-Adjusted Score (0-200): Position sizing hint\n- Institutional Flow (0-150): T86 data integration\n- Structure Score (0-150): Fib 618 proximity, pivot quality\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nfrom typing import Dict, Tuple, Optional, List\n\n\n# ===================== SCORE COMPONENT WEIGHTS =====================\nDEFAULT_WEIGHTS = {\n    'momentum_w': 0.30,\n    'trend_w': 0.25,\n    'atr_w': 0.20,\n    'inst_w': 0.10,\n    'struct_w': 0.15,\n}\n\n\n# ===================== MOMENTUM SCORE (0-300) =====================\ndef calc_momentum_score(close: np.ndarray, n: int) -> Tuple[int, Dict]:\n    lookback_1m = min(21, n-1)\n    lookback_1w = min(5, n-1)\n    \n    momentum_1m = (close[n-1] / close[n-1-lookback_1m] - 1) * 100 if n > lookback_1m else 0\n    momentum_1w = (close[n-1] / close[n-1-lookback_1w] - 1) * 100 if n > lookback_1w else 0\n    \n    if momentum_1m >= 15: mom_1m_score = 120\n    elif momentum_1m >= 10: mom_1m_score = 100\n    elif momentum_1m >= 7: mom_1m_score = 80\n    elif momentum_1m >= 5: mom_1m_score = 60\n    elif momentum_1m >= 3: mom_1m_score = 40\n    elif momentum_1m >= 1: mom_1m_score = 20\n    else: mom_1m_score = 0\n    \n    if momentum_1w >= 8: mom_1w_score = 100\n    elif momentum_1w >= 5: mom_1w_score = 80\n    elif momentum_1w >= 3: mom_1w_score = 60\n    elif momentum_1w >= 2: mom_1w_score = 40\n    elif momentum_1w >= 0: mom_1w_score = 20\n    else: mom_1w_score = 0\n    \n    lookback_3m = min(63, n-1)\n    momentum_3m = (close[n-1] / close[n-1-lookback_3m] - 1) * 100 if n > lookback_3m else 0\n    if momentum_3m >= 20: mom_3m_score = 80\n    elif momentum_3m >= 15: mom_3m_score = 60\n    elif momentum_3m >= 10: mom_3m_score = 40\n    elif momentum_3m >= 5: mom_3m_score = 20\n    else: mom_3m_score = 0\n    \n    total = min(300, mom_1m_score + mom_1w_score + mom_3m_score)\n    \n    return total, {\n        'mom_1m': momentum_1m, 'mom_1m_score': mom_1m_score,\n        'mom_1w': momentum_1w, 'mom_1w_score': mom_1w_score,\n        'mom_3m': momentum_3m, 'mom_3m_score': mom_3m_score,\n    }\n\n\n# ===================== TREND STRENGTH (0-200) =====================\ndef calc_trend_score(close: np.ndarray, ema144: np.ndarray, ema169: np.ndarray, n: int) -> Tuple[int, Dict]:\n    score = 0\n    subs = {}\n    \n    if ema144[n-1] > ema169[n-1]:\n        score += 60\n        subs['ema_aligned'] = True\n    else:\n        score += 0\n        subs['ema_aligned'] = False\n    \n    if close[n-1] > ema144[n-1]:\n        score += 40\n        subs['price_above_ema144'] = True\n    else:\n        score += 0\n        subs['price_above_ema144'] = False\n    \n    if close[n-1] > ema169[n-1]:\n        score += 30\n        subs['price_above_ema169'] = True\n    else:\n        score += 0\n        subs['price_above_ema169'] = False\n    \n    if n >= 6:\n        slope = (ema144[n-1] - ema144[n-6]) / 5\n        slope_pct = slope / ema144[n-6] * 100 if ema144[n-6] > 0 else 0\n        if slope_pct >= 0.5: score += 30\n        elif slope_pct >= 0.2: score += 20\n        elif slope_pct >= 0: score += 10\n        subs['ema_slope_pct'] = slope_pct\n    else:\n        subs['ema_slope_pct'] = 0\n    \n    deviation = abs(close[n-1] - ema144[n-1]) / ema144[n-1] * 100\n    if deviation <= 5: score += 40\n    elif deviation <= 10: score += 20\n    subs['ema_deviation_pct'] = deviation\n    \n    total = min(200, score)\n    return total, subs\n\n\n# ===================== ATR VOLATILITY SCORE (0-200) =====================\ndef calc_atr_score(atr_pct: np.ndarray, n: int) -> Tuple[int, Dict]:\n    current_atr_pct = atr_pct[n-1] if not np.isnan(atr_pct[n-1]) and atr_pct[n-1] > 0 else 1.0\n    \n    if 0.5 <= current_atr_pct <= 2.5:\n        atr_score = 200\n    elif 0.3 <= current_atr_pct < 0.5:\n        atr_score = 150\n    elif 2.5 < current_atr_pct <= 4.0:\n        atr_score = 120\n    elif current_atr_pct < 0.3:\n        atr_score = 80\n    else:\n        atr_score = 60\n    \n    if n >= 14:\n        atr_trend = atr_pct[n-1] / np.nanmean(atr_pct[n-14:n-1]) if np.nanmean(atr_pct[n-14:n-1]) > 0 else 1.0\n    else:\n        atr_trend = 1.0\n    \n    subs = {\n        'atr_pct': current_atr_pct,\n        'atr_trend': atr_trend,\n        'atr_regime': 'high' if current_atr_pct > 3 else ('low' if current_atr_pct < 0.5 else 'normal')\n    }\n    \n    return atr_score, subs\n\n\n# ===================== INSTITUTIONAL FLOW SCORE (0-150) =====================\ndef calc_institutional_score(inst_foreign: float, inst_trust: float) -> Tuple[int, Dict]:\n    if inst_foreign > 5000:\n        foreign_score = 75\n    elif inst_foreign > 2000:\n        foreign_score = 60\n    elif inst_foreign > 1000:\n        foreign_score = 45\n    elif inst_foreign > 0:\n        foreign_score = 30\n    elif inst_foreign > -1000:\n        foreign_score = 15\n    else:\n        foreign_score = 0\n    \n    if inst_trust > 3000:\n        trust_score = 75\n    elif inst_trust > 1000:\n        trust_score = 60\n    elif inst_trust > 500:\n        trust_score = 45\n    elif inst_trust > 0:\n        trust_score = 30\n    elif inst_trust > -500:\n        trust_score = 15\n    else:\n        trust_score = 0\n    \n    total = min(150, foreign_score + trust_score)\n    \n    return total, {\n        'foreign_net': inst_foreign, 'foreign_score': foreign_score,\n        'trust_net': inst_trust, 'trust_score': trust_score,\n    }\n\n\n# ===================== STRUCTURE SCORE (0-150) =====================\ndef _find_local_extrema(c: np.ndarray, order: int = 5) -> Tuple[np.ndarray, np.ndarray]:\n    \"\"\"Internal: find local maxima/minima using numpy.\"\"\"\n    n = len(c)\n    maxima = np.zeros(n, dtype=bool)\n    minima = np.zeros(n, dtype=bool)\n    for i in range(order, n - order):\n        window = c[i-order:i+order+1]\n        if c[i] == np.max(window):\n            maxima[i] = True\n        if c[i] == np.min(window):\n            minima[i] = True\n    return maxima, minima\n\n\ndef calc_structure_score(close: np.ndarray, fib618_support: Optional[float],\n                         fib618_resistance: Optional[float], n: int) -> Tuple[int, Dict]:\n    score = 0\n    current_price = close[n-1]\n    subs = {}\n    \n    if fib618_support:\n        deviation = abs(current_price - fib618_support) / fib618_support\n        if deviation < 0.02:\n            score += 80\n            subs['fib618_zone'] = 'tight'\n        elif deviation < 0.03:\n            score += 60\n            subs['fib618_zone'] = 'near'\n        elif deviation < 0.05:\n            score += 40\n            subs['fib618_zone'] = 'approaching'\n        else:\n            subs['fib618_zone'] = 'far'\n    else:\n        subs['fib618_zone'] = 'no_data'\n    \n    if fib618_resistance:\n        deviation_r = abs(current_price - fib618_resistance) / fib618_resistance\n        if deviation_r < 0.03:\n            score += 20\n        elif deviation_r < 0.05:\n            score += 10\n        subs['resistance_zone'] = 'near' if deviation_r < 0.05 else 'far'\n    else:\n        subs['resistance_zone'] = 'no_data'\n    \n    maxima, minima = _find_local_extrema(close, order=5)\n    n_maxima = int(np.sum(maxima))\n    n_minima = int(np.sum(minima))\n    \n    if n_maxima >= 4 and n_minima >= 4:\n        score += 30\n        subs['pivot_quality'] = 'high'\n    elif n_maxima >= 3 and n_minima >= 3:\n        score += 20\n        subs['pivot_quality'] = 'medium'\n    elif n_maxima >= 2 and n_minima >= 2:\n        score += 10\n        subs['pivot_quality'] = 'low'\n    else:\n        subs['pivot_quality'] = 'poor'\n    \n    total = min(150, score)\n    return total, subs\n\n\n# ===================== MAIN SCORING =====================\ndef score_stock_full(d_ind: Dict, h_ind: Dict, w_str: Dict,\n                     inst_foreign: float = 0, inst_trust: float = 0,\n                     weights: Dict = None) -> Dict:\n    if weights is None:\n        weights = DEFAULT_WEIGHTS.copy()\n    \n    n = len(d_ind['close'])\n    \n    mom_score, mom_subs = calc_momentum_score(d_ind['close'], n)\n    trend_score, trend_subs = calc_trend_score(d_ind['close'], d_ind['ema144'], d_ind['ema169'], n)\n    atr_score, atr_subs = calc_atr_score(d_ind['atr_pct'], n)\n    inst_score, inst_subs = calc_institutional_score(inst_foreign, inst_trust)\n    struct_score, struct_subs = calc_structure_score(\n        d_ind['close'], w_str.get('fib618_support'), w_str.get('fib618_resistance'), n)\n    \n    raw_total = mom_score + trend_score + atr_score + inst_score + struct_score\n    \n    result = {\n        'total_score': min(1000, raw_total),\n        'momentum_score': mom_score,\n        'trend_score': trend_score,\n        'atr_score': atr_score,\n        'institutional_score': inst_score,\n        'structure_score': struct_score,\n        'sub_components': {\n            'momentum': mom_subs,\n            'trend': trend_subs,\n            'atr': atr_subs,\n            'institutional': inst_subs,\n            'structure': struct_subs,\n        }\n    }\n    \n    score = result['total_score']\n    if score >= 700:\n        result['signal'] = 'APPROVE'\n        result['position_size'] = '5%'\n    elif score >= 500:\n        result['signal'] = 'CAUTION'\n        result['position_size'] = '2.5%'\n    else:\n        result['signal'] = 'REJECT'\n        result['position_size'] = '0%'\n    \n    return result\n\n\n# ===================== CALIBRATION REPORT =====================\ndef generate_calibration_report(trades: List[Dict], weights: Dict) -> str:\n    if not trades:\n        return \"No trades for calibration.\"\n    \n    df = pd.DataFrame(trades)\n    wr = len(df[df['profit_pct'] > 0]) / len(df) * 100\n    avg = df['profit_pct'].mean()\n    \n    report_lines = [\n        \"=\" * 60,\n        \"TINA V3 ALPHA - SCORE CALIBRATION REPORT\",\n        \"=\" * 60,\n        f\"Weight Configuration:\",\n        f\"  Momentum:     {weights['momentum_w']*100:.0f}%\",\n        f\"  Trend:        {weights['trend_w']*100:.0f}%\",\n        f\"  ATR:          {weights['atr_w']*100:.0f}%\",\n        f\"  Institutional: {weights['inst_w']*100:.0f}%\",\n        f\"  Structure:   {weights['struct_w']*100:.0f}%\",\n        \"\",\n        f\"Backtest Results:\",\n        f\"  Win Rate:    {wr:.1f}%\",\n        f\"  Avg Return: {avg:.2f}%\",\n        f\"  Total Trades: {len(df)}\",\n        \"=\" * 60,\n    ]\n    \n    return \"\\n\".join(report_lines)\n"}],"isError":false,"timestamp":1778500086340}}
