ired\", []):\n            if field not in axiom:\n                self.errors.append(f\"Missing required field: {field}\")\n\n        # ── Step 3：檢查 strategy_name 格式 ──────────────────────\n        name = axiom.get(\"strategy_name\", \"\")\n        if not re.match(r\"^[A-Z][A-Z0-9_]{2,30}$\", name):\n            self.errors.append(f\"Invalid strategy_name '{name}': must be UPPER_SNAKE_CASE 3-30 chars\")\n\n        # ── Step 4：檢查 indicator 合法值 ────────────────────────\n        valid_indicators = AXIOM_SCHEMA[\"properties\"][\"indicator\"][\"enum\"]\n        ind = axiom.get(\"indicator\")\n        if ind and ind not in valid_indicators:\n            self.errors.append(f\"Unknown indicator '{ind}': must be one of {valid_indicators}\")\n\n        # ── Step 5：檢查 params 範圍 ─────────────────────────────\n        params = axiom.get(\"params\", {})\n        param_specs = AXIOM_SCHEMA[\"properties\"][\"params\"][\"properties\"]\n        for key, spec in param_specs.items():\n            if key in params:\n                val = params[key]\n                if spec[\"type\"] == \"integer\":\n                    if not isinstance(val, int):\n                        self.errors.append(f\"params.{key} must be int, got {type(val).__name__}\")\n                    elif \"minimum\" in spec and val < spec[\"minimum\"]:\n                        self.errors.append(f\"params.{key}={val} < minimum {spec['minimum']}\")\n                    elif \"maximum\" in spec and val > spec[\"maximum\"]:\n                        self.errors.append(f\"params.{key}={val} > maximum {spec['maximum']}\")\n\n        # ── Step 6：檢查 entry_condition ──────────────────────────\n        ec = axiom.get(\"entry_condition\", {})\n        for field in [\"operator\", \"threshold\"]:\n            if field not in ec:\n                self.errors.append(f\"entry_condition missing '{field}'\")\n\n        # ── Step 7：檢查 stop_loss / target 範圍 ─────────────────\n        if \"stop_loss\" in axiom:\n            sl = axiom[\"s