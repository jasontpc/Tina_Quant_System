{"type":"message","id":"aaf63285","parentId":"a51261c0","timestamp":"2026-05-11T11:48:06.340Z","message":{"role":"toolResult","toolCallId":"call_function_qwcggzgfum1j_1","toolName":"read","content":[{"type":"text","text":"# -*- coding: utf-8 -*-\n\"\"\"\nVegas V1 Alpha - 完整四階段交易引擎\nStep 1 日線環境 → Step 2 結構定位 → Step 3 精確觸發 → Step 4 動態風控\n\n對齊 Spec 要點：\n- Step 1: 日線隧道 + 斜率確認（EMA144 now > 5d ago）\n- Step 2: Fib 0.618 與小時隧道 EMA144/169 共振區（±0.5% 容差）\n- Step 3: J 線低位(<20)勾頭 + EMA12 站上 + MACD 柱狀體收縮\n- Step 4: ATR 2.0x 止損 / Fib 1.618 擴展目標 / 1.272 移動保本\n\nATR Stop 倍率說明：已從 3.0 改為 2.0（回測 2.0x 全部止損虧損，3.0x 止損頻率降低但延長持有，\n                          本系統以 EMA 169 作為底層支撐，2.0x 止損較為合理）\n\"\"\"\n\nimport sys\nimport os\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\nsys.stdout.reconfigure(encoding='utf-8')\n\nimport time\nimport json\nimport warnings\nfrom datetime import datetime\nfrom typing import Optional, Dict, Tuple\n\nimport numpy as np\nimport pandas as pd\nimport yfinance as yf\nimport requests\n\nwarnings.filterwarnings('ignore')\n\n# ===================== 設定區 =====================\nUNIVERSE = {\n    \"SP500\": [\"SPY\",\"IVV\",\"VOO\",\"VV\",\"SPEU\",\"EFA\",\"EEM\",\"AGG\",\"IEF\",\"TLT\",\"GLD\",\"SLV\",\"USO\",\"CPER\",\"DBA\",\"XLE\",\"XLF\",\"XLU\",\"XLI\",\"XLK\",\"XLV\",\"XLY\",\"XLP\",\"XLRE\",\"XLC\"],\n    \"NASDAQ100\": [\"QQQ\",\"QQQM\",\"TQQQ\",\"SQQQ\",\"QLD\",\"QID\",\"QLQD\",\"VGT\",\"ARKK\",\"ARKQ\",\"ARKW\",\"SOXX\",\"SMH\",\"SOXL\",\"SOXS\",\"CWEB\",\"DRN\",\"FINX\",\"EFIX\",\"XITK\"],\n    \"SOX30\": [\"AMAT\",\"LRCX\",\"MU\",\"NVDA\",\"ASML\",\"KLAC\",\"TSM\",\"INTC\",\"AMD\",\"QCOM\",\"AVGO\",\"MRVL\",\"MPWR\",\"ON\",\"MCHP\",\"TER\",\"ADI\",\"SWKS\",\"QRVO\",\"CRUS\",\"LSCC\",\"ENTG\",\"ALTR\"],\n}\n\nSYMBOLS = []\nfor _n, _l in UNIVERSE.items():\n    SYMBOLS.extend(_l)\nSYMBOLS = list(dict.fromkeys(SYMBOLS))  # 去重\n\nINTERVAL = \"1h\"\nDAILY_INTERVAL = \"1d\"\nATR_STOP = 2.0          # Spec ATR 2.0x（止損）\nATR_WARNING = 1.5       # ATR 1.5x（預警）\nMAX_HOLD_DAYS = 10\nVIX_MAX = 25\nFIB_ZONE_TOLERANCE = 0.005  # 0.5% 容差\nCONFLOW_TOLERANCE = 0.005   # 共振區容差\n\n\n# ===================== 工具函數 =====================\n\ndef calc_ema(close: np.ndarray, period: int) -> np.ndarray:\n    ema = np.zeros_like(close, dtype=float)\n    ema[0] = close[0]\n    alpha = 2.0 / (period + 1)\n    for i in range(1, len(close)):\n        ema[i] = close[i] * alpha + ema[i - 1] * (1 - alpha)\n    return ema\n\n\ndef calc_atr(high: np.ndarray, low: np.ndarray, close: np.ndarray, period: int = 14) -> np.ndarray:\n    tr = np.zeros(len(high), dtype=float)\n    prev_close = np.roll(close, 1)\n    prev_close[0] = close[0]\n    tr = np.maximum(high - low, np.maximum(np.abs(high - prev_close), np.abs(low - prev_close)))\n    atr = np.zeros(len(high), dtype=float)\n    atr[period - 1] = np.mean(tr[:period])\n    for i in range(period, len(atr)):\n        atr[i] = (atr[i - 1] * (period - 1) + tr[i]) / period\n    return atr\n\n\ndef calc_macd(close: np.ndarray, fast: int = 12, slow: int = 26, signal: int = 9) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:\n    \"\"\"MACD: 標準 MACD Line / Signal Line / Histogram（柱狀體）\"\"\"\n    ema_fast = calc_ema(close, fast)\n    ema_slow = calc_ema(close, slow)\n    macd_line = ema_fast - ema_slow\n    signal_line = calc_ema(macd_line, signal)\n    histogram = macd_line - signal_line\n    return macd_line, signal_line, histogram\n\n\ndef calc_rsi(close: np.ndarray, period: int = 14) -> np.ndarray:\n    delta = np.diff(close, prepend=close[0])\n    gain = np.where(delta > 0, delta, 0.0)\n    loss = np.where(delta < 0, -delta, 0.0)\n    avg_gain = gain.copy()\n    avg_loss = loss.copy()\n    for i in range(1, len(avg_gain)):\n        avg_gain[i] = (avg_gain[i - 1] * (period - 1) + gain[i]) / period\n        avg_loss[i] = (avg_loss[i - 1] * (period - 1) + loss[i]) / period\n    rs = avg_gain / np.where(avg_loss == 0, 1e-10, avg_loss)\n    return 100 - (100 / (1 + rs))\n\n\ndef find_local_extrema(close: np.ndarray, order: int = 5) -> Tuple[np.ndarray, np.ndarray]:\n    close = np.asarray(close, dtype=float)\n    n = len(close)\n    maxima = np.zeros(n, dtype=bool)\n    minima = np.zeros(n, dtype=bool)\n    for i in range(order, n - order):\n        window = close[i - order:i + order + 1]\n        if close[i] == np.max(window):\n            maxima[i] = True\n        if close[i] == np.min(window):\n            minima[i] = True\n    return maxima, minima\n\n\n# ===================== 資料獲取 =====================\ndef fetch_hourly_data(symbol: str, period: str = \"30d\") -> pd.DataFrame:\n    try:\n        df = yf.Ticker(symbol).history(period=period, interval=INTERVAL, auto_adjust=True)\n        if df is None or len(df) < 144:\n            print(f\"[警告] {symbol} 1h 資料不足（{len(df) if df is not None else 0} 筆）\")\n        df.columns = [c.title() for c in df.columns]\n        return df\n    except Exception as e:\n        print(f\"[抓取 1h 失敗] {e}\")\n        return pd.DataFrame()\n\n\ndef fetch_daily_data(symbol: str, period: str = \"2y\") -> pd.DataFrame:\n    try:\n        df = yf.Ticker(symbol).history(period=period, interval=DAILY_INTERVAL, auto_adjust=True)\n        if df is None or len(df) < 170:\n            print(f\"[警告] {symbol} 日線資料不足（{len(df) if df is not None else 0} 筆）\")\n        df.columns = [c.title() for c in df.columns]\n        return df\n    except Exception as e:\n        print(f\"[抓取日線失敗] {e}\")\n        return pd.DataFrame()\n\n\ndef fetch_vix() -> float:\n    try:\n        df = yf.Ticker(\"^VIX\").history(period=\"5d\", interval=\"1d\")\n        return float(df['Close'].iloc[-1]) if df is not None and not df.empty else 20.0\n    except:\n        return 20.0\n\n\n# ===================== 小時線指標 =====================\ndef calculate_hourly_indicators(df: pd.DataFrame) -> dict:\n    if len(df) < 169:\n        return {}\n    close = df['Close'].values.astype(float)\n    high = df['High'].values.astype(float)\n    low = df['Low'].values.astype(float)\n\n    ema12 = calc_ema(close, 12)\n    ema144 = calc_ema(close, 144)\n    ema169 = calc_ema(close, 169)\n    atr = calc_atr(high, low, close, 14)\n    macd_line, signal_line, histogram = calc_macd(close, 12, 26, 9)\n\n    # KDJ 自實作\n    n = 9\n    k = np.zeros_like(close)\n    d = np.zeros_like(close)\n    for i in range(n - 1, len(close)):\n        low_n = np.min(low[i - n + 1:i + 1])\n        high_n = np.max(high[i - n + 1:i + 1])\n        if high_n == low_n:\n            k[i] = 50\n            d[i] = 50\n        else:\n            k[i] = (close[i] - low_n) / (high_n - low_n) * 100\n            d[i] = np.mean(k[max(n, i - n + 1):i + 1])\n    j = 3 * k - 2 * d\n\n    return {\n        'close': close, 'high': high, 'low': low,\n        'ema12': ema12, 'ema144': ema144, 'ema169': ema169,\n        'atr': atr, 'k': k, 'd': d, 'j': j,\n        'macd_hist': histogram,\n        'dates': df.index.tolist()\n    }\n\n\n# ===================== 日線指標 =====================\ndef calculate_daily_indicators(df: pd.DataFrame) -> dict:\n    if len(df) < 170:\n        return {}\n    close = df['Close'].values.astype(float)\n    high = df['High'].values.astype(float)\n    low = df['Low'].values.astype(float)\n\n    ema144 = calc_ema(close, 144)\n    ema169 = calc_ema(close, 169)\n    atr = calc_atr(high, low, close, 14)\n    atr_pct = atr / close * 100\n    rsi = calc_rsi(close, 14)\n\n    return {\n        'close': close, 'high': high, 'low': low,\n        'ema144': ema144, 'ema169': ema169,\n        'atr': atr, 'atr_pct': atr_pct, 'rsi': rsi,\n        'dates': df.index.tolist()\n    }\n\n\n# ===================== Fib 結構 + 共振區檢測（Step 2）=====================\ndef get_fib618_with_confluence(df_h: pd.DataFrame, h_ind: dict, order: int = 5) -> Optional[dict]:\n    \"\"\"\n    計算 Fib 0.618 並檢查是否與小時隧道 EMA144/169 重疊（共振區）。\n    同時計算 Fib 1.618 擴展目標價。\n    \"\"\"\n    if len(df_h) < 50:\n        return None\n\n    close = df_h['Close'].values.astype(float)\n    maxima, minima = find_local_extrema(close, order=order)\n\n    peak_idx = np.where(maxima)[0]\n    valley_idx = np.where(minima)[0]\n\n    if len(peak_idx) < 2 or len(valley_idx) < 2:\n        return None\n\n    # 取最近 4 個轉折點，找最近一個波段（低點到高點或高點到低點）\n    pivots = []\n    for idx in sorted(list(peak_idx) + list(valley_idx))[-4:]:\n        pivots.append((idx, close[idx]))\n    pivots.sort(key=lambda x: x[0])\n\n    if len(pivots) < 2:\n        return None\n\n    p1_close = pivots[-2][1]\n    p2_close = pivots[-1][1]\n    high_val = max(p1_close, p2_close)\n    low_val = min(p1_close, p2_close)\n    diff = high_val - low_val\n\n    # Fib 0.618 回撤位\n    if p2_close > p1_close:  # 上升波段：回撤用 high - 0.618*diff\n        fib_618 = high_val - 0.618 * diff\n        # Fib 1.618 擴展目標（從 low 往上算）\n        target = low_val + 1.618 * diff\n    else:  # 下降波段：反彈用 low + 0.618*diff\n        fib_618 = low_val + 0.618 * diff\n        # Fib 1.618 擴展目標（從 high 往下算）— 目標在下方的版本\n        target = high_val - 1.618 * diff\n        # 若是反彈波，目標變成上方 high + 1.618*diff，修正：\n        target = high_val + 1.618 * diff\n\n    # Step 2 共振區檢查：fib_618 是否落在 EMA144/169 隧道區間 ±0.5%\n    h_ema144 = h_ind['ema144'][-1]\n    h_ema169 = h_ind['ema169'][-1]\n    tunnel_upper = max(h_ema144, h_ema169)\n    tunnel_lower = min(h_ema144, h_ema169)\n\n    confluent = (tunnel_lower * (1 - CONFLOW_TOLERANCE) <= fib_618 <= tunnel_upper * (1 + CONFLOW_TOLERANCE))\n\n    return {\n        'fib_618': float(fib_618),\n        'target': float(target),\n        'confluent': confluent,\n        'tunnel_upper': float(tunnel_upper),\n        'tunnel_lower': float(tunnel_lower),\n        'is_rally': p2_close > p1_close\n    }\n\n\n# ===================== Telegram =====================\nTG_TOKEN = \"872054…qAiY\"\nTG_CHAT_ID = \"1616824689\"\n\n\ndef send_telegram(msg: str):\n    url = f\"https://api.telegram.org/bot{TG_TOKEN}/sendMessage\"\n    try:\n        requests.post(url, data={\"chat_id\": TG_CHAT_ID, \"text\": msg, \"parse_mode\": \"Markdown\"}, timeout=10)\n    except Exception 