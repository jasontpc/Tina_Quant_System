{"type":"message","id":"e1e5951a","parentId":"66303aac","timestamp":"2026-05-11T14:52:03.779Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the NL2Code validator and the evolution core in one combined module, then move on to rewriting the actual scanner scripts.\n","thinkingSignature":"0abdfa266b08ad70e858e2c9558c65510ce1c12bcff4479521df8b4ae01cae1b"},{"type":"toolCall","id":"call_function_srnp8fvzjnwk_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nRay NL2Code 驗證層 — Tina 架構移植版\nJSON Schema 拦截 AI 幻覺，確保策略提案為結構化格式\n\"\"\"\n\nimport json\nimport re\nfrom typing import Dict, List, Optional, Tuple\n\n# ── 嚴格的策略協議 Schema ───────────────────────────────────────────\nAXIOM_SCHEMA = {\n    \"type\": \"object\",\n    \"required\": [\"strategy_name\", \"indicator\", \"params\", \"entry_condition\"],\n    \"properties\": {\n        \"strategy_name\": {\n            \"type\": \"string\",\n            \"pattern\": \"^[A-Z][A-Z0-9_]{2,30}$\"  # 大寫字母+數字+底線\n        },\n        \"indicator\": {\n            \"type\": \"string\",\n            \"enum\": [\"EMA_CROSS\", \"VEGAS_TUNNEL\", \"FOREIGN_BUY\", \"MOMENTUM\",\n                     \"KDJ_CROSS\", \"RSI_THRESHOLD\", \"MACD_CROSS\", \"MA_BREAKOUT\"]\n        },\n        \"params\": {\n            \"type\": \"object\",\n            \"properties\": {\n                \"fast\":   {\"type\": \"integer\", \"minimum\": 2, \"maximum\": 200},\n                \"slow\":   {\"type\": \"integer\", \"minimum\": 5, \"maximum\": 500},\n                \"window\": {\"type\": \"integer\", \"minimum\": 2, \"maximum\": 300},\n                \"rsi_period\":  {\"type\": \"integer\", \"minimum\": 2, \"maximum\": 50},\n                \"rsi_buy\":     {\"type\": \"number\",  \"minimum\": 10, \"maximum\": 60},\n                \"rsi_sell\":    {\"type\": \"number\",  \"minimum\": 50, \"maximum\": 95},\n                \"atr_period\":  {\"type\": \"integer\", \"minimum\": 5, \"maximum\": 50},\n                \"stop_loss_pct\": {\"type\": \"number\", \"minimum\": 0.01, \"maximum\": 0.30},\n                \"target_pct\":    {\"type\": \"number\", \"minimum\": 0.01, \"maximum\": 1.00},\n            }\n        },\n        \"entry_condition\": {\n            \"type\": \"object\",\n            \"required\": [\"operator\", \"threshold\"],\n            \"properties\": {\n                \"operator\":  {\"type\": \"string\", \"enum\": [\">\", \"<\", \">=\", \"<=\", \"CROSS_ABOVE\", \"CROSS_BELOW\"]},\n                \"threshold\": {\"type\": \"number\"}\n            }\n        },\n        \"stop_loss\": {\"type\": \"number\", \"minimum\": 0.01, \"maximum\": 0.50},\n        \"target\":    {\"type\": \"number\", \"minimum\": 0.01, \"maximum\": 2.00},\n        \"max_hold_days\": {\"type\": \"integer\", \"minimum\": 1, \"maximum\": 60}\n    }\n}\n\n\nclass NL2CodeValidator:\n    \"\"\"\n    职责：拦截 AI 自然語言輸出中的「幻覺」，確保所有策略都是合法的結構化 JSON\n    仿 Tina 的 NL2Code 驗證層\n    \"\"\"\n\n    def __init__(self, schema: Dict = None):\n        self.schema = schema or AXIOM_SCHEMA\n        self.errors: List[str] = []\n\n    def validate(self, axiom_json: str) -> Tuple[bool, Optional[Dict], List[str]]:\n        \"\"\"\n        輸入：可能是 JSON 字串或已經是 dict\n        輸出：(is_valid, parsed_axiom, errors)\n        \"\"\"\n        self.errors = []\n\n        # ── Step 1：嘗試解析 JSON ────────────────────────────────\n        if isinstance(axiom_json, str):\n            try:\n                axiom = json.loads(axiom_json)\n            except json.JSONDecodeError as e:\n                self.errors.append(f\"JSON parse failed: {e}\")\n                return False, None, self.errors\n        elif isinstance(axiom_json, dict):\n            axiom = axiom_json\n        else:\n            self.errors.append(f\"Unknown type: {type(axiom_json)}\")\n            return False, None, self.errors\n\n        # ── Step 2：檢查必要欄位 ─────────────────────────────────\n        for field in self.schema.get(\"required\", []):\n            if field not in axiom:\n                self.errors.append(f\"Missing required field: {field}\")\n\n        # ── Step 3：檢查 strategy_name 格式 ──────────────────────\n        name = axiom.get(\"strategy_name\", \"\")\n        if not re.match(r\"^[A-Z][A-Z0-9_]{2,30}$\", name):\n            self.errors.append(f\"Invalid strategy_name '{name}': must be UPPER_SNAKE_CASE 3-30 chars\")\n\n        # ── Step 4：檢查 indicator 合法值 ────────────────────────\n        valid_indicators = AXIOM_SCHEMA[\"properties\"][\"indicator\"][\"enum\"]\n        ind = axiom.get(\"indicator\")\n        if ind and ind not in valid_indicators:\n            self.errors.append(f\"Unknown indicator '{ind}': must be one of {valid_indicators}\")\n\n        # ── Step 5：檢查 params 範圍 ─────────────────────────────\n        params = axiom.get(\"params\", {})\n        param_specs = AXIOM_SCHEMA[\"properties\"][\"params\"][\"properties\"]\n        for key, spec in param_specs.items():\n            if key in params:\n                val = params[key]\n                if spec[\"type\"] == \"integer\":\n                    if not isinstance(val, int):\n                        self.errors.append(f\"params.{key} must be int, got {type(val).__name__}\")\n                    elif \"minimum\" in spec and val < spec[\"minimum\"]:\n                        self.errors.append(f\"params.{key}={val} < minimum {spec['minimum']}\")\n                    elif \"maximum\" in spec and val > spec[\"maximum\"]:\n                        self.errors.append(f\"params.{key}={val} > maximum {spec['maximum']}\")\n\n        # ── Step 6：檢查 entry_condition ──────────────────────────\n        ec = axiom.get(\"entry_condition\", {})\n        for field in [\"operator\", \"threshold\"]:\n            if field not in ec:\n                self.errors.append(f\"entry_condition missing '{field}'\")\n\n        # ── Step 7：檢查 stop_loss / target 範圍 ─────────────────\n        if \"stop_loss\" in axiom:\n            sl = axiom[\"stop_loss\"]\n            if not (0.01 <= sl <= 0.50):\n                self.errors.append(f\"stop_loss={sl} must be between 0.01-0.50\")\n\n        if \"target\" in axiom:\n            tgt = axiom[\"target\"]\n            if not (0.01 <= tgt <= 2.00):\n                self.errors.append(f\"target={tgt} must be between 0.01-2.00\")\n\n        is_valid = len(self.errors) == 0\n        return is_valid, axiom if is_valid else None, self.errors\n\n    def validate_batch(self, axiom_list: List[str]) -> List[Tuple[bool, Optional[Dict], List[str]]]:\n        \"\"\"批量驗證多個策略提案\"\"\"\n        return [self.validate(a) for a in axiom_list]\n\n\ndef sanitize_llm_output(raw_output: str) -> str:\n    \"\"\"\n    在 JSON 解析前，先尝试清理 LLM 输常见的格式問題\n    - 移除 markdown code block\n    - 移除解释性文字\n    - 只保留第一个 { ... } JSON block\n    \"\"\"\n    # 移除 ```json ... ``` 或 ``` ... ```\n    pattern = r\"```(?:json)?\\s*([\\s\\S]*?)```\"\n    matches = re.findall(pattern, raw_output)\n    for block in matches:\n        try:\n            json.loads(block)\n            return block\n        except:\n            pass\n\n    # 找第一個完整的 {...} JSON 區塊\n    start = raw_output.find(\"{\")\n    end   = raw_output.rfind(\"}\") + 1\n    if start >= 0 and end > start:\n        candidate = raw_output[start:end]\n        try:\n            json.loads(candidate)\n            return candidate\n        except:\n            pass\n\n    return raw_output  # fallback\n\n\nif __name__ == \"__main__\":\n    # 測試\n    v = NL2CodeValidator()\n\n    good = '{\"strategy_name\":\"EMA_CROSS_12_26\",\"indicator\":\"EMA_CROSS\",\"params\":{\"fast\":12,\"slow\":26},\"entry_condition\":{\"operator\":\">\",\"threshold\":0},\"stop_loss\":0.08}'\n    ok, ax, errs = v.validate(good)\n    print(f\"Good: valid={ok}, errors={errs}\")\n\n    bad = '{\"strategy_name\":\"ema cross bad\",\"indicator\":\"BOGUS\",\"params\":{\"fast\":9999},\"entry_condition\":{}}'\n    ok2, ax2, errs2 = v.validate(bad)\n    print(f\"Bad: valid={ok2}, errors={errs2}\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_nl2code.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":381,"output":1990,"cacheRead":140288,"cacheWrite":0,"totalTokens":142659,"cost":{"input":0.0001143,"output":0.002388,"cacheRead":0.00841728,"cacheWrite":0,"total":0.010919579999999998}},"stopReason":"toolUse","timestamp":1778511054640,"responseId":"06511fd145427748c03eda7d3db4f60b"}}
{"type":"message","id":"73c470f1","parentId":"e1e5951a","timestamp":"2026-05-11T14:52:03.788Z","message":{"role":"toolResult","toolCallId":"call_function_srnp8fvzjnwk_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 6961 bytes to C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_nl2code.py"}],"isError":false,"timestamp":1778511123788}}
{"type":"message","id":"88770159","parentId":"73c470f1","timestamp":"2026-05-11T14:53:16.204Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the evolution core and the upgraded scripts in parallel. Let me update the plan and write the evolution core.\n","thinkingSignature":"b7704bc1f02e4e9081f901af3bc1f5f5c3b0b188838c5419d2fe5348328f4c20"},{"type":"toolCall","id":"call_function_d1s4vsjdkzox_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nRay 進化核心 - Tina autonomous_learning_cycle 移植版\nAI 提案 → NL2Code 驗證 → 數學審核 → SQLite 永久存儲\n\n工作流：\n  1. LLM 根據市場數據生成策略提案（自然語言）\n  2. NL2Code 層拦截，強制轉為結構化 JSON\n  3. 回測引擎跑 Sharpe/MDD 把關\n  4. 通過 → 寫入 backtest_reports + signals_log\n     失敗 → 記錄失敗原因（供下次學習）\n\"\"\"\n\nimport json\nimport yfinance as yf\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Dict, Optional, List, Tuple\n\nfrom .ray_data_center import RayDataCenter\nfrom .ray_engine import RayEngine\nfrom .ray_nl2code import NL2CodeValidator, sanitize_llm_output\n\n\n# ── 智慧協議模板（給 LLM 看的格式說明）────────────────────────────────\nWISDOM_PROMPT_TEMPLATE = \"\"\"你是 Ray 的策略進化引擎。\n根據以下市場數據，生成一個交易策略提案（JSON 格式）。\n\n約束：\n- strategy_name: 大寫 UPPER_SNAKE_CASE，3-30字\n- indicator: EMA_CROSS | VEGAS_TUNNEL | FOREIGN_BUY | MOMENTUM | KDJ_CROSS | RSI_THRESHOLD\n- params: 具體數字（不要用變量）\n- entry_condition: operator 是 > < >= <= CROSS_ABOVE CROSS_BELOW\n- stop_loss: 0.01-0.50（小數）\n- max_hold_days: 1-60\n\n輸出格式（只輸出 JSON，不要其他文字）：\n{\n    \"strategy_name\": \"EMA_CROSS_9_21\",\n    \"indicator\": \"EMA_CROSS\",\n    \"params\": {\"fast\": 9, \"slow\": 21},\n    \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n    \"stop_loss\": 0.08,\n    \"max_hold_days\": 10\n}\n\n市場數據摘要：\n{snippet}\n\"\"\"\n\n\nclass RayEvolutionCore:\n    \"\"\"\n    自主學習循環：提案 → 驗證 → 回測 → 存儲\n    \"\"\"\n\n    def __init__(self, db_path: str = None):\n        self.db     = RayDataCenter(db_path)\n        self.engine = RayEngine(market_type=\"US\", db_path=db_path)\n        self.validator = NL2CodeValidator()\n        self.learned_count   = 0\n        self.rejected_count  = 0\n\n    # ── 核心：自動學習循環（單檔）──────────────────────────────────\n    def autonomous_learning_cycle(self, symbol: str,\n                                   lookback_days: int = 730,\n                                   min_shappe: float = 1.5,\n                                   max_mdd: float = 0.15) -> Dict:\n        \"\"\"\n        對單一標的執行完整的自主學習循環\n\n        步驟：\n        1. 抓取歷史數據\n        2. 嘗試多個候選策略（網格搜索）\n        3. 每個策略經過 NL2Code + 回測把關\n        4. 最好且通過的把關策略寫入 DB\n\n        返回：{status, best_strategy, sharpe, mdd, ...}\n        \"\"\"\n        print(f\"[RayEvolution] Learning cycle for {symbol}...\")\n\n        # ── 抓數據 ───────────────────────────────────────────────\n        try:\n            df = yf.Ticker(symbol).history(period=f\"{lookback_days}d\",\n                                           interval=\"1d\", auto_adjust=True)\n            if df is None or len(df) < 200:\n                return {\"status\": \"error\", \"reason\": \"insufficient data\"}\n        except Exception as e:\n            return {\"status\": \"error\", \"reason\": str(e)}\n\n        # ── 網格候選參數（Ray 擅長的策略）──────────────────────────\n        candidates = []\n\n        # Vegas Tunnel\n        for ema_fast in [144, 169]:\n            for ema_slow in [576, 676]:\n                if ema_fast >= ema_slow: continue\n                candidates.append({\n                    \"strategy_name\": f\"VEGAS_TUNNEL_{ema_fast}_{ema_slow}\",\n                    \"indicator\": \"VEGAS_TUNNEL\",\n                    \"params\": {\"fast\": ema_fast, \"slow\": ema_slow},\n                    \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n                    \"stop_loss\": 0.08,\n                    \"max_hold_days\": 10,\n                })\n\n        # EMA Cross\n        for fast, slow in [(9, 21), (12, 26), (20, 60), (50, 200)]:\n            candidates.append({\n                \"strategy_name\": f\"EMA_CROSS_{fast}_{slow}\",\n                \"indicator\": \"EMA_CROSS\",\n                \"params\": {\"fast\": fast, \"slow\": slow},\n                \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n                \"stop_loss\": 0.08,\n                \"max_hold_days\": 15,\n            })\n\n        # Momentum\n        for window in [5, 10, 20, 60]:\n            candidates.append({\n                \"strategy_name\": f\"MOMENTUM_{window}\",\n                \"indicator\": \"MOMENTUM\",\n                \"params\": {\"window\": window},\n                \"entry_condition\": {\"operator\": \">\", \"threshold\": 0.02},\n                \"stop_loss\": 0.10,\n                \"max_hold_days\": 20,\n            })\n\n        # ── NL2Code 驗證 + 回測把關 ─────────────────────────────────\n        passed_strategies = []\n        for axiom in candidates:\n            # NL2Code 驗證\n            is_valid, parsed, errors = self.validator.validate(axiom)\n            if not is_valid:\n                continue  # 格式不合，自動跳過\n\n            # 回測把關\n            report = self.engine.run_backtest(df, axiom)\n            if report[\"passed\"]:\n                passed_strategies.append({**report, \"axiom\": axiom})\n                backtest_id = self.db.log_backtest(\n                    strategy_name = axiom[\"strategy_name\"],\n                    symbol        = symbol,\n                    indicator     = axiom[\"indicator\"],\n                    params        = axiom[\"params\"],\n                    sharpe        = report[\"sharpe\"],\n                    mdd           = report[\"mdd\"],\n                    total_ret     = report[\"total_ret\"],\n                    win_rate      = report[\"win_rate\"],\n                    avg_return    = report[\"avg_return\"],\n                    num_trades    = report[\"num_trades\"],\n                    note          = f\"auto_learned | cost={report.get('cost_pct',0.15)}%\",\n                )\n                self.db.log_wisdom(\n                    axiom_json = json.dumps(axiom),\n                    reflection = f\"SHARP={report['sharpe']:.2f} MDD={report['mdd']:.2%} WIN={report['win_rate']:.1%}\",\n                    backtest_id = backtest_id,\n                )\n\n        # ── 選最佳策略 ─────────────────────────────────────────────\n        if passed_strategies:\n            best = sorted(passed_strategies, key=lambda x: -x[\"sharpe\"])[0]\n            self.learned_count += 1\n            print(f\"[RayEvolution] ✅ {symbol}: {len(passed_strategies)} passed, best Sharpe={best['sharpe']:.2f}\")\n            return {\n                \"status\":         \"success\",\n                \"symbol\":         symbol,\n                \"best_strategy\":  best[\"axiom\"][\"strategy_name\"],\n                \"indicator\":       best[\"axiom\"][\"indicator\"],\n                \"sharpe\":         best[\"sharpe\"],\n                \"mdd\":            best[\"mdd\"],\n                \"total_ret\":      best[\"total_ret\"],\n                \"win_rate\":       best[\"win_rate\"],\n                \"num_trades\":     best[\"num_trades\"],\n                \"passed_count\":   len(passed_strategies),\n            }\n        else:\n            self.rejected_count += 1\n            # 記錄失敗\n            self.db.log_wisdom(\n                axiom_json = json.dumps({\"symbol\": symbol, \"attempted\": len(candidates)}),\n                reflection = f\"No strategy passed (tried {len(candidates)})\",\n            )\n            print(f\"[RayEvolution] ❌ {symbol}: all {len(candidates)} strategies rejected\")\n            return {\n                \"status\":   \"rejected\",\n                \"symbol\":   symbol,\n                \"attempted\": len(candidates),\n            }\n\n    # ── 批量學習（多檔）────────────────────────────────────────────\n    def batch_learning(self, symbols: List[str], lookback_days: int = 730) -> List[Dict]:\n        results = []\n        for sym in symbols:\n            r = self.autonomous_learning_cycle(sym, lookback_days)\n            results.append(r)\n        return results\n\n    # ── 讀取已知的好策略（通過把關的）─────────────────────────────\n    def get_approved_strategies(self, limit: int = 20) -> List[Dict]:\n        return self.db.get_approved_backtests(limit=limit)\n\n    # ── 讀取近期學習摘要 ─────────────────────────────────────────\n    def get_learning_stats(self) -> Dict:\n        recent = self.db.get_recent_backtests(days=7)\n        approved = [r for r in recent if r.get(\"passed\")]\n        return {\n            \"total_learned\":   self.learned_count,\n            \"total_rejected\":  self.rejected_count,\n            \"recent_backtests\": len(recent),\n            \"recent_approved\":  len(approved),\n            \"avg_sharpe\":      round(sum(r[\"sharpe_ratio\"] for r in approved) / max(len(approved), 1), 2),\n            \"avg_mdd\":         round(sum(r[\"max_drawdown\"] for r in approved) / max(len(approved), 1), 4),\n        }\n\n\nif __name__ == \"__main__\":\n    core = RayEvolutionCore()\n    result = core.autonomous_learning_cycle(\"NVDA\", lookback_days=365)\n    print(f\"Result: {result}\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_evolution.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":2126,"output":2286,"cacheRead":140544,"cacheWrite":0,"totalTokens":144956,"cost":{"input":0.0006378,"output":0.0027432,"cacheRead":0.00843264,"cacheWrite":0,"total":0.01181364}},"stopReason":"toolUse","timestamp":1778511123790,"responseId":"065120173e6b160d92a59f23a8b9c4cc"}}
{"type":"message","id":"bb2c4e95","parentId":"88770159","timestamp":"2026-05-11T14:53:16.216Z","message":{"role":"toolResult","toolCallId":"call_function_d1s4vsjdkzox_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 8276 bytes to C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_evolution.py"}],"isError":false,"timestamp":1778511196216}}
{"type":"message","id":"aa0026ca","parentId":"bb2c4e95","timestamp":"2026-05-11T14:53:29.401Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the plan and write the integration layer that ties everything together, then rewrite the main scripts.\n","thinkingSignature":"d49e3b855f9f5fffa715449f2d00d19a188bf314693ea019d86160f6d95e4367"},{"type":"toolCall","id":"call_function_f2famyg7hi3e_1","name":"update_plan","arguments":{"plan":[{"status":"completed","step":"建立 SQLite 數據中心（TinaDataCenter）— signals_log / positions_log / trades_log / performance_log"},{"status":"completed","step":"建立回測引擎（TinaEngine）— 摩擦成本 0.15% + Sharpe > 1.5 + MDD < 15% 把關"},{"status":"completed","step":"建立 NL2Code 驗證層（JSON Schema 拦截幻覺）"},{"status":"completed","step":"建立進化核心（autonomous_learning_cycle）— 提案→驗證→存儲 workflow"},{"status":"in_progress","step":"重寫 vegas_scan.py 接入新架構"},{"status":"pending","step":"重寫 us_momentum.py / us_scan_live.py 接入新架構"},{"status":"pending","step":"更新 SOUL.md / IDENTITY.md 同步 Ray 的新定位"}]}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":2377,"output":259,"cacheRead":142592,"cacheWrite":0,"totalTokens":145228,"cost":{"input":0.0007130999999999999,"output":0.00031079999999999997,"cacheRead":0.008555519999999999,"cacheWrite":0,"total":0.009579419999999998}},"stopReason":"toolUse","timestamp":1778511196220,"responseId":"0651205e6fdce8af8c9675bd5be59168"}}
{"type":"message","id":"927ff9eb","parentId":"aa0026ca","timestamp":"2026-05-11T14:53:29.408Z","message":{"role":"toolResult","toolCallId":"call_function_f2famyg7hi3e_1","toolName":"update_plan","content":[],"details":{"status":"updated","plan":[{"step":"建立 SQLite 數據中心（TinaDataCenter）— signals_log / positions_log / trades_log / performance_log","status":"completed"},{"step":"建立回測引擎（TinaEngine）— 摩擦成本 0.15% + Sharpe > 1.5 + MDD < 15% 把關","status":"completed"},{"step":"建立 NL2Code 驗證層（JSON Schema 拦截幻覺）","status":"completed"},{"step":"建立進化核心（autonomous_learning_cycle）— 提案→驗證→存儲 workflow","status":"completed"},{"step":"重寫 vegas_scan.py 接入新架構","status":"in_progress"},{"step":"重寫 us_momentum.py / us_scan_live.py 接入新架構","status":"pending"},{"step":"更新 SOUL.md / IDENTITY.md 同步 Ray 的新定位","status":"pending"}]},"isError":false,"timestamp":1778511209408}}
{"type":"message","id":"619e874c","parentId":"927ff9eb","timestamp":"2026-05-11T14:55:03.439Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me rewrite vegas_scan.py to integrate the new Tina architecture. This is the key scan script that Jo uses. It should:\n\n1. Use RayEngine for backtest validation with Sharpe/MDD gate\n2. Use RayDataCenter for SQLite logging\n3. Use NL2Code validation\n4. Report signals with statistical backing\n\nThe new vegas_scan.py should:\n- Scan NASDAQ100 + SOX30\n- For each candidate that passes basic vegas criteria, also run a 30-day rolling backtest\n- Only push signals that pass both vegas AND Sharpe > 1.5 + MDD < 15%\n\n\n- Log everything to SQLite for a complete audit trail\n","thinkingSignature":"81e834a4f1398f8d6e44b389254c92be91ca094eb0901b79e0886c635ad5b0dd"},{"type":"toolCall","id":"call_function_xdpkakv85v4z_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nVegas Tunnel Scanner - Tina Architecture Edition\nNASDAQ100 + SOX30 via yfinance\n\n整合：RayDataCenter + RayEngine + NL2Code 驗證層\n- 只推送通過「Sharpe > 1.5 + MDD < 15%」把關的信號\n- 所有掃描結果寫入 SQLite\n- 摩擦成本實體化 0.15%\n\nRun: python vegas_scan.py\n\"\"\"\n\nimport sys, os, time, json\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nimport yfinance as yf\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nimport warnings, requests\nfrom io import StringIO\nwarnings.filterwarnings(\"ignore\")\n\n# ── Ray Architecture ────────────────────────────────────────────────\nsys.path.insert(0, __name__)\nfrom ray_data_center import RayDataCenter\nfrom ray_engine import RayEngine\nfrom ray_nl2code import NL2CodeValidator\n\n# ── Constants ──────────────────────────────────────────────────────\nMIN_SCORE        = 3\nSHARPE_MIN       = 1.5\nMDD_MAX          = 0.15\nWIN_MIN          = 0.45\nCOST_US          = 0.0015   # 0.15%\nWIKI_HEADERS     = {\"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64)\"}\n\n# ── Stock Lists ──────────────────────────────────────────────────\ndef fetch_nasdaq100():\n    url = \"https://en.wikipedia.org/wiki/NASDAQ-100\"\n    try:\n        r = requests.get(url, headers=WIKI_HEADERS, timeout=10)\n        tables = pd.read_html(StringIO(r.text))\n        for t in tables:\n            if \"Ticker\" in list(t.columns):\n                syms = [str(s).replace(\".\", \"-\") for s in t[\"Ticker\"].dropna()]\n                print(f\"  NASDAQ100: {len(syms)} stocks\")\n                return syms\n        return []\n    except Exception as e:\n        print(f\"  NASDAQ100 failed: {e}\")\n        return []\n\nSOX30 = [\n    \"NVDA\",\"AMD\",\"INTC\",\"AMAT\",\"LRCX\",\"MU\",\"MCHP\",\"QRVO\",\"QCOM\",\n    \"AVGO\",\"TXN\",\"ADI\",\"SWKS\",\"CRUS\",\"MPWR\",\"ON\",\"NXPI\",\"GFS\",\n    \"ENTG\",\"KLAC\",\"TER\",\"ALAB\",\"LTHM\",\"VSH\",\"DIOD\",\"AXTI\",\"FORM\",\"SNPS\",\"CDNS\",\"ASML\"\n]\n\n# ── Vegas Signal ─────────────────────────────────────────────────\ndef vegas_signal(close, volume):\n    if len(close) < 200: return None\n    ema12  = close.ewm(span=12,  adjust=False).mean()\n    ema144 = close.ewm(span=144, adjust=False).mean()\n    ema169 = close.ewm(span=169, adjust=False).mean()\n    ema576 = close.ewm(span=576, adjust=False).mean()\n    ema676 = close.ewm(span=676, adjust=False).mean()\n    c  = close.iloc[-1]\n    c1 = close.iloc[-2] if len(close) > 1 else c\n    e12  = ema12.iloc[-1]\n    e144 = ema144.iloc[-1]\n    e169 = ema169.iloc[-1]\n    e576 = ema576.iloc[-1]\n    e676 = ema676.iloc[-1]\n    v    = volume.iloc[-1]\n    e12_1  = ema12.iloc[-2]  if len(ema12)  > 1 else e12\n    e144_1 = ema144.iloc[-2] if len(ema144) > 1 else e144\n\n    tunnel_bull   = (e144 > e169) and (e144 > e144_1) and (e169 > ema169.iloc[-2])\n    bigtrend_bull  = (c > e576) and (c > e676) and (e576 > e676) and (e576 > ema576.iloc[-2])\n    price_breakout = (c > e144) and (c > e169) and (c1 <= e144)\n    ema12_confirm  = (e12 > e144) and (e12 > e169) and (e12_1 <= e144)\n    false_breakout = price_breakout and not ema12_confirm\n\n    delta = close.diff()\n    gain  = delta.clip(lower=0).ewm(alpha=1/14, adjust=False).mean()\n    loss  = (-delta.clip(upper=0)).ewm(alpha=1/14, adjust=False).mean()\n    try:\n        rs = gain / loss\n        rsi14 = float((100 - (100 / (1 + rs))).iloc[-1])\n        if np.isnan(rsi14) or np.isinf(rsi14): rsi14 = 50.0\n        else: rsi14 = min(max(rsi14, 0), 99)\n    except: rsi14 = 50.0\n\n    score = 0\n    if tunnel_bull:   score += 1\n    if bigtrend_bull: score += 1\n    if price_breakout and ema12_confirm and not false_breakout: score += 2\n    if rsi14 < 80:    score += 1\n    score = min(score, 5)\n\n    if price_breakout and ema12_confirm and tunnel_bull and bigtrend_bull and not false_breakout:\n        trend, breakout = \"BULL\", True\n    elif tunnel_bull and bigtrend_bull:\n        trend, breakout = \"BULL_LAGGING\", False\n    else:\n        trend, breakout = \"NEUTRAL\", False\n\n    return dict(\n        close=float(c), ema12=float(e12), ema144=float(e144), ema169=float(e169),\n        ema576=float(e576), ema676=float(e676),\n        rsi14=rsi14, score=score, breakout=breakout, trend=trend, volume=int(v)\n    )\n\n# ── Scanner ──────────────────────────────────────────────────────\ndef scan_us(tickers, label, engine, validator, db):\n    results = []\n    failed = []\n    total = len(tickers)\n\n    for i, t in enumerate(tickers):\n        pct = (i+1)*100//total\n        if (i+1) % 50 == 0 or (i+1) == total:\n            print(f\"  {label} {i+1}/{total} ({pct}%)  matched:{len(results)}  failed:{len(failed)}\")\n\n        try:\n            tk = yf.Ticker(t)\n            h = tk.history(period=\"2y\", auto_adjust=True, timeout=5)\n            if h is None or len(h) < 200:\n                failed.append(t); continue\n\n            sig = vegas_signal(h[\"Close\"], h[\"Volume\"])\n            if not sig or sig[\"score\"] < MIN_SCORE:\n                continue\n\n            # ── Tina 數學把關：30日滾動 Sharpe/MDD ─────────────\n            df_30 = h.tail(30).copy()\n            stats = engine.calc_rolling_stats(df_30)\n\n            sharpe = stats.get(\"sharpe\") or 0\n            mdd    = stats.get(\"mdd\")    or 999\n            win_r  = stats.get(\"win_rate\") or 0\n\n            # 通過 Sharpe + MDD 把關\n            math_passed = (sharpe >= SHARPE_MIN and mdd <= MDD_MAX and win_r >= WIN_MIN)\n\n            sig[\"stock_id\"]     = t\n            sig[\"market\"]       = label\n            sig[\"sharpe_30d\"]    = sharpe\n            sig[\"mdd_30d\"]       = mdd\n            sig[\"win_rate_30d\"]  = win_r\n            sig[\"math_passed\"]   = math_passed\n\n            # ── 寫入 SQLite ────────────────────────────────────\n            signal_tag = \"BUY\" if (sig[\"breakout\"] and math_passed) else \\\n                         \"WATCH\" if math_passed else \"NEUT\"\n\n            sig_id = db.log_signal(\n                symbol     = t,\n                source     = \"vegas\",\n                score      = sig[\"score\"],\n                sharpe     = sharpe,\n                mdd        = mdd,\n                win_rate   = win_r,\n                signal_tag = signal_tag,\n                note       = f\"vegas_score={sig['score']} breakout={sig['breakout']}\"\n            )\n            sig[\"signal_id\"] = sig_id\n\n            if math_passed:\n                results.append(sig)\n\n        except Exception as e:\n            failed.append(f\"{t}:{e}\")\n\n        time.sleep(0.15)\n\n    print(f\"  {label}: {len(results)} approved (Sharpe>{SHARPE_MIN} MDD<{MDD_MAX*100}%), {len(failed)} failed\")\n    return results\n\n# ── Report ───────────────────────────────────────────────────────\ndef print_report(rb):\n    for mkt, res in rb.items():\n        if not res: continue\n        res.sort(key=lambda x: (x[\"score\"], x[\"breakout\"]), reverse=True)\n        print(f\"\\n{'='*90}\")\n        print(f\"{mkt} Vegas + Math Gate ({len(res)} approved signals)\")\n        print(f\"{'='*90}\")\n        print(f\"{'Ticker':<10}{'Close':>8}{'VScore':>7}{'Sharpe':>8}{'MDD':>8}{'WinR':>7}{'RSI':>6}{'Signal'}\")\n        print(\"-\"*90)\n        for r in res:\n            tag = \"🟢 BREAKOUT\" if r[\"breakout\"] else \"🟡 BULL_LAG\"\n            print(f\"{r['stock_id']:<10}{r['close']:>8.2f}{r['score']:>7}{r['sharpe_30d']:>8.3f}\"\n                  f\"{r['mdd_30d']:>8.2%}{r['win_rate_30d']:>7.1%}{r['rsi14']:>6.1f} {tag}\")\n\n        bk = [x for x in res if x[\"breakout\"]]\n        if bk:\n            print(f\"\\n  🟢 BREAKOUT ({len(bk)} stocks)\")\n            for r in bk:\n                print(f\"  -> {r['stock_id']} | C:${r['close']:.2f} | S:{r['sharpe_30d']:.2f} | \"\n                      f\"MDD:{r['mdd_30d']:.2%} | RSI:{r['rsi14']:.1f} | S:{r['score']}/5\")\n\ndef save_csv(rb):\n    rows = []\n    for mkt, res in rb.items():\n        for r in res:\n            r2 = dict(r)\n            r2[\"market\"] = mkt\n            rows.append(r2)\n    if rows:\n        df = pd.DataFrame(rows)\n        ts = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n        path = f\"vegas_results_{ts}.csv\"\n        df.to_csv(path, index=False, encoding=\"utf-8-sig\")\n        print(f\"Saved {path}\")\n\n# ── Main ─────────────────────────────────────────────────────────\nif __name__ == \"__main__\":\n    print(\"=\"*60)\n    print(\"Vegas Tunnel Scanner | Tina Architecture\")\n    print(f\"Time: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    print(f\"Math Gate: Sharpe > {SHARPE_MIN}, MDD < {MDD_MAX*100}%, Win > {WIN_MIN*100}%\")\n    print(f\"Cost: {COST_US*100:.2f}% per trade\")\n    print(\"=\"*60)\n\n    db       = RayDataCenter()\n    engine   = RayEngine(market_type=\"US\")\n    validator = NL2CodeValidator()\n    rb       = {}\n\n    nasdaq100 = fetch_nasdaq100()\n    sox30     = SOX30\n\n    if nasdaq100:\n        print(f\"\\n[SCAN] NASDAQ100 ({len(nasdaq100)} stocks)\")\n        rb[\"NASDAQ100\"] = scan_us(nasdaq100, \"NASDAQ100\", engine, validator, db)\n\n    print(f\"\\n[SCAN] SOX30 ({len(sox30)} stocks)\")\n    rb[\"SOX30\"] = scan_us(sox30, \"SOX30\", engine, validator, db)\n\n    print_report(rb)\n    save_csv(rb)\n\n    # 只推送數學把關通過的信號（供外部推播使用）\n    all_approved = [r for res in rb.values() for r in res]\n    approved_ids = [r.get(\"signal_id\") for r in all_approved if r.get(\"signal_id\")]\n    if approved_ids:\n        db.mark_signals_pushed(approved_ids)\n\n    total = sum(len(v) for v in rb.values())\n    print(f\"\\nTotal approved: {total} signals (from {len(nasdaq100)+len(sox30)} stocks scanned)\")\n    print(\"Done.\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\vegas_scan.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":324,"output":3116,"cacheRead":144896,"cacheWrite":0,"totalTokens":148336,"cost":{"input":0.00009719999999999999,"output":0.0037392,"cacheRead":0.00869376,"cacheWrite":0,"total":0.01253016}},"stopReason":"toolUse","timestamp":1778511209411,"responseId":"0651206c089530c3aeb625ea81b623d6"}}
