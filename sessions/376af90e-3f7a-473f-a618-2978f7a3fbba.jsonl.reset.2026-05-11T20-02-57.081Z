{"type":"message","id":"9904ee32","parentId":"579db318","timestamp":"2026-05-11T19:54:00.788Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The file has encoding issues. Let me just write a clean new version.\n","thinkingSignature":"129174cea4dc4d99ead5b149dda93a0875a94dce73fdcd0770fa07dafbc0f279"},{"type":"toolCall","id":"call_function_sido7pusfrm2_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nRay Tina Bridge - Ollama Local Model Integration Layer\n\"\"\"\n\nimport requests\nimport json\nimport re\n\nDEFAULT_URL   = \"http://localhost:11434/api/chat\"\nDEFAULT_MODEL = \"qwen2.5:1.5b\"\n\n\nclass TinaBridge:\n    def __init__(self, model: str = DEFAULT_MODEL, base_url: str = DEFAULT_URL):\n        self.url   = base_url\n        self.model = model\n\n    def ask_logic(self, prompt: str, context_data: str = \"\") -> str:\n        system_prompt = (\n            \"You are Ray's quant logic unit. Tina Architecture Edition. \"\n            \"Always output valid JSON. No natural language. \"\n            'Schema: {\"strategy_name\":\"...\",\"indicator\":\"...\",\"params\":{},'\n            '\"entry_condition\":{},\"stop_loss\":0.0}'\n        )\n\n        payload = {\n            \"model\":      self.model,\n            \"messages\": [\n                {\"role\": \"system\", \"content\": system_prompt},\n                {\"role\": \"user\",   \"content\": f\"Context:\\n{context_data}\\n\\nTask:\\n{prompt}\"}\n            ],\n            \"temperature\": 0.1,\n            \"stream\":     False,\n        }\n\n        try:\n            resp = requests.post(self.url, json=payload, timeout=120)\n            resp.raise_for_status()\n            raw = resp.json()[\"message\"][\"content\"]\n\n            # Extract first JSON block from markdown or raw text\n            json_str = self._extract_json(raw)\n            json.loads(json_str)  # validate\n            return json_str\n\n        except requests.exceptions.ConnectionError:\n            return '{\"error\": \"Ollama not running\"}'\n        except json.JSONDecodeError as e:\n            return f'{{\"error\": \"Invalid JSON\", \"details\": \"{str(e)[:100]}\"}}'\n        except Exception as e:\n            return f'{{\"error\": \"Bridge failure\", \"details\": \"{str(e)[:100]}\"}}'\n\n    def _extract_json(self, text: str) -> str:\n        \"\"\"Strip markdown code fences and extract first valid JSON block.\"\"\"\n        # Remove ```json ... ``` or ``` ... ```\n        text = text.strip()\n        m = re.search(r'```(?:\\w+)?\\s*([\\s\\S]*?)```', text)\n        if m:\n            candidate = m.group(1).strip()\n            try:\n                json.loads(candidate)\n                return candidate\n            except: pass\n\n        # Find first {...} block\n        start = text.find('{')\n        end   = text.rfind('}') + 1\n        if start >= 0 and end > start:\n            candidate = text[start:end]\n            try:\n                json.loads(candidate)\n                return candidate\n            except: pass\n\n        return text  # fallback: return raw\n\n\nif __name__ == \"__main__\":\n    bridge = TinaBridge(model=\"ray-v1\")\n    data = \"NVDA | RSI=28 | Sharpe=1.8 | MACD金叉 | 外資淨買\"\n    result = bridge.ask_logic(\"Output strict JSON strategy\", data)\n    print(result)\n    try:\n        parsed = json.loads(result)\n        print(f\"Strategy: {parsed.get('strategy_name')}\")\n    except:\n        pass","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\tina_bridge.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":169,"output":762,"cacheRead":107136,"cacheWrite":0,"totalTokens":108067,"cost":{"input":0.0000507,"output":0.0009144,"cacheRead":0.00642816,"cacheWrite":0,"total":0.00739326}},"stopReason":"toolUse","timestamp":1778526437487,"responseId":"06515be72957f6fc89a573f05d9e1e96"}}
