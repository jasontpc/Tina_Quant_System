{"type":"message","id":"6757d84d","parentId":"efb3f899","timestamp":"2026-05-11T19:49:09.628Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"ray_distiller.py doesn't exist yet. I need to create it. Let me write it to the correct location.\n","thinkingSignature":"473a5cd946a51b22af39c857f283fa23213010857d80051b33b725dae0f10c20"},{"type":"toolCall","id":"call_function_b4bvk1tilinn_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nRay 蒸餾引擎 - Tina Architecture Edition\n自動從 Ray 的交易智慧中提取「決策邏輯」，蒸餾給 1.5B\n\n流程：\n  1. 讀取 wisdom_logs（7B 的推理過程）\n  2. 讀取 backtest_reports（數學把關結果）\n  3. 只蒸餾 Sharpe > 1.8 + passed=1 的黃金案例\n  4. 生成 SFT JSONL（用於微調 1.5B）\n\nRun: python ray_distiller.py\n\"\"\"\n\nimport os\nimport sqlite3\nimport json\nfrom datetime import datetime\n\nDB_PATH     = os.path.join(os.path.dirname(__file__), \"ray_wisdom.db\")\nOUTPUT_PATH = os.path.join(os.path.dirname(__file__), \"ray_distill_train.jsonl\")\nSHARPE_MIN  = 1.8   # 只有高 Sharpe 才能當老師\n\n\nclass RayDistiller:\n    def __init__(self, db_path: str = None):\n        self.db_path = db_path or DB_PATH\n\n    def generate(self, output_path: str = None) -> dict:\n        \"\"\"\n        從 DB 中提取黃金案例，格式化為 SFT JSONL\n        每筆案例 = {messages: [system, user, assistant]}\n        \"\"\"\n        conn = sqlite3.connect(self.db_path, isolation_level='IMMEDIATE')\n        conn.row_factory = sqlite3.Row\n        cur = conn.cursor()\n\n        # 查詢：7B 推理 + 數學驗證通過 + 高 Sharpe\n        cur.execute(\"\"\"\n            SELECT w.axiom_json, w.reflection, w.model_used,\n                   w.timestamp, w.passed,\n                   r.sharpe_ratio, r.max_drawdown, r.total_return,\n                   r.win_rate, r.strategy_name, r.symbol, r.indicator\n            FROM wisdom_logs w\n            JOIN backtest_reports r ON w.backtest_id = r.id\n            WHERE r.sharpe_ratio > ?\n              AND r.passed = 1\n              AND w.passed = 1\n            ORDER BY r.sharpe_ratio DESC\n            LIMIT 500\n        \"\"\", (SHARPE_MIN,))\n\n        rows = cur.fetchall()\n        conn.close()\n\n        distilled = []\n        symbols = set()\n\n        for row in rows:\n            try:\n                axiom = json.loads(row[\"axiom_json\"])\n            except:\n                axiom = {\"strategy_name\": \"UNKNOWN\", \"raw\": row[\"axiom_json\"]}\n\n            reflection = row[\"reflection\"] or \"\"\n            symbols.add(row[\"symbol\"])\n\n            entry = {\n                \"messages\": [\n                    {\n                        \"role\": \"system\",\n                        \"content\": (\n                            \"You are Ray-Fast (1.5B distilled). \"\n                            \"Output ONLY valid JSON. No text. \"\n                            'Schema: {\"strategy_name\":\"...\",\"indicator\":\"...\",\"params\":{},'\n                            '\"entry_condition\":{},\"stop_loss\":0.0}'\n                        )\n                    },\n                    {\n                        \"role\": \"user\",\n                        \"content\": (\n                            f\"Symbol: {row['symbol']}\\n\"\n                            f\"Reflection: {reflection[:200]}\\n\"\n                            f\"Sharpe: {row['sharpe_ratio']:.2f} | \"\n                            f\"MDD: {row['max_drawdown']:.2%} | \"\n                            f\"WinRate: {row['win_rate']:.1%}\\n\"\n                            f\"Output JSON strategy.\"\n                        )\n                    },\n                    {\n                        \"role\": \"assistant\",\n                        \"content\": row[\"axiom_json\"]\n                    }\n                ],\n                \"metadata\": {\n                    \"symbol\":    row[\"symbol\"],\n                    \"strategy\":  row[\"strategy_name\"],\n                    \"sharpe\":    round(row[\"sharpe_ratio\"], 3),\n                    \"mdd\":       round(row[\"max_drawdown\"], 4),\n                    \"win_rate\":  round(row[\"win_rate\"], 4),\n                    \"model\":     row[\"model_used\"] or \"qwen2.5:7b\",\n                    \"rationale\": reflection[:300] if reflection else \"\"\n                }\n            }\n            distilled.append(entry)\n\n        path = output_path or OUTPUT_PATH\n\n        with open(path, \"w\", encoding=\"utf-8\") as f:\n            for item in distilled:\n                f.write(json.dumps(item, ensure_ascii=False) + \"\\n\")\n\n        avg_sharpe = round(sum(r['sharpe_ratio'] for r in rows) / len(rows), 3) if rows else 0\n\n        print(f\"[*] 蒸餾完成：{len(distilled)} 筆黃金案例 → {path}\")\n        print(f\"[*] 覆蓋 {len(symbols)} 個標的，平均 Sharpe = {avg_sharpe}\")\n\n        return {\n            \"count\":      len(distilled),\n            \"symbols\":    list(symbols),\n            \"avg_sharpe\": avg_sharpe,\n            \"path\":       path,\n            \"min_sharpe\": SHARPE_MIN\n        }\n\n    def generate_from_signals(self, output_path: str = None) -> dict:\n        \"\"\"\n        如果 wisdom_logs 還沒有足夠的數據，\n        從 signals_log 中提取通過數學把關的信號作為替代蒸餾源。\n        這些是本地 Python 的「專家信號」，可以作为 1.5B 的微調起點。\n        \"\"\"\n        conn = sqlite3.connect(self.db_path, isolation_level='IMMEDIATE')\n        conn.row_factory = sqlite3.Row\n        cur = conn.cursor()\n\n        # 從信號日誌中取高評分案例\n        cur.execute(\"\"\"\n            SELECT symbol, score, sharpe_30d, mdd_30d, win_rate_30d,\n                   signal_tag, note, timestamp\n            FROM signals_log\n            WHERE approved = 1\n              AND sharpe_30d IS NOT NULL\n              AND sharpe_30d > 1.5\n            ORDER BY sharpe_30d DESC\n            LIMIT 300\n        \"\"\")\n        rows = cur.fetchall()\n        conn.close()\n\n        distilled = []\n        symbols = set()\n\n        for row in rows:\n            symbols.add(row[\"symbol\"])\n\n            # 構造「專家策略」格式\n            note_parts = []\n            if row[\"note\"]:\n                note_parts.append(row[\"note\"][:150])\n\n            entry = {\n                \"messages\": [\n                    {\n                        \"role\": \"system\",\n                        \"content\": (\n                            \"You are Ray-Fast (1.5B expert-distilled). \"\n                            \"Output ONLY valid JSON. No text. \"\n                            'Schema: {\"strategy_name\":\"...\",\"indicator\":\"...\",\"params\":{},'\n                            '\"entry_condition\":{},\"stop_loss\":0.0}'\n                        )\n                    },\n                    {\n                        \"role\": \"user\",\n                        \"content\": (\n                            f\"Symbol: {row['symbol']}\\n\"\n                            f\"Score: {row['score']}/5 | Signal: {row['signal_tag']}\\n\"\n                            f\"Sharpe: {row['sharpe_30d']:.2f} | \"\n                            f\"MDD: {row['mdd_30d']:.2%} | \"\n                            f\"WinRate: {row['win_rate_30d']:.1%}\\n\"\n                            f\"Context: {', '.join(note_parts) if note_parts else 'expert signal'}\\n\"\n                            f\"Output JSON strategy.\"\n                        )\n                    },\n                    {\n                        \"role\": \"assistant\",\n                        \"content\": json.dumps({\n                            \"strategy_name\": f\"EXPERT_SIGNAL_{row['symbol']}_{int(row['score'])}\",\n                            \"indicator\": \"MOMENTUM\",\n                            \"params\": {\"window\": 20},\n                            \"entry_condition\": {\"operator\": \">\", \"threshold\": 0.02},\n                            \"stop_loss\": 0.08,\n                            \"max_hold_days\": 10,\n                            \"confidence\": \"HIGH\" if row[\"sharpe_30d\"] > 2.0 else \"MEDIUM\"\n                        }, ensure_ascii=False)\n                    }\n                ],\n                \"metadata\": {\n                    \"symbol\":    row[\"symbol\"],\n                    \"source\":    \"signals_log\",\n                    \"sharpe\":    round(row[\"sharpe_30d\"], 3) if row[\"sharpe_30d\"] else 0,\n                    \"mdd\":       round(row[\"mdd_30d\"], 4) if row[\"mdd_30d\"] else 0,\n                    \"win_rate\":  round(row[\"win_rate_30d\"], 4) if row[\"win_rate_30d\"] else 0,\n                    \"signal_tag\": row[\"signal_tag\"],\n                    \"score\":     row[\"score\"]\n                }\n            }\n            distilled.append(entry)\n\n        path = output_path or os.path.join(os.path.dirname(__file__), \"ray_signal_distill.jsonl\")\n\n        with open(path, \"w\", encoding=\"utf-8\") as f:\n            for item in distilled:\n                f.write(json.dumps(item, ensure_ascii=False) + \"\\n\")\n\n        print(f\"[*] 信號蒸餾完成：{len(distilled)} 筆 → {path}\")\n        print(f\"[*] 覆蓋 {len(symbols)} 個標的\")\n\n        return {\n            \"count\":   len(distilled),\n            \"symbols\": list(symbols),\n            \"path\":    path,\n            \"source\":  \"signals_log (expert signals)\"\n        }\n\n\nif __name__ == \"__main__\":\n    distiller = RayDistiller()\n\n    # 先嘗試從 wisdom_logs + backtest_reports 蒸餾\n    print(\"=== Ray Distiller ===\")\n    print(f\"DB: {DB_PATH}\")\n    print(f\"Min Sharpe: {SHARPE_MIN}\")\n\n    result1 = distiller.generate()\n\n    # 如果蒸餾不到 50 筆，從 signals_log 補充\n    if result1[\"count\"] < 50:\n        print(\"\\n[INFO] wisdom_logs 數據不足，從 signals_log 補充...\")\n        result2 = distiller.generate_from_signals()\n        print(f\"[INFO] 補充後總計: {result1['count'] + result2['count']} 筆\")\n    else:\n        print(f\"\\n[OK] 找到 {result1['count']} 筆黃金案例\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_distiller.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":168,"output":2292,"cacheRead":84992,"cacheWrite":0,"totalTokens":87452,"cost":{"input":0.0000504,"output":0.0027504,"cacheRead":0.00509952,"cacheWrite":0,"total":0.007900319999999999}},"stopReason":"toolUse","timestamp":1778528891825,"responseId":"0651657d82094760d84fd1f92cc6ae5c"}}
