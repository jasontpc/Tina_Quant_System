{"type":"message","id":"9f9712cf","parentId":"034f656c","timestamp":"2026-05-11T15:43:35.894Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the TinaBridge Python script, then start ollama serve and pull the model.\n","thinkingSignature":"0ade5765954c0dc6f15a7f80962408953d0922dd05db2bbbb84501b0966448ba"},{"type":"toolCall","id":"call_function_elgtansl5y5r_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nRay Tina Bridge — Ollama 本地模型整合層\n搭配 OpenClaw Agent 使用\n\n用法：\n  from tina_bridge import TinaBridge\n  bridge = TinaBridge(model=\"qwen2.5:1.5b\")  # 或 ray-v1 已創建的模型\n  result = bridge.ask_logic(\"根據以下數據提煉買入策略\", context_data)\n\"\"\"\n\nimport requests\nimport json\nfrom typing import Optional, Dict\n\nDEFAULT_URL = \"http://localhost:11434/v1/chat/completions\"\nDEFAULT_MODEL = \"qwen2.5:1.5b\"\n\n\nclass TinaBridge:\n    \"\"\"\n    將 OpenClaw 的量化需求發送到本地 Qwen 模型，\n    配合 NL2Code 驗證層確保輸出穩定。\n    \"\"\"\n\n    def __init__(self, model: str = DEFAULT_MODEL, base_url: str = DEFAULT_URL):\n        self.url   = base_url\n        self.model = model\n\n    def ask_logic(self, prompt: str, context_data: str = \"\") -> str:\n        \"\"\"\n        發送任務給本地 Qwen，返回 JSON 字串\n        失敗時返回 {\"error\": \"...\", \"details\": \"...\"}\n        \"\"\"\n        system_prompt = (\n            \"You are Ray's quant logic unit. Tina Architecture Edition. \"\n            \"Always output valid JSON. No natural language.\"\n        )\n\n        messages = [\n            {\"role\": \"system\", \"content\": system_prompt},\n            {\"role\": \"user\", \"content\": f\"Context:\\n{context_data}\\n\\nTask:\\n{prompt}\"}\n        ]\n\n        payload = {\n            \"model\":      self.model,\n            \"messages\":   messages,\n            \"temperature\": 0.1,\n            \"stream\":     False,\n        }\n\n        try:\n            resp = requests.post(self.url, json=payload, timeout=60)\n            resp.raise_for_status()\n            content = resp.json()[\"choices\"][0][\"message\"][\"content\"]\n\n            # NL2Code 驗證：嘗試解析為 JSON\n            json.loads(content)\n            return content\n\n        except requests.exceptions.ConnectionError:\n            return '{\"error\": \"Ollama not running\", \"details\": \"Start ollama serve or check localhost:11434\"}'\n        except json.JSONDecodeError:\n            return f'{{\"error\": \"Invalid JSON from model\", \"details\": \"{content[:200]}\"}}'\n        except Exception as e:\n            return f'{{\"error\": \"Bridge failure\", \"details\": \"{str(e)}\"}}'\n\n    def batch_ask(self, tasks: list) -> list:\n        \"\"\"批量查詢\"\"\"\n        return [self.ask_logic(t[\"prompt\"], t.get(\"context\", \"\")) for t in tasks]\n\n\nif __name__ == \"__main__\":\n    bridge = TinaBridge()\n\n    sample_data = \"\"\"\n    Stock: NVDA\n    Price: $920\n    RSI(14): 28.5\n    Foreign Net Buy (5D): +5000 shares\n    EMA12: 905 | EMA144: 870 | EMA169: 862\n    Tunnel: BULL (ema144 > ema169, price breakout above ema144)\n    Sharpe(30d): 1.8\n    MDD(30d): 0.08\n    WinRate(30d): 0.55\n    \"\"\"\n\n    result = bridge.ask_logic(\n        \"根據以上數據，輸出嚴格的策略 JSON\",\n        sample_data\n    )\n    print(result)\n\n    parsed = json.loads(result)\n    print(f\"\\nStrategy: {parsed.get('strategy_name', 'N/A')}\")\n    print(f\"Indicator: {parsed.get('indicator', 'N/A')}\")\n    print(f\"Stop Loss: {parsed.get('stop_loss', 'N/A')}\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\tina_bridge.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":280,"output":883,"cacheRead":74432,"cacheWrite":0,"totalTokens":75595,"cost":{"input":0.000084,"output":0.0010596,"cacheRead":0.00446592,"cacheWrite":0,"total":0.00560952}},"stopReason":"toolUse","timestamp":1778514151633,"responseId":"06512bf470d482eaf9d58b253366c763"}}
