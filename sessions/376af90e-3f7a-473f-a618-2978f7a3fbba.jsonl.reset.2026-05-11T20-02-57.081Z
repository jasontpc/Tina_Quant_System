{"type":"message","id":"32373b12","parentId":"6bbccf31","timestamp":"2026-05-11T19:54:00.788Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me just overwrite the file with the correct content directly using write tool. The file encoding issues are problematic. Let me create a clean version.\n","thinkingSignature":"f5bb2c58698f1d148e53754b5d0892dad59cfe9108c5a451792ebe9c90639d2c"},{"type":"toolCall","id":"call_function_bbhugcxr96qq_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"Ray Brain - Qwen 路由层 + 本地脚本协调器\"\"\"\n\nimport json, re, sqlite3, time\nfrom typing import Dict, List, Optional\n\nBASE_URL = \"http://localhost:11434/api/chat\"\n\ntry:\n    from ray_data_center import RayDataCenter\n    from ray_engine import RayEngine\n    from ray_nl2code import NL2CodeValidator\n    HAS_RAY = True\nexcept ImportError:\n    HAS_RAY = False\n\n\nclass RayBrain:\n    def __init__(self):\n        self.fast_model = \"ray-v1\"      # Qwen 1.5B\n        self.deep_model = \"qwen2.5:7b\"  # Qwen 7B (will use ray-deep-v1 after model ready)\n        self.db = RayDataCenter() if HAS_RAY else None\n        self.engine = RayEngine() if HAS_RAY else None\n        self.validator = NL2CodeValidator() if HAS_RAY else None\n\n    # ===== Layer 1: Local Python (no LLM) =====\n    def local_indicators(self, symbol: str) -> Dict:\n        \"\"\"用本地 Python 计算技术指标（不需要 LLM）\"\"\"\n        if not HAS_RAY:\n            return {\"error\": \"ray modules not available\"}\n\n        try:\n            import yfinance as yf\n            df = yf.Ticker(symbol).history(period=\"60d\", interval=\"1d\", auto_adjust=True)\n            if df is None or len(df) < 20:\n                return {\"symbol\": symbol, \"error\": \"insufficient data\"}\n\n            close = df[\"Close\"].values.astype(float)\n            high  = df[\"High\"].values.astype(float)\n            low   = df[\"Low\"].values.astype(float)\n\n            # EMA calculation\n            def ema(c, n):\n                e = [c[0]] * len(c)\n                a = 2 / (n + 1)\n                for i in range(1, len(c)):\n                    e[i] = c[i] * a + e[i - 1] * (1 - a)\n                return e\n\n            m20 = ema(close, 20)\n            m60 = ema(close, 60)\n            ef  = ema(close, 12)\n            es  = ema(close, 26)\n            mac = [ef[i] - es[i] for i in range(len(ef))]\n            sigv = ema(mac, 9)\n            mh = [mac[i] - sigv[i] for i in range(len(mac))]\n\n            # RSI\n            d = [0] + [close[i] - close[i - 1] for i in range(1, len(close))]\n            g = [max(d[i], 0) for i in range(len(d))]\n            l = [max(-d[i], 0) for i in range(len(d))]\n            ag = list(g)\n            al = list(l)\n            for i in range(1, len(ag)):\n                ag[i] = (ag[i - 1] * 13 + g[i]) / 14\n                al[i] = (al[i - 1] * 13 + l[i]) / 14\n            rs = [ag[i] / max(al[i], 1e-10) for i in range(len(ag))]\n            rsi = [100 - (100 / (1 + rs[i])) for i in range(len(rs))]\n\n            # KDJ\n            k_arr = [50] * len(close)\n            d_arr = [50] * len(close)\n            for i in range(8, len(close)):\n                lo = min(low[max(0, i - 8):i + 1])\n                hi = max(high[max(0, i - 8):i + 1])\n                if hi > lo:\n                    k_arr[i] = (close[i] - lo) / (hi - lo) * 100\n                d_arr[i] = sum(k_arr[max(9, i - 8):i + 1]) / 9\n            j_arr = [3 * k_arr[i] - 2 * d_arr[i] for i in range(len(k_arr))]\n\n            # Momentum\n            mom5  = (close[-1] - close[-6]) / close[-6] * 100 if len(close) > 5 else 0\n            mom20 = (close[-1] - close[-21]) / close[-21] * 100 if len(close) > 20 else 0\n\n            # Rolling stats (Sharpe/MDD via engine)\n            stats = {}\n            if self.engine:\n                try:\n                    stats = self.engine.calc_rolling_stats(df, window=30)\n                except:\n                    pass\n\n            p = float(close[-1])\n            math_passed = (\n                (stats.get(\"sharpe\") or 0) >= 1.5 and\n                (stats.get(\"mdd\") or 999) <= 0.15 and\n                (stats.get(\"win_rate\") or 0) >= 0.45\n            )\n\n            return {\n                \"symbol\":       symbol,\n                \"price\":        round(p, 2),\n                \"ema20\":        round(m20[-1], 2),\n                \"ema60\":        round(m60[-1], 2),\n                \"macd_hist\":    round(mh[-1], 4),\n                \"rsi14\":        round(rsi[-1], 1),\n                \"kdj_j\":        round(j_arr[-1], 1),\n                \"mom_5d\":       round(mom5, 2),\n                \"mom_20d\":      round(mom20, 2),\n                \"sharpe_30d\":   stats.get(\"sharpe\"),\n                \"mdd_30d\":      stats.get(\"mdd\"),\n                \"win_rate_30d\":  stats.get(\"win_rate\"),\n                \"above_ma20\":   p > m20[-1],\n                \"above_ma60\":   p > m60[-1],\n                \"macd_bull\":    mh[-1] > 0,\n                \"kdj_bull\":     20 < j_arr[-1] < 85,\n                \"math_passed\":  math_passed,\n            }\n        except Exception as e:\n            return {\"symbol\": symbol, \"error\": str(e)}\n\n    # ===== Layer 2: Qwen 1.5B - Fast Proposal =====\n    def fast_propose(self, indicators: Dict, model: str = None) -> Dict:\n        \"\"\"用 1.5B 对已计算的指标快速输出策略 JSON\"\"\"\n        model = model or self.fast_model\n\n        gate = \"PASSED\" if indicators.get(\"math_passed\") else \"FAILED\"\n        ctx = (\n            f\"Symbol: {indicators.get('symbol', 'N/A')}\\n\"\n            f\"Price: ${indicators.get('price', 'N/A')}\\n\"\n            f\"EMA20: {indicators.get('ema20')} | EMA60: {indicators.get('ema60')}\\n\"\n            f\"MACD Hist: {indicators.get('macd_hist')} | RSI: {indicators.get('rsi14')}\\n\"\n            f\"KDJ J: {indicators.get('kdj_j')} | Mom 5D: {indicators.get('mom_5d')}%\\n\"\n            f\"Sharpe: {indicators.get('sharpe_30d')} | MDD: {indicators.get('mdd_30d')} | Win: {indicators.get('win_rate_30d')}\\n\"\n            f\"Math Gate: {gate}\"\n        )\n\n        payload = {\n            \"model\":      model,\n            \"messages\": [\n                {\"role\": \"system\", \"content\": \"Output ONLY valid JSON. No text.\"},\n                {\"role\": \"user\",   \"content\": f\"Data:\\n{ctx}\\n\\nTask: Output strategy JSON\"}\n            ],\n            \"temperature\": 0.1,\n            \"stream\":     False,\n        }\n\n        try:\n            import requests\n            resp = requests.post(BASE_URL, json=payload, timeout=30)\n            resp.raise_for_status()\n            text = self._extract_json(resp.json()[\"message\"][\"content\"])\n            result = json.loads(text)\n\n            # NL2Code 二次验证\n            if self.validator:\n                is_valid, _, errs = self.validator.validate(result)\n                if not is_valid:\n                    return {\"error\": f\"NL2Code rejected: {errs[0]}\", \"raw\": text[:200]}\n\n            return result\n        except Exception as e:\n            return {\"error\": f\"fast_propose: {str(e)[:100]}\"}\n\n    # ===== Layer 3: Qwen 7B - Deep Analysis =====\n    def deep_analysis(self, symbol: str, context: str = \"\") -> Dict:\n        \"\"\"用 7B 做深度归因分析\"\"\"\n        payload = {\n            \"model\":      self.deep_model,\n            \"messages\": [\n                {\"role\": \"system\", \"content\": \"Output JSON with rationale field.\"},\n                {\"role\": \"user\",   \"content\": f\"Symbol: {symbol}\\n\\nContext:\\n{context}\\n\\nTask: Deep analysis\"}\n            ],\n            \"temperature\": 0.2,\n            \"stream\":     False,\n        }\n\n        try:\n            import requests\n            resp = requests.post(BASE_URL, json=payload, timeout=300)\n            resp.raise_for_status()\n            text = self._extract_json(resp.json()[\"message\"][\"content\"])\n            return json.loads(text)\n        except Exception as e:\n            return {\"error\": f\"deep_analysis: {str(e)[:100]}\"}\n\n    # ===== End-to-End: Scan + Propose =====\n    def scan_and_propose(self, symbols: List[str]) -> List[Dict]:\n        \"\"\"\n        完整流程：\n        1. 本地计算指标（us_momentum 等效）\n        2. 数学把关筛选\n        3. Qwen 1.5B 快速策略提案\n        4. 结果写入 SQLite\n        \"\"\"\n        results = []\n        for sym in symbols:\n            ind = self.local_indicators(sym)\n            if \"error\" in ind:\n                results.append({\"symbol\": sym, \"error\": ind[\"error\"]})\n                continue\n\n            if not ind.get(\"math_passed\"):\n                results.append({\n                    \"symbol\": sym,\n                    \"price\":  ind.get(\"price\"),\n                    \"score\":  0,\n                    \"tag\":   \"NEUT\",\n                    \"reason\": \"math_gate_failed\",\n                    \"indicators\": ind,\n                })\n                continue\n\n            strategy = self.fast_propose(ind)\n            score = self._calc_score(ind)\n            tag = \"BUY\" if score >= 3 else \"WATCH\"\n\n            if self.db:\n                try:\n                    self.db.log_signal(\n                        symbol     = sym,\n                        source     = \"brain_scan\",\n                        score      = float(score),\n                        sharpe     = ind.get(\"sharpe_30d\"),\n                        mdd        = ind.get(\"mdd_30d\"),\n                        win_rate   = ind.get(\"win_rate_30d\"),\n                        signal_tag = tag,\n                    )\n                except Exception as e:\n                    pass\n\n            results.append({\n                \"symbol\":     sym,\n                \"price\":      ind.get(\"price\"),\n                \"score\":      score,\n                \"tag\":        tag,\n                \"strategy\":   strategy,\n                \"indicators\": ind,\n            })\n\n        return results\n\n    def _calc_score(self, ind: Dict) -> int:\n        \"\"\"计算多空评分（5分制）\"\"\"\n        s = 0\n        if ind.get(\"above_ma20\"): s += 1\n        if ind.get(\"above_ma60\"): s += 1\n        if ind.get(\"macd_bull\"):  s += 1\n        if ind.get(\"kdj_bull\"):   s += 1\n        if ind.get(\"math_passed\"): s += 1\n        return min(s, 5)\n\n    def _extract_json(self, text: str) -> str:\n        \"\"\"从任意文字提取第一个 JSON 区块\"\"\"\n        text = text.strip()\n        m = re.search(r\"```(?:\\w+)?\\s*([\\s\\S]*?)```\", text)\n        if m:\n            try:\n                json.loads(m.group(1).strip())\n                return m.group(1).strip()\n            except:\n                pass\n        start = text.find(\"{\")\n        end = text.rfind(\"}\") + 1\n        if start >= 0 and end > start:\n            try:\n                json.loads(text[start:end])\n                return text[start:end]\n            except:\n                pass\n        return text\n\n    @property\n    def stats(self) -> Dict:\n        \"\"\"Ray 系统状态\"\"\"\n        if not self.db:\n            return {\"status\": \"db unavailable\"}\n        sig_stats = self.db.get_signal_stats()\n        wids = self.db.get_wisdom_logs(limit=100)\n        bts = self.db.get_recent_backtests(days=7)\n        approved = [b for b in bts if b.get(\"passed\")]\n        return {\n            \"signals\":        f\"{sig_stats['approved_signals']}/{sig_stats['total_signals']} approved\",\n            \"wisdom_logs\":    len(wids),\n            \"failed_wisdoms\": len([w for w in wids if not w.get(\"passed\")]),\n            \"backtests_7d\":   len(bts),\n            \"approved_bt\":    len(approved),\n        }\n\n\nif __name__ == \"__main__\":\n    brain = RayBrain()\n    print(\"=== Local Indicators (NVDA) ===\")\n    ind = brain.local_indicators(\"NVDA\")\n    print(f\"NVDA: price={ind.get('price')}, RSI={ind.get('rsi14')}, Sharpe={ind.get('sharpe_30d')}, Math={ind.get('math_passed')}\")\n\n    print(\"\\n=== Brain Stats ===\")\n    print(brain.stats)","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_brain.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":395,"output":3109,"cacheRead":139200,"cacheWrite":0,"totalTokens":142704,"cost":{"input":0.0001185,"output":0.0037308,"cacheRead":0.008352,"cacheWrite":0,"total":0.0122013}},"stopReason":"toolUse","timestamp":1778527305325,"responseId":"06515f4b5d82aa8aa1a1a1064f46b530"}}
