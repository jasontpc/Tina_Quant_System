{"type":"message","id":"01787de5","parentId":"62533291","timestamp":"2026-05-11T12:23:19.516Z","message":{"role":"toolResult","toolCallId":"call_function_hq3kd925crya_1","toolName":"read","content":[{"type":"text","text":"import sys\nimport os\nsys.path.insert(0, r'C:\\Users\\USER\\.openclaw\\workspace\\Tina_Quant_System\\teams\\tina_v3_alpha')\nos.environ['PYTHONIOENCODING'] = 'utf-8'\n\nfrom tina_v3_alpha_live import execute_logic, SYMBOLS, send_telegram\nfrom datetime import datetime\n\nts = datetime.now().strftime('%Y-%m-%d %H:%M')\nhits = []\nfails = []\n\nfor sym in SYMBOLS:\n    try:\n        ok = execute_logic(sym)\n        if ok:\n            hits.append(sym)\n    except Exception as e:\n        fails.append(f'{sym}:{e}')\n\nif hits:\n    msg = f\"📡 *Tina V3 Alpha 定時掃描 {ts}*\\n\"\n    msg += f\"━━━━━━━━━━━━━━━\\n\"\n    msg += f\"🚀 觸發進場：{', '.join(hits)}\\n\"\n    msg += f\"━━━━━━━━━━━━━━━\\n\"\n    msg += f\"失敗:{len(fails)} 檔 | 總掃描:{len(SYMBOLS)} 檔\"\n    send_telegram(msg)\nelse:\n    print(f'[{ts}] 本輪無訊號 ({len(SYMBOLS)}檔)')"}],"isError":false,"timestamp":1778502199516}}
