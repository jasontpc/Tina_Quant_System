{"type":"message","id":"42916d8b","parentId":"6d242717","timestamp":"2026-05-11T13:49:49.572Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The script runs but prints nothing for individual stocks. The issue might be with the yfinance history call returning fewer rows than 120. Let me try reducing the period threshold to 60 and also catch errors better.\n","thinkingSignature":"3ae68c08223c59723f3644cef41c09f85cbfbc2955fbc5047e5e615abd6db0dc"},{"type":"toolCall","id":"call_function_7nvu34842jz8_1","name":"write","arguments":{"content":"import sys, yfinance as yf, numpy as np\nfrom datetime import datetime\nsys.stdout.reconfigure(encoding='utf-8')\nimport warnings; warnings.filterwarnings('ignore')\n\ndef ema(c, n):\n    e = np.zeros(len(c)); e[0] = c[0]; a = 2/(n+1)\n    for i in range(1, len(c)): e[i] = c[i]*a + e[i-1]*(1-a)\n    return e\n\ndef kdj(h, l, c, n=9):\n    k = np.zeros_like(c); d = np.zeros_like(c)\n    for i in range(n-1, len(c)):\n        ln = np.min(l[i-n+1:i+1]); hn = np.max(h[i-n+1:i+1])\n        k[i] = 50 if hn == ln else (c[i]-ln)/(hn-ln)*100\n        d[i] = np.mean(k[max(n, i-n+1):i+1])\n    return 3*k - 2*d\n\ndef rsi_calc(c):\n    d = np.diff(c, prepend=c[0])\n    g = np.where(d > 0, d, 0.); l = np.where(d < 0, -d, 0.)\n    ag = g.copy(); al = l.copy()\n    for i in range(1, len(ag)): ag[i] = (ag[i-1]*13+g[i])/14; al[i] = (al[i-1]*13+l[i])/14\n    return float(100 - (100 / (1 + ag[-1]/max(al[-1], 1e-10))))\n\nsyms = [\"NVDA\",\"AMD\",\"AVGO\",\"ASML\",\"AMAT\",\"LRCX\",\"MU\",\"INTC\",\"QCOM\",\"META\",\"AAPL\",\"MSFT\",\"GOOGL\",\"KLAC\",\"TER\",\"SNPS\",\"CDNS\",\"NXPI\",\"MRVL\",\"ADI\",\"ON\",\"QQQ\"]\n\nprint(f\"📊 US Tech 報價 {datetime.now().strftime('%Y-%m-%d %H:%M')}\")\nprint(f\"{'Ticker':<8}{'Price':>9}{'MA20':>9}{'MA60':>9}{'RSI':>7}{'MACD':>9}{'J':>8} S\")\nprint(\"-\"*70)\n\nres = []\nfor sym in syms:\n    try:\n        tk = yf.Ticker(sym)\n        df = tk.history(period=\"6mo\", interval=\"1d\", auto_adjust=True, timeout=10)\n        if df is None or len(df) < 60:\n            print(f\"{sym:<8} insufficient data ({len(df) if df is not None else 0})\")\n            continue\n        \n        c = df['Close'].values.astype(float)\n        h = df['High'].values.astype(float)\n        l = df['Low'].values.astype(float)\n        \n        m20 = ema(c, 20); m60 = ema(c, 60)\n        ef = ema(c, 12); es = ema(c, 26)\n        mac = ef - es; sig = ema(mac, 9); mh = mac - sig\n        j_arr = kdj(h, l, c); j0 = j_arr[-1]; j1 = j_arr[-2]\n        rs = rsi_calc(c)\n        p = c[-1]\n        \n        bull = 0\n        if p > m20[-1]: bull += 1\n        if p > m60[-1]: bull += 1\n        if mh[-1] > 0: bull += 1\n        if j0 > j1 and 10 < j0 < 85: bull += 1\n        \n        tag = \"🟢\" if bull >= 3 else \"🟡\" if bull == 2 else \"⚪\"\n        print(f\"{sym:<8}{p:>9.2f}{m20[-1]:>9.2f}{m60[-1]:>9.2f}{rs:>7.1f}{mh[-1]:>9.3f}{j0:>8.1f} {tag}\")\n        res.append((sym, p, rs, j0, mh[-1], bull))\n    except Exception as e:\n        print(f\"{sym:<8} error: {e}\")\n\nprint()\nb = sorted([(s,p,r,j,h,b) for s,p,r,j,h,b in res if b >= 3], key=lambda x: -x[5])\nif b:\n    lines = [f\"  {s} ${p:.2f} RSI={r:.1f} J={j:.1f} MACD={h:.3f}\" for s,p,r,j,h,b in b]\n    print(f\"🟢 BUY ({len(b)}):\\n\" + \"\\n\".join(lines))\nelse:\n    print(\"🟢 BUY: none\")\n\nw = sorted([(s,p,r,j,h,b) for s,p,r,j,h,b in res if b == 2], key=lambda x: -x[2])\nif w:\n    print(f\"\\n🟡 WATCH ({len(w)}): \" + \", \".join(f\"{s}({p:.1f})\" for s,p,_,_,_,_ in w))","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\us_scan_live.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":155,"output":1249,"cacheRead":102208,"cacheWrite":0,"totalTokens":103612,"cost":{"input":0.0000465,"output":0.0014988,"cacheRead":0.006132479999999999,"cacheWrite":0,"total":0.0076777799999999995}},"stopReason":"toolUse","timestamp":1778507346820,"responseId":"06511155ebb863939b27acfe7765631b"}}
