{"type":"message","id":"4c37bb3d","parentId":"cf4451bd","timestamp":"2026-05-11T19:20:25.117Z","message":{"role":"toolResult","toolCallId":"call_function_gpzqt7e8qsdi_1","toolName":"exec","content":[{"type":"text","text":"# -*- coding: utf-8 -*-\r\n\"\"\"\r\nRay Brain ??Qwen 頝舐撅?+ ?砍?單?矽??Level 3嚗???Python ????蝞?Qwen 鞎痊?圾????\r\n撌乩??極嚗?  ?砍 Python  ???? ??閮??摮豢??QLite ????銝?閬?LLM嚗?  Qwen 1.5B   ???? ?單?蝑???翰??JSON ?澆???< 5 蝘?\r\n  Qwen 7B     ???? 瘛勗漲甇詨????仿脣???蝺????閬???\r\n\r\n雿輻蝭?嚗?  brain = RayBrain()\r\n\r\n  # 敹恍芋撘?1.5B嚗?us_momentum ??∠巨 ??蝑 JSON\r\n  result = brain.scan_and_propose(symbols=[\"NVDA\",\"AMD\",\"META\"])\n\n(Command exited with code 1)"}],"details":{"status":"completed","exitCode":1,"durationMs":356,"aggregated":"# -*- coding: utf-8 -*-\r\n\"\"\"\r\nRay Brain ??Qwen 頝舐撅?+ ?砍?單?矽??Level 3嚗???Python ????蝞?Qwen 鞎痊?圾????\r\n撌乩??極嚗?  ?砍 Python  ???? ??閮??摮豢??QLite ????銝?閬?LLM嚗?  Qwen 1.5B   ???? ?單?蝑???翰??JSON ?澆???< 5 蝘?\r\n  Qwen 7B     ???? 瘛勗漲甇詨????仿脣???蝺????閬???\r\n\r\n雿輻蝭?嚗?  brain = RayBrain()\r\n\r\n  # 敹恍芋撘?1.5B嚗?us_momentum ??∠巨 ??蝑 JSON\r\n  result = brain.scan_and_propose(symbols=[\"NVDA\",\"AMD\",\"META\"])\n\n(Command exited with code 1)","cwd":"C:\\Users\\USER\\.openclaw\\agents\\ray"},"isError":false,"timestamp":1778527225117}}
{"type":"message","id":"ae288e54","parentId":"4c37bb3d","timestamp":"2026-05-11T19:21:37.101Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a character encoding issue. The file has garbled Chinese characters. Let me rewrite the file directly with ASCII-safe content.\n","thinkingSignature":"a2532a4b5618cc5f5a3f34540f37a22bfe333c43fd295fdbe96024c995c070b6"},{"type":"toolCall","id":"call_function_fqbtupjmu2yh_1","name":"exec","arguments":{"command":"cd C:\\Users\\USER\\.openclaw\\agents\\ray; python -c \"\ncontent = '''# -*- coding: utf-8 -*-\n\\\"\\\"\\\"Ray Brain - Qwen Router + Local Script Coordinator\\\"\\\"\\\"\n\nimport json, re, sqlite3, time\nfrom typing import Dict, List, Optional\n\nBASE_URL = 'http://localhost:11434/api/chat'\n\ntry:\n    from ray_data_center import RayDataCenter\n    from ray_engine import RayEngine\n    from ray_nl2code import NL2CodeValidator\n    HAS_RAY = True\nexcept ImportError:\n    HAS_RAY = False\n\n\nclass RayBrain:\n    def __init__(self):\n        self.fast_model = 'ray-v1'\n        self.deep_model = 'qwen2.5:7b'\n        self.db = RayDataCenter() if HAS_RAY else None\n        self.engine = RayEngine() if HAS_RAY else None\n        self.validator = NL2CodeValidator() if HAS_RAY else None\n\n    # === Layer 1: Local Python (no LLM) ===\n    def local_indicators(self, symbol: str) -> Dict:\n        if not HAS_RAY:\n            return {'error': 'ray_engine not available'}\n        try:\n            import yfinance as yf\n            df = yf.Ticker(symbol).history(period='60d', interval='1d', auto_adjust=True)\n            if df is None or len(df) < 20:\n                return {'error': 'insufficient data'}\n\n            close = df['Close'].values.astype(float)\n            high  = df['High'].values.astype(float)\n            low   = df['Low'].values.astype(float)\n\n            def ema(c, n):\n                e = [c[0]] * len(c); a = 2/(n+1)\n                for i in range(1,len(c)): e[i] = c[i]*a + e[i-1]*(1-a)\n                return e\n\n            m20 = ema(close, 20); m60 = ema(close, 60)\n            ef = ema(close, 12); es = ema(close, 26)\n            mac = [ef[i]-es[i] for i in range(len(ef))]\n            sigv = ema(mac, 9)\n            mh = [mac[i]-sigv[i] for i in range(len(mac))]\n\n            d = [0] + [close[i]-close[i-1] for i in range(1,len(close))]\n            g = [max(d[i],0) for i in range(len(d))]\n            l = [max(-d[i],0) for i in range(len(d))]\n            ag=g.copy(); al=l.copy()\n            for i in range(1,len(ag)): ag[i]=(ag[i-1]*13+g[i])/14; al[i]=(al[i-1]*13+l[i])/14\n            rs = [ag[i]/max(al[i],1e-10) for i in range(len(ag))]\n            rsi = [100-(100/(1+rs[i])) for i in range(len(rs))]\n\n            k_arr=[50]*len(close); d_arr=[50]*len(close)\n            for i in range(8,len(close)):\n                lo = min(low[max(0,i-8):i+1]); hi = max(high[max(0,i-8):i+1])\n                if hi>lo: k_arr[i]=(close[i]-lo)/(hi-lo)*100\n                d_arr[i]=sum(k_arr[max(9,i-8):i+1])/9\n            j_arr=[3*k_arr[i]-2*d_arr[i] for i in range(len(k_arr))]\n\n            mom5  = (close[-1]-close[-6])/close[-6]*100 if len(close)>5 else 0\n            mom20 = (close[-1]-close[-21])/close[-21]*100 if len(close)>20 else 0\n\n            stats = self.engine.calc_rolling_stats(df, 30) if self.engine else {}\n\n            p = float(close[-1])\n            return {\n                'symbol':      symbol,\n                'price':       round(p, 2),\n                'ema20':       round(m20[-1], 2),\n                'ema60':       round(m60[-1], 2),\n                'macd_hist':   round(mh[-1], 4),\n                'rsi14':       round(rsi[-1], 1),\n                'kdj_j':       round(j_arr[-1], 1),\n                'mom_5d':      round(mom5, 2),\n                'mom_20d':     round(mom20, 2),\n                'sharpe_30d':  stats.get('sharpe'),\n                'mdd_30d':     stats.get('mdd'),\n                'win_rate_30d':stats.get('win_rate'),\n                'above_ma20':  p > m20[-1],\n                'above_ma60':  p > m60[-1],\n                'macd_bull':   mh[-1] > 0,\n                'kdj_bull':    j_arr[-1] > 20 and j_arr[-1] < 85,\n                'math_passed': (\n                    (stats.get('sharpe') or 0) >= 1.5 and\n                    (stats.get('mdd') or 999) <= 0.15 and\n                    (stats.get('win_rate') or 0) >= 0.45\n                ),\n            }\n        except Exception as e:\n            return {'symbol': symbol, 'error': str(e)}\n\n    # === Layer 2: Qwen 1.5B - Fast Proposal ===\n    def fast_propose(self, indicators: Dict, model: str = None) -> Dict:\n        model = model or self.fast_model\n        ctx = (\n            f\\\"Symbol: {indicators.get('symbol','N/A')}\\\\n\\\"\n            f\\\"Price: \\\\${indicators.get('price','N/A')}\\\\n\\\"\n            f\\\"EMA20: {indicators.get('ema20')} | EMA60: {indicators.get('ema60')}\\\\n\\\"\n            f\\\"MACD Hist: {indicators.get('macd_hist')} | RSI: {indicators.get('rsi14')}\\\\n\\\"\n            f\\\"KDJ J: {indicators.get('kdj_j')} | Mom 5D: {indicators.get('mom_5d')}%\\\\n\\\"\n            f\\\"Sharpe: {indicators.get('sharpe_30d')} | MDD: {indicators.get('mdd_30d')}\\\\n\\\"\n            f\\\"Math Gate: {'PASSED' if indicators.get('math_passed') else 'FAILED'}\\\"\n        )\n        payload = {\n            'model': model,\n            'messages': [\n                {'role': 'system', 'content': 'Output ONLY JSON. No text.'},\n                {'role': 'user', 'content': f\\\"Data:\\\\n{ctx}\\\\n\\\\nTask: Output strategy JSON\\\"}\n            ],\n            'temperature': 0.1,\n            'stream': False,\n        }\n        try:\n            import requests\n            resp = requests.post(BASE_URL, json=payload, timeout=30)\n            resp.raise_for_status()\n            text = self._extract_json(resp.json()['message']['content'])\n            result = json.loads(text)\n            if self.validator:\n                is_valid, _, errs = self.validator.validate(result)\n                if not is_valid:\n                    return {'error': f'NL2Code rejected: {errs[0]}'}\n            return result\n        except Exception as e:\n            return {'error': f'fast_propose: {str(e)[:100]}'}\n\n    # === Layer 3: Qwen 7B - Deep Analysis ===\n    def deep_analysis(self, symbol: str, context: str = '') -> Dict:\n        payload = {\n            'model': self.deep_model,\n            'messages': [\n                {'role': 'system', 'content': 'Output JSON with rationale.'},\n                {'role': 'user', 'content': f\\\"Symbol: {symbol}\\\\n\\\\nContext:\\\\n{context}\\\\n\\\\nTask: Deep analysis\\\"}\n            ],\n            'temperature': 0.2,\n            'stream': False,\n        }\n        try:\n            import requests\n            resp = requests.post(BASE_URL, json=payload, timeout=300)\n            resp.raise_for_status()\n            text = self._extract_json(resp.json()['message']['content'])\n            return json.loads(text)\n        except Exception as e:\n            return {'error': f'deep_analysis: {str(e)[:100]}'}\n\n    # === End-to-end: Scan + Propose ===\n    def scan_and_propose(self, symbols: List[str]) -> List[Dict]:\n        results = []\n        for sym in symbols:\n            ind = self.local_indicators(sym)\n            if 'error' in ind:\n                results.append({'symbol': sym, 'error': ind['error']})\n                continue\n            if not ind.get('math_passed'):\n                results.append({'symbol': sym, 'price': ind.get('price'), 'score': 0, 'tag': 'NEUT', 'reason': 'math_gate_failed'})\n                continue\n            strategy = self.fast_propose(ind)\n            score = self._calc_score(ind)\n            tag = 'BUY' if score >= 3 else 'WATCH'\n            if self.db:\n                self.db.log_signal(sym, 'brain_scan', score, ind.get('sharpe_30d'), ind.get('mdd_30d'), ind.get('win_rate_30d'), tag)\n            results.append({'symbol': sym, 'price': ind.get('price'), 'score': score, 'tag': tag, 'strategy': strategy})\n        return results\n\n    def _calc_score(self, ind: Dict) -> int:\n        s = 0\n        if ind.get('above_ma20'): s += 1\n        if ind.get('above_ma60'): s += 1\n        if ind.get('macd_bull'):  s += 1\n        if ind.get('kdj_bull'):   s += 1\n        if ind.get('math_passed'): s += 1\n        return min(s, 5)\n\n    def _extract_json(self, text: str) -> str:\n        text = text.strip()\n        m = re.search(r'```(?:\\\\w+)?\\\\s*([\\\\s\\\\S]*?)```', text)\n        if m:\n            try: json.loads(m.group(1).strip()); return m.group(1).strip()\n            except: pass\n        start = text.find('{'); end = text.rfind('}') + 1\n        if start >= 0 and end > start:\n            try: json.loads(text[start:end]); return text[start:end]\n            except: pass\n        return text\n\n    @property\n    def stats(self) -> Dict:\n        if not self.db: return {'status': 'db unavailable'}\n        s = self.db.get_signal_stats()\n        wids = self.db.get_wisdom_logs(limit=100)\n        bts = self.db.get_recent_backtests(days=7)\n        return {\n            'signals': f\\\"{s['approved_signals']}/{s['total_signals']} approved\\\",\n            'wisdom_logs': len(wids),\n            'failed_wisdoms': len([w for w in wids if not w.get('passed')]),\n            'recent_backtests': len(bts),\n            'approved_backtests': len([b for b in bts if b.get('passed')]),\n        }\n\n\nif __name__ == '__main__':\n    brain = RayBrain()\n    print('=== Local Indicators ===')\n    ind = brain.local_indicators('NVDA')\n    print(f\\\"NVDA: price={ind.get('price')}, RSI={ind.get('rsi14')}, Sharpe={ind.get('sharpe_30d')}\\\")\n    print('\\\\n=== Brain Stats ===')\n    print(brain.stats)\n'''\nwith open('ray_brain.py', 'w', encoding='utf-8') as f:\n    f.write(content)\nprint('Done')\n\"","timeout":"15"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":537,"output":2706,"cacheRead":135872,"cacheWrite":0,"totalTokens":139115,"cost":{"input":0.00016109999999999999,"output":0.0032472,"cacheRead":0.00815232,"cacheWrite":0,"total":0.011560619999999999}},"stopReason":"toolUse","timestamp":1778527225123,"responseId":"06515efd831f64a0ae1a558102f7a061"}}
