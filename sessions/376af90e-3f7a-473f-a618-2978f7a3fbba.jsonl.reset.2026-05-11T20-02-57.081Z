{"type":"message","id":"75e6b7a8","parentId":"4d4ec808","timestamp":"2026-05-11T19:54:00.788Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the evolution core and the upgraded scripts in parallel. Let me update the plan and write the evolution core.\n","thinkingSignature":"b7704bc1f02e4e9081f901af3bc1f5f5c3b0b188838c5419d2fe5348328f4c20"},{"type":"toolCall","id":"call_function_d1s4vsjdkzox_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nRay 進化核心 - Tina autonomous_learning_cycle 移植版\nAI 提案 → NL2Code 驗證 → 數學審核 → SQLite 永久存儲\n\n工作流：\n  1. LLM 根據市場數據生成策略提案（自然語言）\n  2. NL2Code 層拦截，強制轉為結構化 JSON\n  3. 回測引擎跑 Sharpe/MDD 把關\n  4. 通過 → 寫入 backtest_reports + signals_log\n     失敗 → 記錄失敗原因（供下次學習）\n\"\"\"\n\nimport json\nimport yfinance as yf\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime\nfrom typing import Dict, Optional, List, Tuple\n\nfrom .ray_data_center import RayDataCenter\nfrom .ray_engine import RayEngine\nfrom .ray_nl2code import NL2CodeValidator, sanitize_llm_output\n\n\n# ── 智慧協議模板（給 LLM 看的格式說明）────────────────────────────────\nWISDOM_PROMPT_TEMPLATE = \"\"\"你是 Ray 的策略進化引擎。\n根據以下市場數據，生成一個交易策略提案（JSON 格式）。\n\n約束：\n- strategy_name: 大寫 UPPER_SNAKE_CASE，3-30字\n- indicator: EMA_CROSS | VEGAS_TUNNEL | FOREIGN_BUY | MOMENTUM | KDJ_CROSS | RSI_THRESHOLD\n- params: 具體數字（不要用變量）\n- entry_condition: operator 是 > < >= <= CROSS_ABOVE CROSS_BELOW\n- stop_loss: 0.01-0.50（小數）\n- max_hold_days: 1-60\n\n輸出格式（只輸出 JSON，不要其他文字）：\n{\n    \"strategy_name\": \"EMA_CROSS_9_21\",\n    \"indicator\": \"EMA_CROSS\",\n    \"params\": {\"fast\": 9, \"slow\": 21},\n    \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n    \"stop_loss\": 0.08,\n    \"max_hold_days\": 10\n}\n\n市場數據摘要：\n{snippet}\n\"\"\"\n\n\nclass RayEvolutionCore:\n    \"\"\"\n    自主學習循環：提案 → 驗證 → 回測 → 存儲\n    \"\"\"\n\n    def __init__(self, db_path: str = None):\n        self.db     = RayDataCenter(db_path)\n        self.engine = RayEngine(market_type=\"US\", db_path=db_path)\n        self.validator = NL2CodeValidator()\n        self.learned_count   = 0\n        self.rejected_count  = 0\n\n    # ── 核心：自動學習循環（單檔）──────────────────────────────────\n    def autonomous_learning_cycle(self, symbol: str,\n                                   lookback_days: int = 730,\n                                   min_shappe: float = 1.5,\n                                   max_mdd: float = 0.15) -> Dict:\n        \"\"\"\n        對單一標的執行完整的自主學習循環\n\n        步驟：\n        1. 抓取歷史數據\n        2. 嘗試多個候選策略（網格搜索）\n        3. 每個策略經過 NL2Code + 回測把關\n        4. 最好且通過的把關策略寫入 DB\n\n        返回：{status, best_strategy, sharpe, mdd, ...}\n        \"\"\"\n        print(f\"[RayEvolution] Learning cycle for {symbol}...\")\n\n        # ── 抓數據 ───────────────────────────────────────────────\n        try:\n            df = yf.Ticker(symbol).history(period=f\"{lookback_days}d\",\n                                           interval=\"1d\", auto_adjust=True)\n            if df is None or len(df) < 200:\n                return {\"status\": \"error\", \"reason\": \"insufficient data\"}\n        except Exception as e:\n            return {\"status\": \"error\", \"reason\": str(e)}\n\n        # ── 網格候選參數（Ray 擅長的策略）──────────────────────────\n        candidates = []\n\n        # Vegas Tunnel\n        for ema_fast in [144, 169]:\n            for ema_slow in [576, 676]:\n                if ema_fast >= ema_slow: continue\n                candidates.append({\n                    \"strategy_name\": f\"VEGAS_TUNNEL_{ema_fast}_{ema_slow}\",\n                    \"indicator\": \"VEGAS_TUNNEL\",\n                    \"params\": {\"fast\": ema_fast, \"slow\": ema_slow},\n                    \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n                    \"stop_loss\": 0.08,\n                    \"max_hold_days\": 10,\n                })\n\n        # EMA Cross\n        for fast, slow in [(9, 21), (12, 26), (20, 60), (50, 200)]:\n            candidates.append({\n                \"strategy_name\": f\"EMA_CROSS_{fast}_{slow}\",\n                \"indicator\": \"EMA_CROSS\",\n                \"params\": {\"fast\": fast, \"slow\": slow},\n                \"entry_condition\": {\"operator\": \"CROSS_ABOVE\", \"threshold\": 0},\n                \"stop_loss\": 0.08,\n                \"max_hold_days\": 15,\n            })\n\n        # Momentum\n        for window in [5, 10, 20, 60]:\n            candidates.append({\n                \"strategy_name\": f\"MOMENTUM_{window}\",\n                \"indicator\": \"MOMENTUM\",\n                \"params\": {\"window\": window},\n                \"entry_condition\": {\"operator\": \">\", \"threshold\": 0.02},\n                \"stop_loss\": 0.10,\n                \"max_hold_days\": 20,\n            })\n\n        # ── NL2Code 驗證 + 回測把關 ─────────────────────────────────\n        passed_strategies = []\n        for axiom in candidates:\n            # NL2Code 驗證\n            is_valid, parsed, errors = self.validator.validate(axiom)\n            if not is_valid:\n                continue  # 格式不合，自動跳過\n\n            # 回測把關\n            report = self.engine.run_backtest(df, axiom)\n            if report[\"passed\"]:\n                passed_strategies.append({**report, \"axiom\": axiom})\n                backtest_id = self.db.log_backtest(\n                    strategy_name = axiom[\"strategy_name\"],\n                    symbol        = symbol,\n                    indicator     = axiom[\"indicator\"],\n                    params        = axiom[\"params\"],\n                    sharpe        = report[\"sharpe\"],\n                    mdd           = report[\"mdd\"],\n                    total_ret     = report[\"total_ret\"],\n                    win_rate      = report[\"win_rate\"],\n                    avg_return    = report[\"avg_return\"],\n                    num_trades    = report[\"num_trades\"],\n                    note          = f\"auto_learned | cost={report.get('cost_pct',0.15)}%\",\n                )\n                self.db.log_wisdom(\n                    axiom_json = json.dumps(axiom),\n                    reflection = f\"SHARP={report['sharpe']:.2f} MDD={report['mdd']:.2%} WIN={report['win_rate']:.1%}\",\n                    backtest_id = backtest_id,\n                )\n\n        # ── 選最佳策略 ─────────────────────────────────────────────\n        if passed_strategies:\n            best = sorted(passed_strategies, key=lambda x: -x[\"sharpe\"])[0]\n            self.learned_count += 1\n            print(f\"[RayEvolution] ✅ {symbol}: {len(passed_strategies)} passed, best Sharpe={best['sharpe']:.2f}\")\n            return {\n                \"status\":         \"success\",\n                \"symbol\":         symbol,\n                \"best_strategy\":  best[\"axiom\"][\"strategy_name\"],\n                \"indicator\":       best[\"axiom\"][\"indicator\"],\n                \"sharpe\":         best[\"sharpe\"],\n                \"mdd\":            best[\"mdd\"],\n                \"total_ret\":      best[\"total_ret\"],\n                \"win_rate\":       best[\"win_rate\"],\n                \"num_trades\":     best[\"num_trades\"],\n                \"passed_count\":   len(passed_strategies),\n            }\n        else:\n            self.rejected_count += 1\n            # 記錄失敗\n            self.db.log_wisdom(\n                axiom_json = json.dumps({\"symbol\": symbol, \"attempted\": len(candidates)}),\n                reflection = f\"No strategy passed (tried {len(candidates)})\",\n            )\n            print(f\"[RayEvolution] ❌ {symbol}: all {len(candidates)} strategies rejected\")\n            return {\n                \"status\":   \"rejected\",\n                \"symbol\":   symbol,\n                \"attempted\": len(candidates),\n            }\n\n    # ── 批量學習（多檔）────────────────────────────────────────────\n    def batch_learning(self, symbols: List[str], lookback_days: int = 730) -> List[Dict]:\n        results = []\n        for sym in symbols:\n            r = self.autonomous_learning_cycle(sym, lookback_days)\n            results.append(r)\n        return results\n\n    # ── 讀取已知的好策略（通過把關的）─────────────────────────────\n    def get_approved_strategies(self, limit: int = 20) -> List[Dict]:\n        return self.db.get_approved_backtests(limit=limit)\n\n    # ── 讀取近期學習摘要 ─────────────────────────────────────────\n    def get_learning_stats(self) -> Dict:\n        recent = self.db.get_recent_backtests(days=7)\n        approved = [r for r in recent if r.get(\"passed\")]\n        return {\n            \"total_learned\":   self.learned_count,\n            \"total_rejected\":  self.rejected_count,\n            \"recent_backtests\": len(recent),\n            \"recent_approved\":  len(approved),\n            \"avg_sharpe\":      round(sum(r[\"sharpe_ratio\"] for r in approved) / max(len(approved), 1), 2),\n            \"avg_mdd\":         round(sum(r[\"max_drawdown\"] for r in approved) / max(len(approved), 1), 4),\n        }\n\n\nif __name__ == \"__main__\":\n    core = RayEvolutionCore()\n    result = core.autonomous_learning_cycle(\"NVDA\", lookback_days=365)\n    print(f\"Result: {result}\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\ray_evolution.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":2126,"output":2286,"cacheRead":140544,"cacheWrite":0,"totalTokens":144956,"cost":{"input":0.0006378,"output":0.0027432,"cacheRead":0.00843264,"cacheWrite":0,"total":0.01181364}},"stopReason":"toolUse","timestamp":1778511123790,"responseId":"065120173e6b160d92a59f23a8b9c4cc"}}
