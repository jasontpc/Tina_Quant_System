{"type":"message","id":"045c381c","parentId":"4d1898ec","timestamp":"2026-05-11T19:54:00.788Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The file got corrupted - the Chinese characters got garbled. Let me rewrite it cleanly.\n","thinkingSignature":"cbbc51fa061ec3e8c5d5c81a41e81a10fff51538160307b064229d8537317b4f"},{"type":"text","text":"\n\n好，修復。Ollama API 是 `/api/chat` 不是 `/v1/chat/completions`。重新寫入 tina_bridge.py：\n"},{"type":"toolCall","id":"call_function_wcqkakm7elq4_1","name":"write","arguments":{"content":"# -*- coding: utf-8 -*-\n\"\"\"\nRay Tina Bridge - Ollama Local Model Integration Layer\nCompatible with OpenClaw Agent workspace\n\nUsage:\n  from tina_bridge import TinaBridge\n  bridge = TinaBridge(model=\"qwen2.5:1.5b\")\n  result = bridge.ask_logic(\"提煉買入策略\", context_data)\n\"\"\"\n\nimport requests\nimport json\nfrom typing import Optional, Dict\n\nDEFAULT_URL   = \"http://localhost:11434/api/chat\"  # Ollama native API\nDEFAULT_MODEL = \"qwen2.5:1.5b\"\n\n\nclass TinaBridge:\n    \"\"\"\n    Sends quant logic requests to local Qwen via Ollama.\n    NL2Code validation ensures stable JSON output.\n    \"\"\"\n\n    def __init__(self, model: str = DEFAULT_MODEL, base_url: str = DEFAULT_URL):\n        self.url   = base_url\n        self.model = model\n\n    def ask_logic(self, prompt: str, context_data: str = \"\") -> str:\n        \"\"\"\n        Send task to local Qwen, return JSON string.\n        Returns error JSON on failure.\n        \"\"\"\n        system_prompt = (\n            \"You are Ray's quant logic unit. Tina Architecture Edition. \"\n            \"Always output valid JSON. No natural language. \"\n            \"Schema: {\\\"strategy_name\\\":\\\"...\\\",\\\"indicator\\\":\\\"...\\\",\"\n            \"\\\"params\\\":{},\\\"entry_condition\\\":{},\\\"stop_loss\\\":0.0}\"\n        )\n\n        payload = {\n            \"model\":     self.model,\n            \"messages\": [\n                {\"role\": \"system\", \"content\": system_prompt},\n                {\"role\": \"user\",   \"content\": f\"Context:\\n{context_data}\\n\\nTask:\\n{prompt}\"}\n            ],\n            \"temperature\": 0.1,\n            \"stream\":     False,\n        }\n\n        try:\n            resp = requests.post(self.url, json=payload, timeout=120)\n            resp.raise_for_status()\n            content = resp.json()[\"message\"][\"content\"]\n            json.loads(content)  # validate\n            return content\n\n        except requests.exceptions.ConnectionError:\n            return '{\"error\": \"Ollama not running\", \"details\": \"Start ollama serve\"}'\n        except json.JSONDecodeError:\n            return f'{{\"error\": \"Invalid JSON from model\", \"details\": \"{content[:200]}\"}}'\n        except Exception as e:\n            return f'{{\"error\": \"Bridge failure\", \"details\": \"{str(e)}\"}}'\n\n    def batch_ask(self, tasks: list) -> list:\n        \"\"\"Batch query multiple tasks.\"\"\"\n        return [self.ask_logic(t[\"prompt\"], t.get(\"context\", \"\")) for t in tasks]\n\n\nif __name__ == \"__main__\":\n    bridge = TinaBridge()\n    data = \"Stock: NVDA | RSI: 28 | Foreign Net Buy: +5000 | Sharpe: 1.8 | MDD: 0.08 | WinRate: 55%\"\n    result = bridge.ask_logic(\"輸出嚴格 JSON 策略\", data)\n    print(result)\n    parsed = json.loads(result)\n    print(f\"Strategy: {parsed.get('strategy_name', 'N/A')}\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\tina_bridge.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":288,"output":773,"cacheRead":93952,"cacheWrite":0,"totalTokens":95013,"cost":{"input":0.0000864,"output":0.0009276,"cacheRead":0.00563712,"cacheWrite":0,"total":0.00665112}},"stopReason":"toolUse","timestamp":1778514709368,"responseId":"06512e188273c346c1bc6c469a71e90f"}}
