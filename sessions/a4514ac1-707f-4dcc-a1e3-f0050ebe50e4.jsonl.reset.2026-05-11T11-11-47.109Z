ascii=False)\n        found = re.findall(r'\\\"(\\d{4,6})\\\"', text)\n        codes = sorted([c for c in found if 1000 <= int(c) <= 99999])\n        print(f\\\"  TWSE stocks fetched: {len(codes)}\\\")\n        return codes[:600]\n    except Exception as e:\n        print(f\\\"  TWSE fetch failed: {e}, using fallback list\\\")\n        return FALLBACK_TWSE\n\ndef fetch_sp500():\n    url = \\\"https://en.wikipedia.org/wiki/List_of_S%26P_500_companies\\\"\n    try:\n        tables = pd.read_html(url)\n        syms = [str(s).replace(\\\".\\\", \\\"-\\\") for s in tables[0][\\\"Symbol\\\"].dropna()]\n        print(f\\\"  S&P500 fetched: {len(syms)} stocks\\\")\n        return syms\n    except Exception as e:\n        print(f\\\"  S&P500 fetch failed: {e}\\\")\n        return []\n\ndef fetch_nasdaq100():\n    url = \\\"https://en.wikipedia.org/wiki/NASDAQ-100\\\"\n    try:\n        tables = pd.read_html(url)\n        syms = [str(s).replace(\\\".\\\", \\\"-\\\") for s in tables[4][\\\"Ticker\\\"].dropna()]\n        print(f\\\"  NASDAQ100 fetched: {len(syms)} stocks\\\")\n        return syms\n    except Exception as e:\n        print(f\\\"  NASDAQ100 fetch failed: {e}\\\")\n        return []\n\ndef fetch_sox30():\n    return [\n        \\\"NVDA\\\",\\\"AMD\\\",\\\"INTC\\\",\\\"AMAT\\\",\\\"LRCX\\\",\\\"MU\\\",\\\"MCHP\\\",\\\"QRVO\\\",\\\"QCOM\\\",\n        \\\"AVGO\\\",\\\"TXN\\\",\\\"ADI\\\",\\\"SWKS\\\",\\\"CRUS\\\",\\\"MPWR\\\",\\\"ON\\\",\\\"NXPI\\\",\\\"GFS\\\",\n        \\\"ENTG\\\",\\\"KLAC\\\",\\\"TER\\\",\\\"ALAB\\\",\\\"LTHM\\\",\\\"VSH\\\",\\\"DIOD\\\",\\\"AXTI\\\",\n        \\\"FORM\\\",\\\"SNPS\\\",\\\"CDNS\\\",\\\"ASML\\\"\n    ]\n\n# ========================\n# Vegas Signal\n# ========================\ndef vegas_signal(close, volume):\n    if len(close) < 200: return None\n\n    ema12  = close.ewm(span=12,  adjust=False).mean()\n    ema144 = close.ewm(span=144, adjust=False).mean()\n    ema169 = close.ewm(span=169, adjust=False).mean()\n    ema576 = close.ewm(span=576, adjust=False).mean()\n    ema676 = close.ewm(span=676, adjust=False).mean()\n\n    c    = close.iloc[-1]\n    c1   = close.iloc[-2] if len(close)>1 else c\n    e12  = ema12.iloc[-1]\n    e144 = ema144.iloc[-1]\n    e169 = ema169.iloc[-1]\n    e576 = ema576.iloc[-1]\n    e676 = ema676.iloc[-1]\n    v    = volume.iloc[-1]\n    e12"},"partialJson":"{\"command\":\"C:\\\\Users\\\\USER\\\\AppData\\\\Local\\\\Programs\\\\Python\\\\Python312\\\\python.exe -c \\\"\\nimport os\\nscript = '''\\\\\\\"\\\\\\\"\\\\\\\"\\nVegas Tunnel 掃描器 - 全市場版\\n台股 TWSE 500: FinMind(優先) / yfinance(備用)\\n美股 S&P500 / NASDAQ100 / SOX30: yfinance(即時)\\n執行: python vegas_scan.py\\n\\\\\\\"\\\\\\\"\\\\\\\"\\n\\nimport sys, os\\nsys.path.insert(0, r\\\\\\\"C:\\\\\\\\\\\\\\\\Users\\\\\\\\\\\\\\\\USER\\\\\\\\\\\\\\\\AppData\\\\\\\\\\\\\\\\Local\\\\\\\\\\\\\\\\Programs\\\\\\\\\\\\\\\\Python\\\\\\\\\\\\\\\\Python312\\\\\\\\\\\\\\\\Lib\\\\\\\\\\\\\\\\site-packages\\\\\\\")\\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\\n\\nimport yfinance as yf\\nfrom FinMind.data import DataLoader\\nimport pandas as pd\\nimport numpy as np\\nfrom datetime import datetime, timedelta\\nimport warnings, ssl, json, urllib.request, re\\nwarnings.filterwarnings(\\\\\\\"ignore\\\\\\\")\\n\\nMIN_SCORE = 3\\nBACKTEST_DAYS = 700\\n\\n# ========================\\n# Stock List Loaders\\n# ========================\\ndef fetch_twse_list():\\n    ctx = ssl.create_default_context()\\n    ctx.check_hostname = False\\n    ctx.verify_mode = ssl.CERT_NONE\\n    headers = {\\\\\\\"User-Agent\\\\\\\": \\\\\\\"Mozilla/5.0\\\\\\\"}\\n    url = \\\\\\\"https://www.twse.com.tw/rwd/zh/afterTrading/MI_INDEX?date=&type=ALL&response=json\\\\\\\"\\n    try:\\n        req = urllib.request.Request(url, headers=headers)\\n        resp = urllib.request.urlopen(req, context=ctx, timeout=10)\\n        raw = json.loads(resp.read())\\n        text = json.dumps(raw, ensure_ascii=False)\\n        found = re.findall(r'\\\\\\\"(\\\\d{4,6})\\\\\\\"', text)\\n        codes = sorted([c for c in found if 1000 <= int(c) <= 99999])\\n        print(f\\\\\\\"  TWSE stocks fetched: {len(codes)}\\\\\\\")\\n        return codes[:600]\\n    except Exception as e:\\n        print(f\\\\\\\"  TWSE fetch failed: {e}, using fallback list\\\\\\\")\\n        return FALLBACK_TWSE\\n\\ndef fetch_sp500():\\n    url = \\\\\\\"https://en.wikipedia.org/wiki/List_of_S%26P_500_companies\\\\\\\"\\n    try:\\n        tables = pd.read_html(url)\\n        syms = [str(s).replace(\\\\\\\".\\\\\\\", \\\\\\\"-\\\\\\\") for s in tables[0][\\\\\\\"Symbol\\\\\\\"].dropna()]\\n        print(f\\\\\\\"  S&P500 fetched: {len(syms)} stocks\\\\\\\")\\n        return syms\\n    except Exception as e:\\n        print(f\\\\\\\"  S&P500 fetch failed: {e}\\\\\\\")\\n        return []\\n\\ndef fetch_nasdaq100():\\n    url = \\\\\\\"https://en.wikipedia.org/wiki/NASDAQ-100\\\\\\\"\\n    try:\\n        tables = pd.read_html(url)\\n        syms = [str(s).replace(\\\\\\\".\\\\\\\", \\\\\\\"-\\\\\\\") for s in tables[4][\\\\\\\"Ticker\\\\\\\"].dropna()]\\n        print(f\\\\\\\"  NASDAQ100 fetched: {len(syms)} stocks\\\\\\\")\\n        return syms\\n    except Exception as e:\\n        print(f\\\\\\\"  NASDAQ100 fetch failed: {e}\\\\\\\")\\n        return []\\n\\ndef fetch_sox30():\\n    return [\\n        \\\\\\\"NVDA\\\\\\\",\\\\\\\"AMD\\\\\\\",\\\\\\\"INTC\\\\\\\",\\\\\\\"AMAT\\\\\\\",\\\\\\\"LRCX\\\\\\\",\\\\\\\"MU\\\\\\\",\\\\\\\"MCHP\\\\\\\",\\\\\\\"QRVO\\\\\\\",\\\\\\\"QCOM\\\\\\\",\\n        \\\\\\\"AVGO\\\\\\\",\\\\\\\"TXN\\\\\\\",\\\\\\\"ADI\\\\\\\",\\\\\\\"SWKS\\\\\\\",\\\\\\\"CRUS\\\\\\\",\\\\\\\"MPWR\\\\\\\",\\\\\\\"ON\\\\\\\",\\\\\\\"NXPI\\\\\\\",\\\\\\\"GFS\\\\\\\",\\n        \\\\\\\"ENTG\\\\\\\",\\\\\\\"KLAC\\\\\\\",\\\\\\\"TER\\\\\\\",\\\\\\\"ALAB\\\\\\\",\\\\\\\"LTHM\\\\\\\",\\\\\\\"VSH\\\\\\\",\\\\\\\"DIOD\\\\\\\",\\\\\\\"AXTI\\\\\\\",\\n        \\\\\\\"FORM\\\\\\\",\\\\\\\"SNPS\\\\\\\",\\\\\\\"CDNS\\\\\\\",\\\\\\\"ASML\\\\\\\"\\n    ]\\n\\n# ========================\\n# Vegas Signal\\n# ========================\\ndef vegas_signal(close, volume):\\n    if len(close) < 200: return None\\n\\n    ema12  = close.ewm(span=12,  adjust=False).mean()\\n    ema144 = close.ewm(span=144, adjust=False).mean()\\n    ema169 = close.ewm(span=169, adjust=False).mean()\\n    ema576 = close.ewm(span=576, adjust=False).mean()\\n    ema676 = close.ewm(span=676, adjust=False).mean()\\n\\n    c    = close.iloc[-1]\\n    c1   = close.iloc[-2] if len(close)>1 else c\\n    e12  = ema12.iloc[-1]\\n    e144 = ema144.iloc[-1]\\n    e169 = ema169.iloc[-1]\\n    e576 = ema576.iloc[-1]\\n    e676 = ema676.iloc[-1]\\n    v    = volume.iloc[-1]\\n    e12","index":1}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":81744,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":81744,"cost":{"input":0.0245232,"output":0,"cacheRead":0,"cacheWrite":0,"total":0.0245232}},"stopReason":"stop","timestamp":1778492330330,"responseId":"0650d6acd0021fd0cb3f261a48cd8093"}}
