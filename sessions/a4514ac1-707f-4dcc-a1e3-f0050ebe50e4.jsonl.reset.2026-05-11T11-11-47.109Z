{"type":"message","id":"885b8c05","parentId":"6bca203a","timestamp":"2026-05-11T09:36:36.261Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, yfinance works. Now let me write the comprehensive updated vegas_scan.py with:\n1. S&P 500, NASDAQ 100, SOX 30 → yfinance (real-time)\n2. TWSE 500 → FinMind (primary, Shioaji backup if available)\n3. Vegas scanning logic for all\n\nLet me write this properly. I'll get the S&P 500 and NASDAQ 100 components from yfinance/some source.\n","thinkingSignature":"9e3c8eebed594fd78a590a4355a707098ab7f41440abd4203e3d2b6fb414769f"},{"type":"toolCall","id":"call_function_jrhxp1802d62_1","name":"write","arguments":{"content":"\"\"\"\nVegas Tunnel 掃描器 - 完整版\n適用：台股 TWSE 500 + 美股 S&P500/NASDAQ100/SOXX 30\n來源：TWSE→FinMind(優先)/yfinance(備用) | US→yfinance(即時)\n\n執行：python vegas_scan.py\n\"\"\"\n\nimport sys, os\nsys.path.insert(0, r'C:\\Users\\USER\\AppData\\Local\\Programs\\Python\\Python312\\Lib\\site-packages')\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\n\nimport yfinance as yf\nfrom FinMind.data import DataLoader\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ========================\n# 參數\n# ========================\nMIN_SCORE = 3\nTWSE_START_DATE = (datetime.today() - timedelta(days=700)).strftime('%Y-%m-%d')\nTWSE_END_DATE   = datetime.today().strftime('%Y-%m-%d')\n\n# ========================\n# Stock Pools（動態抓取）\n# ========================\ndef fetch_sp500():\n    \"\"\"從 Wikipedia 抓 S&P 500 成分股\"\"\"\n    try:\n        tables = pd.read_html('https://en.wikipedia.org/wiki/List_of_S%26P_500_companies')\n        df = tables[0]\n        return df['Symbol'].tolist()\n    except Exception as e:\n        print(f\"⚠️ S&P500 fetch failed: {e}\")\n        return []\n\ndef fetch_nasdaq100():\n    \"\"\"從 Wikipedia 抓 NASDAQ-100 成分股\"\"\"\n    try:\n        tables = pd.read_html('https://en.wikipedia.org/wiki/NASDAQ-100')\n        df = tables[4]  # 通常第4個table是成分股\n        return df['Symbol'].tolist()\n    except Exception as e:\n        print(f\"⚠️ NASDAQ100 fetch failed: {e}\")\n        return []\n\ndef fetch_sox30():\n    \"\"\"SOX 30 半導體股指成分股（費城半導體指數）\"\"\"\n    # 根據費城半導體指數成分股（2024年版本）\n    return [\n        \"NVDA\",\"AMD\",\"INTC\",\"AMAT\",\"LRCX\",\"MU\",\"MCHP\",\"QRVO\",\"QCOM\",\n        \"AVGO\",\"TXN\",\"ADI\",\"SWKS\",\"CRUS\",\"MPWR\",\"ON\",\"NXPI\",\"GFS\",\n        \"ENTG\",\"KLAC\",\"TER\",\"ALAB\",\"LTHM\",\"VSH\",\"DIOD\",\"AXTI\",\n        \"FORM\",\"SNPS\",\"CDNS\",\"ASML\"\n    ]\n\ndef fetch_twse_top500():\n    \"\"\"從 TWSE 官網取得上市公司完整清單（依代碼排序）\"\"\"\n    try:\n        url = 'https://www.twse.com.tw/rwd/zh/listed/companyList?type=csv'\n        r = pd.read_csv(url)\n        codes = r['公司代號'].dropna().astype(str).tolist()\n        # 過濾：只留 4-6 碼數字（上市股票）\n        codes = [c for c in codes if c.isdigit() and 4 <= len(c) <= 6]\n        return codes[:600]  # 取前 600 檔\n    except Exception as e:\n        print(f\"⚠️ TWSE fetch failed: {e}\")\n        return []\n\n# ========================\n# EMA 計算\n# ========================\ndef calc_ema(series: pd.Series, period: int) -> pd.Series:\n    return series.ewm(span=period, adjust=False).mean()\n\n# ========================\n# Vegas 信號\n# ========================\ndef vegas_signal(close: pd.Series, volume: pd.Series):\n    if len(close) < 200:\n        return None\n\n    ema12  = calc_ema(close, 12)\n    ema144 = calc_ema(close, 144)\n    ema169 = calc_ema(close, 169)\n    ema576 = calc_ema(close, 576)\n    ema676 = calc_ema(close, 676)\n\n    c     = close.iloc[-1]\n    c1    = close.iloc[-2]  if len(close) > 1 else c\n    e12   = ema12.iloc[-1]\n    e144  = ema144.iloc[-1]\n    e169  = ema169.iloc[-1]\n    e576  = ema576.iloc[-1]\n    e676  = ema676.iloc[-1]\n    v_now = volume.iloc[-1]\n\n    e12_1  = ema12.iloc[-2]  if len(ema12)  > 1 else e12\n    e144_1 = ema144.iloc[-2] if len(ema144) > 1 else e144\n\n    # 隧道狀態\n    tunnel_bull = (e144 > e169) and (e144 > e144_1) and (e169 > ema169.iloc[-2])\n    bigtrend_bull = (c > e576) and (c > e676) and (e576 > e676) and (e576 > ema576.iloc[-2])\n\n    # 突破\n    price_breakout_up = (c > e144) and (c > e169) and (c1 <= e144)\n    ema12_confirm_up  = (e12 > e144) and (e12 > e169) and (e12_1 <= e144)\n    false_breakout    = price_breakout_up and not ema12_confirm_up\n\n    # RSI\n    delta = close.diff()\n    gain = delta.clip(lower=0).ewm(alpha=1/14, adjust=False).mean()\n    loss = (-delta.clip(upper=0)).ewm(alpha=1/14, adjust=False).mean()\n    rsi14 = (100 - (100 / (1 + gain/loss))).iloc[-1]\n\n    # 評分\n    score = 0\n    if tunnel_bull:    score += 1\n    if bigtrend_bull:  score += 1\n    if price_breakout_up and ema12_confirm_up and not false_breakout: score += 2\n    if rsi14 < 80:     score += 1\n    score = min(score, 5)\n\n    tunnel_width = (e144 - e169) / e169 * 100 if e169 != 0 else 0\n\n    if price_breakout_up and ema12_confirm_up and tunnel_bull and bigtrend_bull and not false_breakout:\n        trend, breakout = 'BULL', True\n    elif tunnel_bull and bigtrend_bull:\n        trend, breakout = 'BULL_LAGGING', False\n    else:\n        trend, breakout = 'NEUTRAL', False\n\n    return {\n        'close': round(c, 2),\n        'ema12': round(e12, 2),\n        'ema144': round(e144, 2),\n        'ema169': round(e169, 2),\n        'ema576': round(e576, 2),\n        'ema676': round(e676, 2),\n        'tunnel_width': round(tunnel_width, 3),\n        'rsi14': round(rsi14, 1),\n        'score': score,\n        'breakout': breakout,\n        'trend': trend,\n        'volume': int(v_now),\n    }\n\n# ========================\n# 掃描器：TWSE → FinMind（優先）/ yfinance（備用）\n# ========================\ndef scan_twse_finmind(codes: list):\n    \"\"\"用 FinMind 掃 TWSE 股票（優先）\"\"\"\n    dl = DataLoader()\n    results = []\n    total = len(codes)\n    fetched = 0\n\n    for i, code in enumerate(codes):\n        if (i+1) % 50 == 0 or (i+1) == total:\n            print(f\"  TWSE FinMind: {i+1}/{total} ({(i+1)*100//total}%)\")\n        try:\n            df = dl.taiwan_stock_daily(stock_id=code, start_date=TWSE_START_DATE, end_date=TWSE_END_DATE)\n            fetched += 1\n        except:\n            continue\n\n        if df is None or len(df) < 200:\n            continue\n\n        df = df.rename(columns={'open':'open','max':'high','min':'low','close':'close"},"partialJson":"{\"content\":\"\\\"\\\"\\\"\\nVegas Tunnel 掃描器 - 完整版\\n適用：台股 TWSE 500 + 美股 S&P500/NASDAQ100/SOXX 30\\n來源：TWSE→FinMind(優先)/yfinance(備用) | US→yfinance(即時)\\n\\n執行：python vegas_scan.py\\n\\\"\\\"\\\"\\n\\nimport sys, os\\nsys.path.insert(0, r'C:\\\\Users\\\\USER\\\\AppData\\\\Local\\\\Programs\\\\Python\\\\Python312\\\\Lib\\\\site-packages')\\nsys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))\\n\\nimport yfinance as yf\\nfrom FinMind.data import DataLoader\\nimport pandas as pd\\nimport numpy as np\\nfrom datetime import datetime, timedelta\\nimport warnings\\nwarnings.filterwarnings('ignore')\\n\\n# ========================\\n# 參數\\n# ========================\\nMIN_SCORE = 3\\nTWSE_START_DATE = (datetime.today() - timedelta(days=700)).strftime('%Y-%m-%d')\\nTWSE_END_DATE   = datetime.today().strftime('%Y-%m-%d')\\n\\n# ========================\\n# Stock Pools（動態抓取）\\n# ========================\\ndef fetch_sp500():\\n    \\\"\\\"\\\"從 Wikipedia 抓 S&P 500 成分股\\\"\\\"\\\"\\n    try:\\n        tables = pd.read_html('https://en.wikipedia.org/wiki/List_of_S%26P_500_companies')\\n        df = tables[0]\\n        return df['Symbol'].tolist()\\n    except Exception as e:\\n        print(f\\\"⚠️ S&P500 fetch failed: {e}\\\")\\n        return []\\n\\ndef fetch_nasdaq100():\\n    \\\"\\\"\\\"從 Wikipedia 抓 NASDAQ-100 成分股\\\"\\\"\\\"\\n    try:\\n        tables = pd.read_html('https://en.wikipedia.org/wiki/NASDAQ-100')\\n        df = tables[4]  # 通常第4個table是成分股\\n        return df['Symbol'].tolist()\\n    except Exception as e:\\n        print(f\\\"⚠️ NASDAQ100 fetch failed: {e}\\\")\\n        return []\\n\\ndef fetch_sox30():\\n    \\\"\\\"\\\"SOX 30 半導體股指成分股（費城半導體指數）\\\"\\\"\\\"\\n    # 根據費城半導體指數成分股（2024年版本）\\n    return [\\n        \\\"NVDA\\\",\\\"AMD\\\",\\\"INTC\\\",\\\"AMAT\\\",\\\"LRCX\\\",\\\"MU\\\",\\\"MCHP\\\",\\\"QRVO\\\",\\\"QCOM\\\",\\n        \\\"AVGO\\\",\\\"TXN\\\",\\\"ADI\\\",\\\"SWKS\\\",\\\"CRUS\\\",\\\"MPWR\\\",\\\"ON\\\",\\\"NXPI\\\",\\\"GFS\\\",\\n        \\\"ENTG\\\",\\\"KLAC\\\",\\\"TER\\\",\\\"ALAB\\\",\\\"LTHM\\\",\\\"VSH\\\",\\\"DIOD\\\",\\\"AXTI\\\",\\n        \\\"FORM\\\",\\\"SNPS\\\",\\\"CDNS\\\",\\\"ASML\\\"\\n    ]\\n\\ndef fetch_twse_top500():\\n    \\\"\\\"\\\"從 TWSE 官網取得上市公司完整清單（依代碼排序）\\\"\\\"\\\"\\n    try:\\n        url = 'https://www.twse.com.tw/rwd/zh/listed/companyList?type=csv'\\n        r = pd.read_csv(url)\\n        codes = r['公司代號'].dropna().astype(str).tolist()\\n        # 過濾：只留 4-6 碼數字（上市股票）\\n        codes = [c for c in codes if c.isdigit() and 4 <= len(c) <= 6]\\n        return codes[:600]  # 取前 600 檔\\n    except Exception as e:\\n        print(f\\\"⚠️ TWSE fetch failed: {e}\\\")\\n        return []\\n\\n# ========================\\n# EMA 計算\\n# ========================\\ndef calc_ema(series: pd.Series, period: int) -> pd.Series:\\n    return series.ewm(span=period, adjust=False).mean()\\n\\n# ========================\\n# Vegas 信號\\n# ========================\\ndef vegas_signal(close: pd.Series, volume: pd.Series):\\n    if len(close) < 200:\\n        return None\\n\\n    ema12  = calc_ema(close, 12)\\n    ema144 = calc_ema(close, 144)\\n    ema169 = calc_ema(close, 169)\\n    ema576 = calc_ema(close, 576)\\n    ema676 = calc_ema(close, 676)\\n\\n    c     = close.iloc[-1]\\n    c1    = close.iloc[-2]  if len(close) > 1 else c\\n    e12   = ema12.iloc[-1]\\n    e144  = ema144.iloc[-1]\\n    e169  = ema169.iloc[-1]\\n    e576  = ema576.iloc[-1]\\n    e676  = ema676.iloc[-1]\\n    v_now = volume.iloc[-1]\\n\\n    e12_1  = ema12.iloc[-2]  if len(ema12)  > 1 else e12\\n    e144_1 = ema144.iloc[-2] if len(ema144) > 1 else e144\\n\\n    # 隧道狀態\\n    tunnel_bull = (e144 > e169) and (e144 > e144_1) and (e169 > ema169.iloc[-2])\\n    bigtrend_bull = (c > e576) and (c > e676) and (e576 > e676) and (e576 > ema576.iloc[-2])\\n\\n    # 突破\\n    price_breakout_up = (c > e144) and (c > e169) and (c1 <= e144)\\n    ema12_confirm_up  = (e12 > e144) and (e12 > e169) and (e12_1 <= e144)\\n    false_breakout    = price_breakout_up and not ema12_confirm_up\\n\\n    # RSI\\n    delta = close.diff()\\n    gain = delta.clip(lower=0).ewm(alpha=1/14, adjust=False).mean()\\n    loss = (-delta.clip(upper=0)).ewm(alpha=1/14, adjust=False).mean()\\n    rsi14 = (100 - (100 / (1 + gain/loss))).iloc[-1]\\n\\n    # 評分\\n    score = 0\\n    if tunnel_bull:    score += 1\\n    if bigtrend_bull:  score += 1\\n    if price_breakout_up and ema12_confirm_up and not false_breakout: score += 2\\n    if rsi14 < 80:     score += 1\\n    score = min(score, 5)\\n\\n    tunnel_width = (e144 - e169) / e169 * 100 if e169 != 0 else 0\\n\\n    if price_breakout_up and ema12_confirm_up and tunnel_bull and bigtrend_bull and not false_breakout:\\n        trend, breakout = 'BULL', True\\n    elif tunnel_bull and bigtrend_bull:\\n        trend, breakout = 'BULL_LAGGING', False\\n    else:\\n        trend, breakout = 'NEUTRAL', False\\n\\n    return {\\n        'close': round(c, 2),\\n        'ema12': round(e12, 2),\\n        'ema144': round(e144, 2),\\n        'ema169': round(e169, 2),\\n        'ema576': round(e576, 2),\\n        'ema676': round(e676, 2),\\n        'tunnel_width': round(tunnel_width, 3),\\n        'rsi14': round(rsi14, 1),\\n        'score': score,\\n        'breakout': breakout,\\n        'trend': trend,\\n        'volume': int(v_now),\\n    }\\n\\n# ========================\\n# 掃描器：TWSE → FinMind（優先）/ yfinance（備用）\\n# ========================\\ndef scan_twse_finmind(codes: list):\\n    \\\"\\\"\\\"用 FinMind 掃 TWSE 股票（優先）\\\"\\\"\\\"\\n    dl = DataLoader()\\n    results = []\\n    total = len(codes)\\n    fetched = 0\\n\\n    for i, code in enumerate(codes):\\n        if (i+1) % 50 == 0 or (i+1) == total:\\n            print(f\\\"  TWSE FinMind: {i+1}/{total} ({(i+1)*100//total}%)\\\")\\n        try:\\n            df = dl.taiwan_stock_daily(stock_id=code, start_date=TWSE_START_DATE, end_date=TWSE_END_DATE)\\n            fetched += 1\\n        except:\\n            continue\\n\\n        if df is None or len(df) < 200:\\n            continue\\n\\n        df = df.rename(columns={'open':'open','max':'high','min':'low','close':'close","index":1}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":73308,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":73308,"cost":{"input":0.0219924,"output":0,"cacheRead":0,"cacheWrite":0,"total":0.0219924}},"stopReason":"stop","timestamp":1778492115226,"responseId":"0650d5d42a9b7e8552cdf1a5c366b7cb"}}
