{"type":"message","id":"577d0f86","parentId":"2785ec94","timestamp":"2026-05-11T11:07:55.116Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Jo wants me to create a Streamlit app for the Vegas scanner and upload it to TryCloudflare. Let me do that.\n\nLet me:\n1. Kill the running scan first (already killed)\n2. Create a Streamlit app for vegas_scan\n3. Upload it using trycloudflare\n","thinkingSignature":"e129327d3bb71130f4398c16a39bc718740b6759b75f90a19cee665178826349"},{"type":"text","text":"\n\n好，做一個 Streamlit 版 + 丢上 TryCloudflare！📈\n"},{"type":"toolCall","id":"call_function_mksjuwroe39k_1","name":"write","arguments":{"content":"\"\"\"\nVegas Tunnel Scanner - Streamlit App\nRun: streamlit run vegas_streamlit.py\n\"\"\"\n\nimport sys\nsys.path.insert(0, r\"C:\\Users\\USER\\AppData\\Local\\Programs\\Python\\Python312\\Lib\\site-packages\")\n\nimport streamlit as st\nimport yfinance as yf\nimport pandas as pd\nimport numpy as np\nfrom datetime import datetime, timedelta\nimport requests\nfrom io import StringIO\nimport time\n\nst.set_page_config(page_title=\"Vegas Tunnel Scanner\", page_icon=\"📈\", layout=\"wide\")\nst.title(\"📈 Vegas Tunnel Scanner\")\n\n# ========================\n# Vegas Signal\n# ========================\ndef calc_ema(series, span):\n    return series.ewm(span=span, adjust=False).mean()\n\ndef vegas_signal(close, volume):\n    if len(close) < 200:\n        return None\n    ema12  = calc_ema(close, 12)\n    ema144 = calc_ema(close, 144)\n    ema169 = calc_ema(close, 169)\n    ema576 = calc_ema(close, 576)\n    ema676 = calc_ema(close, 676)\n    c  = close.iloc[-1]\n    c1 = close.iloc[-2] if len(close) > 1 else c\n    e12  = ema12.iloc[-1]\n    e144 = ema144.iloc[-1]\n    e169 = ema169.iloc[-1]\n    e576 = ema576.iloc[-1]\n    e676 = ema676.iloc[-1]\n    v    = volume.iloc[-1]\n    e12_1  = ema12.iloc[-2]  if len(ema12)  > 1 else e12\n    e144_1 = ema144.iloc[-2] if len(ema144) > 1 else e144\n    tunnel_bull    = (e144 > e169) and (e144 > e144_1) and (e169 > ema169.iloc[-2])\n    bigtrend_bull  = (c > e576) and (c > e676) and (e576 > e676) and (e576 > ema576.iloc[-2])\n    price_breakout = (c > e144) and (c > e169) and (c1 <= e144)\n    ema12_confirm  = (e12 > e144) and (e12 > e169) and (e12_1 <= e144)\n    false_breakout = price_breakout and not ema12_confirm\n    delta = close.diff()\n    gain  = delta.clip(lower=0).ewm(alpha=1/14, adjust=False).mean()\n    loss  = (-delta.clip(upper=0)).ewm(alpha=1/14, adjust=False).mean()\n    rsi14 = float((100 - (100/(1+gain/loss))).iloc[-1])\n    score = 0\n    if tunnel_bull:    score += 1\n    if bigtrend_bull:  score += 1\n    if price_breakout and ema12_confirm and not false_breakout: score += 2\n    if rsi14 < 80:     score += 1\n    score = min(score, 5)\n    if price_breakout and ema12_confirm and tunnel_bull and bigtrend_bull and not false_breakout:\n        trend, breakout = \"BULL\", True\n    elif tunnel_bull and bigtrend_bull:\n        trend, breakout = \"BULL_LAGGING\", False\n    else:\n        trend, breakout = \"NEUTRAL\", False\n    return dict(\n        close=float(c), ema12=float(e12), ema144=float(e144), ema169=float(e169),\n        ema576=float(e576), ema676=float(e676), rsi14=rsi14,\n        score=score, breakout=breakout, trend=trend, volume=int(v)\n    )\n\n# ========================\n# Data Loaders\n# ========================\ndef fetch_sp500():\n    url = \"https://en.wikipedia.org/wiki/List_of_S%26P_500_companies\"\n    try:\n        r = requests.get(url, headers={\"User-Agent\":\"Mozilla/5.0\"}, timeout=10)\n        tables = pd.read_html(StringIO(r.text))\n        return [str(s).replace(\".\",\"-\") for s in tables[0][\"Symbol\"].dropna()]\n    except:\n        return []\n\ndef fetch_nasdaq100():\n    url = \"https://en.wikipedia.org/wiki/NASDAQ-100\"\n    try:\n        r = requests.get(url, headers={\"User-Agent\":\"Mozilla/5.0\"}, timeout=10)\n        tables = pd.read_html(StringIO(r.text))\n        for t in tables:\n            if \"Ticker\" in list(t.columns):\n                return [str(s).replace(\".\",\"-\") for s in t[\"Ticker\"].dropna()]\n        return []\n    except:\n        return []\n\nSOX30 = [\"NVDA\",\"AMD\",\"INTC\",\"AMAT\",\"LRCX\",\"MU\",\"MCHP\",\"QRVO\",\"QCOM\",\"AVGO\",\"TXN\",\"ADI\",\"SWKS\",\"CRUS\",\"MPWR\",\"ON\",\"NXPI\",\"GFS\",\"ENTG\",\"KLAC\",\"TER\",\"ALAB\",\"LTHM\",\"VSH\",\"DIOD\",\"AXTI\",\"FORM\",\"SNPS\",\"CDNS\",\"ASML\"]\n\nTWSE_TOP200 = [\n    \"2330\",\"2317\",\"2454\",\"2303\",\"2308\",\"2377\",\"2357\",\"2382\",\"2376\",\"2395\",\"2408\",\"2379\",\"2449\",\"2468\",\"2472\",\"2478\",\"2492\",\"3034\",\"3036\",\"3231\",\"3443\",\"3504\",\"3530\",\"3545\",\"3583\",\"3661\",\"3682\",\"3702\",\"3711\",\"4919\",\"4952\",\"5225\",\"5871\",\"5880\",\"6024\",\"6116\",\"6176\",\"6214\",\"6239\",\"6269\",\"6271\",\"6409\",\"6443\",\"6552\",\"6573\",\"6579\",\"6589\",\"6592\",\"6625\",\"6669\",\"6670\",\"6706\",\"6770\",\"8016\",\"8028\",\"8033\",\"8046\",\"8081\",\"8104\",\"8114\",\"8261\",\"8367\",\"8454\",\"8464\",\"8481\",\"8926\",\"8996\",\"9802\",\"9810\",\"9933\",\"9958\",\n    \"2880\",\"2881\",\"2882\",\"2883\",\"2884\",\"2885\",\"2886\",\"2887\",\"2889\",\"2890\",\"2891\",\"2892\",\"5856\",\n    \"1101\",\"1102\",\"1301\",\"1303\",\"1304\",\"1323\",\"1402\",\"1409\",\"1414\",\"1417\",\"1470\",\"1471\",\"1476\",\"1477\",\"1503\",\"1512\",\"1513\",\"1514\",\"1515\",\"1516\",\"1517\",\"1519\",\"1521\",\"1522\",\"1523\",\"1524\",\"1525\",\"1526\",\"1527\",\"1528\",\"1529\",\"1530\",\"1531\",\"1532\",\"1533\",\"1534\",\"1535\",\"1536\",\"1537\",\"1538\",\"1539\",\"1540\",\"1541\",\"1542\",\"1543\",\"1544\",\"1545\",\"1546\",\"1547\",\"1548\",\"1549\",\"1550\",\"1551\",\"1552\",\"1553\",\"1554\",\"1555\",\"1556\",\"1557\",\"1558\",\"1559\",\"1560\",\"1561\",\"1562\",\"1563\",\"1564\",\"1565\",\"1566\",\"1567\",\"1568\",\"1569\",\"1570\",\"1571\",\"1572\",\"1573\",\"1574\",\"1575\",\"1576\",\"1577\",\"1578\",\"1579\",\"1580\",\"1581\",\"1582\",\"1583\",\"1584\",\"1585\",\"1586\",\"1587\",\n    \"1605\",\"1609\",\"1611\",\"1612\",\"1614\",\"1615\",\"1616\",\"1617\",\"1618\",\"1619\",\n    \"1702\",\"1704\",\"1707\",\"1708\",\"1709\",\"1710\",\"1711\",\"1712\",\"1713\",\"1714\",\"1715\",\"1716\",\"1717\",\"1718\",\"1719\",\"1720\",\"1721\",\"1722\",\"1723\",\"1724\",\"1725\",\"1726\",\"1727\",\"1728\",\"1729\",\"1730\",\"1731\",\"1732\",\"1733\",\"1734\",\n    \"1802\",\"1805\",\"1806\",\"1807\",\"1808\",\"1809\",\"1810\",\"1811\",\"1812\",\"1813\",\n    \"2002\",\"2008\",\"2010\",\"2012\",\"2013\",\"2014\",\"2015\",\"2016\",\"2017\",\"2018\",\"2019\",\"2020\",\"2021\",\"2022\",\"2023\",\"2024\",\"2025\",\"2026\",\"2027\",\"2028\"\n]\n\n# ========================\n# Sidebar\n# ========================\nst.sidebar.header(\"Settings\")\nmarket = st.sidebar.selectbox(\"Market\", [\"TWSE Top200\", \"S&P500\", \"NASDAQ100\", \"SOX30\", \"All Markets\"])\nmin_score = st.sidebar.slider(\"Min Score\", 1, 5, 3)\nrun_btn = st.sidebar.button(\"Run Scan\", type=\"primary\")\n\nif market == \"TWSE Top200\":\n    pool = {\"TWSE\": TWSE_TOP200}\nelif market == \"S&P500\":\n    pool = {\"SP500\": fetch_sp500()}\nelif market == \"NASDAQ100\":\n    pool = {\"NASDAQ100\": fetch_nasdaq100()}\nelif market == \"SOX30\":\n    pool = {\"SOX30\": SOX30}\nelse:\n    sp = fetch_sp500()\n    ndq = fetch_nasdaq100()\n    pool = {\"TWSE\": TWSE_TOP200, \"SP500\": sp, \"NASDAQ100\": ndq, \"SOX30\": SOX30}\n\nif run_btn:\n    all_results = {}\n    progress_bar = st.progress(0)\n    status_text = st.empty()\n    total_items = sum(len(v) for v in pool.values())\n    count = 0\n\n    for label, tickers in pool.items():\n        results = []\n        for i, t in enumerate(tickers):\n            ticker_str = f\"{t}.TW\" if label == \"TWSE\" else t\n            status_text.text(f\"Scanning {label}: {i+1}/{len(tickers)}\")\n            try:\n                tk = yf.Ticker(ticker_str)\n                h = tk.history(period=\"2y\", auto_adjust=True, timeout=5)\n                if h is None or len(h) < 200:\n                    count += 1\n                    progress_bar.progress(count / total_items)\n                    continue\n                h.columns = [c.lower() for c in h.columns]\n                sig = vegas_signal(h[\"close\"], h[\"volume\"])\n                if sig and sig[\"score\"] >= min_score:\n                    sig[\"stock_id\"] = t\n                    results.append(sig)\n            except:\n                pass\n            count += 1\n            progress_bar.progress(count / total_items)\n            if i % 10 == 0:\n                time.sleep(0.05)\n\n        if results:\n            results.sort(key=lambda x: (x[\"score\"], x[\"breakout\"]), reverse=True)\n            all_results[label] = results\n\n    status_text.text(\"Done!\")\n    progress_bar.empty()\n\n    if not all_results:\n        st.warning(\"No matches found\")\n    else:\n        for label, res in all_results.items():\n            st.subheader(f\"{label} - {len(res)} Signals\")\n            breakout = [r for r in res if r[\"breakout\"]]\n            lag      = [r for r in res if not r[\"breakout\"] and r[\"trend\"] == \"BULL_LAGGING\"]\n            st.caption(f\"  BREAKOUT: {len(breakout)} | BULL_LAG: {len(lag)}\")\n\n            df = pd.DataFrame(res)\n            df[\"Signal\"] = df.apply(lambda r: \"BREAKOUT\" if r[\"breakout\"] else (\"BULL_LAG\" if r[\"trend\"]==\"BULL_LAGGING\" else \"\"), axis=1)\n            st.dataframe(\n                df[[\"stock_id\",\"close\",\"ema12\",\"ema144\",\"ema169\",\"rsi14\",\"score\",\"Signal\"]]\n                .rename(columns={\"stock_id\":\"Ticker\",\"close\":\"Price\",\"ema12\":\"EMA12\",\"ema144\":\"T144\",\"ema169\":\"T169\",\"rsi14\":\"RSI\",\"score\":\"Score\"})\n                .sort_values(\"Score\", ascending=False),\n                use_container_width=True\n            )\n            if breakout:\n                st.success(f\"  BREAKOUT: \" + \" \".join([r[\"stock_id\"] for r in breakout]))\n\n        # Summary\n        total = sum(len(v) for v in all_results.values())\n        st.success(f\"Total: {total} signals across all markets\")\n        ts = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n        rows = []\n        for mkt, res in all_results.items():\n            for r in res:\n                r2 = dict(r)\n                r2[\"market\"] = mkt\n                rows.append(r2)\n        df_all = pd.DataFrame(rows)\n        csv = df_all.to_csv(index=False).encode(\"utf-8-sig\")\n        st.download_button(\"Download CSV\", csv, f\"vegas_results_{ts}.csv\", \"text/csv\", key=\"csv\")\nelse:\n    st.info(\"Select market and click Run Scan\")\n    st.markdown(\"---\")\n    st.caption(\"Vegas Tunnel: EMA12 + EMA144/169 (隧道) + EMA576/676 (大趨勢)\")\n    st.caption(\"Score: +1 隧道多頭 | +1 大趨勢多頭 | +2 真突破 | +1 RSI<80\")","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\vegas_streamlit.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":123061,"output":3104,"cacheRead":192,"cacheWrite":0,"totalTokens":126357,"cost":{"input":0.0369183,"output":0.0037248,"cacheRead":0.000011519999999999998,"cacheWrite":0,"total":0.04065462}},"stopReason":"toolUse","timestamp":1778497569995,"responseId":"0650eb3639e33f9ce9c7dbe1988b2eaa"}}
