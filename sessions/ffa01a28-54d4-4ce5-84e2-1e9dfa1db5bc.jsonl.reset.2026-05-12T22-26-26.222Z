{"type":"message","id":"96a73bbf","parentId":"4224d610","timestamp":"2026-05-12T15:12:29.530Z","message":{"role":"toolResult","toolCallId":"call_function_gs6mt0zeiv0s_1","toolName":"read","content":[{"type":"text","text":"\ndef get_rsi(closes):\n    d = np.diff(closes)\n    g = np.where(d > 0, d, 0)\n    l = np.where(d > 0, 0, -d)\n    ag = np.mean(g[-14:])\n    al = np.mean(l[-14:])\n    return 100 - (100 / (1 + ag / al)) if al != 0 else 50\n\ndef get_inst(symbol):\n    conn = sqlite3.connect(DB_PATH)\n    cur = conn.cursor()\n    cur.execute('SELECT foreign_net, trust_net FROM MarketData WHERE symbol = ? ORDER BY date DESC LIMIT 10', (symbol,))\n    rows = cur.fetchall()\n    conn.close()\n    f_c = t_c = 0\n    for f, t in rows:\n        if f and f > 0: f_c += 1\n        else: break\n    for f, t in rows:\n        if t and t > 0: t_c += 1\n        else: break\n    return f_c, t_c\n\ndef analyze(symbol):\n    \"\"\"分析單一股票\"\"\"\n    try:\n        df = yf.download(symbol + '.TW', period='90d', auto_adjust=True, progress=False)\n        if df is None or len(df) < 30:\n            return None\n\n[151 more lines in file. Use offset=55 to continue.]"}],"isError":false,"timestamp":1778598749529}}
