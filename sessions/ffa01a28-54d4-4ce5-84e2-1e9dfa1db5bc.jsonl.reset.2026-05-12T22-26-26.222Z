es)\n","path":"C:\\Users\\USER\\.openclaw\\agents\\ray\\fix_streamlit_toast.py"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":245,"output":508,"cacheRead":97632,"cacheWrite":0,"totalTokens":98385,"cost":{"input":0.0000735,"output":0.0006096,"cacheRead":0.005857919999999999,"cacheWrite":0,"total":0.006541019999999999}},"stopReason":"toolUse","timestamp":1778601020174,"responseId":"06527f3e29580201f879bffd07009057"}}
