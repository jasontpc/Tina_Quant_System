{"type":"message","id":"fa723bfc","parentId":"9f57bbb6","timestamp":"2026-05-12T15:49:21.998Z","message":{"role":"toolResult","toolCallId":"call_function_k855wn663v43_1","toolName":"exec","content":[{"type":"text","text":"1: # -*- coding: utf-8 -*-\r\n2: \r\n3: \"\"\"\r\n2: \r\n5: Tina Scanner v3.0 - TW+US Stock Analysis | 1000 Tech Scoring + Institutional Data + Telegram\r\n2: \r\n3: \"\"\"\r\n2: \r\n9: import os\r\n2: \r\n11: import sqlite3\r\n2: \r\n13: import subprocess\r\n2: \r\n15: import streamlit as st\r\n2: \r\n17: import yfinance as yf\r\n2: \r\n19: import numpy as np\r\n2: \r\n21: import pandas as pd\r\n2: \r\n23: import time\r\n2: \r\n25: import urllib.request\r\n2: \r\n27: import json\r\n2: \r\n29: from datetime import datetime, timedelta\r\n2: \r\n31: from pathlib import Path\r\n2: \r\n33: from concurrent.futures import ThreadPoolExecutor, as_completed\r\n2: \r\n35: import logging\r\n2: \r\n37: from logging.handlers import RotatingFileHandler\r\n2: \r\n39: # ?? Debug Log Setup ??????????????????????????????????????????????????????\r\n40: LOG_DIR = Path(__file__).parent / \"logs\"\r\n41: LOG_DIR.mkdir(exist_ok=True)\r\n42: _log = logging.getLogger(\"tina_scanner\")\r\n43: _log.setLevel(logging.INFO)\r\n44: if not _log.handlers:\r\n45:     _h = RotatingFileHandler(LOG_DIR / \"streamlit_debug.log\", maxBytes=5*1024*1024, backupCount=3, encoding=\"utf-8\")\r\n46:     _h.setFormatter(logging.Formatter(\"%(asctime)s [%(levelname)s] %(message)s\", datefmt=\"%H:%M:%S\"))\r\n47:     _log.addHandler(_h)\r\n48:     _log.info(\"=== Tina Scanner ?? ===\")\r\n2: \r\n50: # ?? Shioaji Real-Time Data (?芸? > yfinance) ????????????????????????\r\n51: _SHIOAJI_AVAILABLE = False\r\n52: try:\r\n53:     import shioaji as sj\r\n54:     _SHIOAJI_AVAILABLE = True\r\n55: except ImportError:\r\n56:     _SHIOAJI_AVAILABLE = False\r\n57:     _log.warning(\"[Shioaji] Not available in this environment, using yfinance fallback\")\r\n58: _SJ_API = None\r\n59: _SJ_READY = False\r\n2: \r\n61: import threading as _threading\r\n62: _SJ_LOGIN_LOCK = _threading.Lock()\r\n2: \r\n64: def _get_shioaji_api():\r\n65:     global _SJ_API, _SJ_READY\r\n66:     if not _SHIOAJI_AVAILABLE:\r\n67:         return None\r\n68:     if _SJ_READY:\r\n69:         return _SJ_API\r\n70:     with _SJ_LOGIN_LOCK:\r\n71:         if _SJ_READY:\r\n72:             return _SJ_API\r\n73:         try:\r\n74:             _SJ_API = sj.Shioaji(simulation=False)\r\n75:             _SJ_API.login(\r\n76:                 api_key=os.get…EY\", \"3r6UGMUX7bnxhnbrZ92sSseGVzL3C63kkBxH3WkAPsgW\"),\r\n77:                 secret_key=os.getenv(\"SJ_SECRET_KEY\", \"FCcefW9iatHvYyp3XgSYVM1VhdmZMawjQ49Mzp97WPBF\")\r\n78:             )\r\n79:             _SJ_API.activate_ca(\r\n80:                 ca_path=os.getenv(\"SJ_CA_PATH\", None),\r\n81:                 ca_passwd=os.getenv(\"SJ_CA_PASSWD\", \"\"),\r\n82:                 subscription=Sj.Subscription(\"FK,OPT\")\r\n78:             )\r\n84:             _SJ_READY = True\r\n85:             _log.info(f\"[Shioaji] Connected: {_SJ_API.stock_account.account_id}\")\r\n86:         except Exception as e:\r\n87:             _SJ_READY = False\r\n88:             _log.warning(f\"[Shioaji] Connection failed: {e}\")\r\n69:         return _SJ_API\r\n2: \r\n91: def sj_get_quote(code):\r\n92:     try:\r\n93:         api = _get_shioaji_api()\r\n94:         if not api:\r\n95:             return None\r\n96:         c = api.Contracts.Stocks[code]\r\n97:         snap = api.snapshots([c])[0]\r\n98:         return {'close': float(snap.close), 'open': float(snap.open),\r\n99:                 'high': float(snap.high), 'low': float(snap.low),\r\n100:                 'volume': int(snap.total_volume),"}],"details":{"status":"completed","exitCode":0,"durationMs":399,"aggregated":"1: # -*- coding: utf-8 -*-\r\n2: \r\n3: \"\"\"\r\n2: \r\n5: Tina Scanner v3.0 - TW+US Stock Analysis | 1000 Tech Scori